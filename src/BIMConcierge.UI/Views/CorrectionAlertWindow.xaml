<Window x:Class="BIMConcierge.UI.Views.CorrectionAlertWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        mc:Ignorable="d"
        Title="BIMConcierge - Alerta de Correção" 
        Width="420" SizeToContent="Height"
        WindowStartupLocation="Manual" WindowStyle="None" 
        AllowsTransparency="True" Background="Transparent" FontFamily="Segoe UI"
        Topmost="True">

    <Border CornerRadius="12" Background="#17191B" BorderBrush="#1E293B" BorderThickness="1" Margin="15" MouseLeftButtonDown="Border_MouseLeftButtonDown">
        <Border.Effect>
            <DropShadowEffect Color="Black" BlurRadius="20" Opacity="0.5" Direction="270" ShadowDepth="8"/>
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Background="#1E293B" CornerRadius="12,12,0,0" Padding="15,12">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0" Text="⚠️" Foreground="#F59E0B" FontSize="16" Margin="0,0,10,0" VerticalAlignment="Center"/>
                    <TextBlock Grid.Column="1" Text="Aviso de Não Conformidade" Foreground="#F59E0B" FontSize="14" FontWeight="Bold" VerticalAlignment="Center"/>

                    <Button Grid.Column="2" Content="✕" FontSize="14" Foreground="#94A3B8" Background="Transparent" BorderThickness="0"
                            Cursor="Hand" Click="BtnClose_Click" Padding="5,0" VerticalAlignment="Center"/>
                </Grid>
            </Border>

            <StackPanel Grid.Row="1" Margin="20,20,20,15">
                <TextBlock Text="Parede Básica - Genérico 200mm" FontSize="18" FontWeight="Bold" Foreground="White" Margin="0,0,0,8" TextWrapping="Wrap"/>

                <TextBlock Text="O elemento recém modelado (ID: 459281) possui um deslocamento de base negativo (-0.15m)." 
                           Foreground="#CBD5E1" FontSize="14" TextWrapping="Wrap" LineHeight="20"/>
            </StackPanel>

            <Border Grid.Row="2" Background="#121820" BorderBrush="#F59E0B" BorderThickness="4,0,0,0" CornerRadius="0,6,6,0" Margin="20,0,20,20" Padding="15">
                <StackPanel>
                    <TextBlock Text="REGRA VIOLADA" Foreground="#94A3B8" FontSize="11" FontWeight="Bold" Margin="0,0,0,5"/>
                    <TextBlock Text="Paredes externas devem nascer no nível zero do osso ou acabado, sem deslocamentos negativos. Ajuste a restrição da base." 
                               Foreground="#94A3B8" FontSize="13" TextWrapping="Wrap" LineHeight="18"/>
                </StackPanel>
            </Border>

            <Border Grid.Row="3" Background="#0F172A" CornerRadius="0,0,12,12" BorderBrush="#1E293B" BorderThickness="0,1,0,0" Padding="20,15">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="15"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <Button Grid.Column="0" Content="IGNORAR" Height="40" 
                            Background="#1E293B" Foreground="#94A3B8" FontSize="13" FontWeight="Bold" BorderThickness="0" Cursor="Hand" Click="BtnClose_Click">
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="6"/>
                            </Style>
                        </Button.Resources>
                    </Button>

                    <Button Grid.Column="2" Content="CORRIGIR AUTOMATICAMENTE" Height="40" Padding="20,0"
                            Background="#F59E0B" Foreground="White" FontSize="13" FontWeight="Bold" BorderThickness="0" Cursor="Hand">
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="6"/>
                            </Style>
                        </Button.Resources>
                    </Button>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>
