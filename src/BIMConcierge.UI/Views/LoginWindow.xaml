<Window x:Class="BIMConcierge.UI.Views.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:BIMConcierge.UI.ViewModels"
        xmlns:conv="clr-namespace:BIMConcierge.UI.Converters"
        Title="BIM Concierge — Login"
        Width="900" Height="600"
        WindowStyle="None" AllowsTransparency="True"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        Background="Transparent">

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="../Themes/BIMConciergeTheme.xaml" />
            </ResourceDictionary.MergedDictionaries>
            <conv:BoolToVisibilityConverter x:Key="BoolToVis" />
            <conv:InverseBoolToVisibilityConverter x:Key="InvBoolToVis" />
        </ResourceDictionary>
    </Window.Resources>

    <!-- Drop-shadow outer border -->
    <Border CornerRadius="12"
            Background="{StaticResource SurfaceDarkBrush}"
            BorderBrush="{StaticResource BorderDarkBrush}"
            BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect BlurRadius="32" ShadowDepth="0" Color="#000000" Opacity="0.5" />
        </Border.Effect>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- ── LEFT PANEL — Branding ──────────────────────────────────── -->
            <Border Grid.Column="0" CornerRadius="12,0,0,12"
                    Background="{StaticResource SurfaceDark2Color}">

                <!-- Blueprint grid overlay -->
                <Grid>
                    <Rectangle Opacity="0.05">
                        <Rectangle.Fill>
                            <DrawingBrush TileMode="Tile"
                                          Viewport="0,0,40,40"
                                          ViewportUnits="Absolute">
                                <DrawingBrush.Drawing>
                                    <GeometryDrawing Brush="Transparent">
                                        <GeometryDrawing.Pen>
                                            <Pen Brush="{StaticResource PrimaryBrush}" Thickness="0.5" />
                                        </GeometryDrawing.Pen>
                                        <GeometryDrawing.Geometry>
                                            <GeometryGroup>
                                                <LineGeometry StartPoint="40,0" EndPoint="40,40" />
                                                <LineGeometry StartPoint="0,40" EndPoint="40,40" />
                                            </GeometryGroup>
                                        </GeometryDrawing.Geometry>
                                    </GeometryDrawing>
                                </DrawingBrush.Drawing>
                            </DrawingBrush>
                        </Rectangle.Fill>
                    </Rectangle>

                    <!-- Primary gradient overlay -->
                    <Rectangle>
                        <Rectangle.Fill>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#206A7D90" Offset="0" />
                                <GradientStop Color="Transparent" Offset="1" />
                            </LinearGradientBrush>
                        </Rectangle.Fill>
                    </Rectangle>

                    <!-- Logo + Text -->
                    <StackPanel HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                Margin="48">
                        <!-- Icon badge -->
                        <Border Width="80" Height="80"
                                CornerRadius="16"
                                Background="{StaticResource PrimaryBrush}"
                                HorizontalAlignment="Center"
                                Margin="0,0,0,24">
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="20" ShadowDepth="0"
                                                  Color="#6A7D90" Opacity="0.6" />
                            </Border.Effect>
                            <TextBlock Text="&#xE53C;"
                                       FontFamily="Segoe MDL2 Assets"
                                       FontSize="40"
                                       Foreground="White"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center" />
                        </Border>

                        <TextBlock Text="BIM Concierge"
                                   FontSize="28" FontWeight="Black"
                                   Foreground="{StaticResource TextPrimaryBrush}"
                                   HorizontalAlignment="Center"
                                   Margin="0,0,0,8" />

                        <TextBlock Text="Precision-engineered for Revit 2026"
                                   FontSize="14"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   HorizontalAlignment="Center"
                                   TextAlignment="Center" />

                        <!-- Feature pills -->
                        <StackPanel Margin="0,32,0,0" HorizontalAlignment="Center">
                            <Border CornerRadius="20" Padding="12,6" Margin="0,4"
                                    Background="#1A6A7D90" BorderBrush="#336A7D90" BorderThickness="1">
                                <TextBlock Text="✓  Tutoriais guiados passo a passo"
                                           FontSize="12" Foreground="{StaticResource PrimaryLightBrush}" />
                            </Border>
                            <Border CornerRadius="20" Padding="12,6" Margin="0,4"
                                    Background="#1A6A7D90" BorderBrush="#336A7D90" BorderThickness="1">
                                <TextBlock Text="✓  Correção em tempo real"
                                           FontSize="12" Foreground="{StaticResource PrimaryLightBrush}" />
                            </Border>
                            <Border CornerRadius="20" Padding="12,6" Margin="0,4"
                                    Background="#1A6A7D90" BorderBrush="#336A7D90" BorderThickness="1">
                                <TextBlock Text="✓  Padrões da empresa automatizados"
                                           FontSize="12" Foreground="{StaticResource PrimaryLightBrush}" />
                            </Border>
                        </StackPanel>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- ── RIGHT PANEL — Login form ───────────────────────────────── -->
            <Border Grid.Column="1"
                    Background="{StaticResource SurfaceDarkBrush}"
                    CornerRadius="0,12,12,0"
                    Padding="40">

                <StackPanel VerticalAlignment="Center">

                    <!-- Header -->
                    <TextBlock Text="Bem-vindo ao seu"
                               FontSize="13" FontWeight="Medium"
                               Foreground="{StaticResource PrimaryLightBrush}"
                               Margin="0,0,0,2" />
                    <TextBlock Text="Assistente BIM Inteligente"
                               FontSize="22" FontWeight="Bold"
                               Foreground="{StaticResource TextPrimaryBrush}"
                               Margin="0,0,0,4" />
                    <TextBlock Text="Insira suas credenciais para acessar o plugin."
                               FontSize="13"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               Margin="0,0,0,28" />

                    <!-- Error banner -->
                    <Border CornerRadius="{StaticResource RadiusMd}"
                            Background="#1FEF4444" BorderBrush="#33EF4444" BorderThickness="1"
                            Padding="12,8" Margin="0,0,0,16"
                            Visibility="{Binding ErrorMessage, Converter={StaticResource BoolToVis}}">
                        <TextBlock Text="{Binding ErrorMessage}"
                                   Foreground="{StaticResource ErrorBrush}"
                                   FontSize="13" TextWrapping="Wrap" />
                    </Border>

                    <!-- Email -->
                    <TextBlock Text="Endereço de e-mail" FontSize="12" FontWeight="Medium"
                               Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,6" />
                    <TextBox Style="{StaticResource ModernTextBox}"
                             Text="{Binding Email, UpdateSourceTrigger=PropertyChanged}"
                             Margin="0,0,0,16" />

                    <!-- Password -->
                    <TextBlock Text="Senha" FontSize="12" FontWeight="Medium"
                               Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,6" />
                    <PasswordBox x:Name="PasswordBox"
                                 Padding="40,12,16,12"
                                 Background="{StaticResource BackgroundDarkBrush}"
                                 Foreground="{StaticResource TextPrimaryBrush}"
                                 BorderBrush="{StaticResource BorderDarkBrush}"
                                 BorderThickness="1"
                                 FontSize="14"
                                 Margin="0,0,0,16" />

                    <!-- License Key -->
                    <TextBlock Text="Chave de Licença" FontSize="12" FontWeight="Medium"
                               Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,6" />
                    <TextBox Style="{StaticResource ModernTextBox}"
                             Text="{Binding LicenseKey, UpdateSourceTrigger=PropertyChanged}"
                             CharacterCasing="Upper"
                             Margin="0,0,0,20" />

                    <!-- Remember me row -->
                    <Grid Margin="0,0,0,24">
                        <CheckBox Content="Lembrar-me"
                                  IsChecked="{Binding RememberMe}"
                                  Foreground="{StaticResource TextSecondaryBrush}"
                                  FontSize="13"
                                  HorizontalAlignment="Left" />
                        <TextBlock Text="Esqueceu a senha?"
                                   FontSize="13" FontWeight="SemiBold"
                                   Foreground="{StaticResource PrimaryBrush}"
                                   HorizontalAlignment="Right"
                                   Cursor="Hand" />
                    </Grid>

                    <!-- Login button -->
                    <Button Content="Entrar no Plugin"
                            Style="{StaticResource PrimaryButton}"
                            Command="{Binding LoginCommand}"
                            HorizontalAlignment="Stretch"
                            Height="48" FontSize="15" />

                    <!-- Busy spinner -->
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center"
                                Margin="0,12,0,0"
                                Visibility="{Binding IsBusy, Converter={StaticResource BoolToVis}}">
                        <TextBlock Text="Autenticando…"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   FontSize="13" />
                    </StackPanel>

                    <!-- Footer -->
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,20,0,0">
                        <TextBlock Text="Não tem licença? "
                                   FontSize="12"
                                   Foreground="{StaticResource TextSecondaryBrush}" />
                        <TextBlock Text="Solicitar Acesso"
                                   FontSize="12" FontWeight="Bold"
                                   Foreground="{StaticResource PrimaryBrush}"
                                   Cursor="Hand" />
                    </StackPanel>

                </StackPanel>
            </Border>

            <!-- Drag handle (top bar) -->
            <Border Grid.ColumnSpan="2" Height="32"
                    VerticalAlignment="Top" CornerRadius="12,12,0,0"
                    Background="Transparent"
                    MouseLeftButtonDown="TitleBar_MouseLeftButtonDown" />

            <!-- Close button -->
            <Button Grid.Column="1" Content="✕"
                    Width="32" Height="32"
                    HorizontalAlignment="Right" VerticalAlignment="Top"
                    Margin="0,8,12,0"
                    Background="Transparent" BorderThickness="0"
                    Foreground="{StaticResource TextSecondaryBrush}"
                    FontSize="14" Cursor="Hand"
                    Click="CloseButton_Click" />
        </Grid>
    </Border>
</Window>
