<Window x:Class="BIMConcierge.UI.Views.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:helpers="clr-namespace:BIMConcierge.UI.Helpers"
        xmlns:loc="clr-namespace:BIMConcierge.UI.Localization"
        mc:Ignorable="d"
        Title="{loc:Loc LoginTitle}" Height="635" Width="950"
        WindowStartupLocation="CenterScreen" WindowStyle="None" 
        AllowsTransparency="True" Background="Transparent" FontFamily="Segoe UI">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
    </Window.Resources>

    <Border CornerRadius="16" Background="#17191B" BorderBrush="#1E293B" BorderThickness="1" MouseLeftButtonDown="Border_MouseLeftButtonDown">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="450" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" CornerRadius="16,0,0,16" Padding="40">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#0F172A" Offset="0"/>
                        <GradientStop Color="#17191B" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>

                <StackPanel VerticalAlignment="Center">
                    <Border Width="60" Height="60" Background="#1E293B" CornerRadius="12" HorizontalAlignment="Left" Margin="0,0,0,30">
                        <TextBlock Text="BIM" Foreground="#6A7D90" FontWeight="Black" FontSize="20" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>

                    <TextBlock Text="BIM CONCIERGE" FontSize="14" FontWeight="Bold" Foreground="#6A7D90" Margin="0,0,0,10"/>
                    <TextBlock Text="{loc:Loc LoginHeroTitle}" FontSize="36" FontWeight="Black" Foreground="White" TextWrapping="Wrap" Margin="0,0,0,20" LineHeight="40"/>
                    <TextBlock Text="{loc:Loc LoginHeroSubtitle}"
                               FontSize="16" Foreground="#94A3B8" TextWrapping="Wrap" Margin="0,0,0,40" LineHeight="24"/>

                    <StackPanel Margin="0,0,0,15" Orientation="Horizontal">
                        <Ellipse Width="24" Height="24" Fill="#1E293B" Margin="0,0,15,0"/>
                        <TextBlock Text="{loc:Loc LoginFeature1}" Foreground="#CBD5E1" FontSize="15" VerticalAlignment="Center"/>
                    </StackPanel>
                    <StackPanel Margin="0,0,0,15" Orientation="Horizontal">
                        <Ellipse Width="24" Height="24" Fill="#1E293B" Margin="0,0,15,0"/>
                        <TextBlock Text="{loc:Loc LoginFeature2}" Foreground="#CBD5E1" FontSize="15" VerticalAlignment="Center"/>
                    </StackPanel>
                    <StackPanel Margin="0,0,0,15" Orientation="Horizontal">
                        <Ellipse Width="24" Height="24" Fill="#1E293B" Margin="0,0,15,0"/>
                        <TextBlock Text="{loc:Loc LoginFeature3}" Foreground="#CBD5E1" FontSize="15" VerticalAlignment="Center"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <Grid Grid.Column="1" Margin="50">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Button Grid.Row="0" HorizontalAlignment="Right" VerticalAlignment="Top" 
                        Content="✕" FontSize="16" Foreground="#94A3B8" Background="Transparent" BorderThickness="0"
                        Cursor="Hand" Click="BtnClose_Click"/>

                <StackPanel Grid.Row="1" VerticalAlignment="Center">
                    <TextBlock Text="{loc:Loc LoginWelcome}" FontSize="30" FontWeight="Bold" Foreground="White" Margin="0,0,0,8"/>
                    <TextBlock Text="{loc:Loc LoginCredentials}" FontSize="14" Foreground="#94A3B8" Margin="0,0,0,35"/>

                    <TextBlock Text="{Binding ErrorMessage}" Foreground="#EF4444" FontSize="13" Margin="0,0,0,15" FontWeight="SemiBold"
                               TextWrapping="Wrap" Visibility="{Binding HasError, Converter={StaticResource BooleanToVisibilityConverter}, FallbackValue=Collapsed}"/>

                    <TextBlock Text="{loc:Loc LoginEmail}" Foreground="#94A3B8" FontSize="13" FontWeight="SemiBold" Margin="0,0,0,8"/>
                    <Border Background="#1E293B" CornerRadius="8" BorderBrush="#334155" BorderThickness="1" Margin="0,0,0,20" Height="45">
                        <TextBox Text="{Binding Email, UpdateSourceTrigger=PropertyChanged}" 
                                 Background="Transparent" Foreground="White" BorderThickness="0" 
                                 VerticalContentAlignment="Center" Padding="15,0" FontSize="14"/>
                    </Border>

                    <TextBlock Text="{loc:Loc LoginPassword}" Foreground="#94A3B8" FontSize="13" FontWeight="SemiBold" Margin="0,0,0,8"/>
                    <Border Background="#1E293B" CornerRadius="8" BorderBrush="#334155" BorderThickness="1" Margin="0,0,0,20" Height="45">
                        <PasswordBox PasswordChanged="PasswordBox_PasswordChanged"
                                     Background="Transparent" Foreground="White" BorderThickness="0"
                                     VerticalContentAlignment="Center" Padding="15,0" FontSize="14"/>
                    </Border>

                    <TextBlock Text="{loc:Loc LoginLicenseKey}" Foreground="#94A3B8" FontSize="13" FontWeight="SemiBold" Margin="0,0,0,8"/>
                    <Border Background="#1E293B" CornerRadius="8" BorderBrush="#334155" BorderThickness="1" Margin="0,0,0,20" Height="45">
                        <TextBox Text="{Binding LicenseKey, UpdateSourceTrigger=PropertyChanged}" 
                                 Background="Transparent" Foreground="White" BorderThickness="0" 
                                 VerticalContentAlignment="Center" Padding="15,0" FontSize="14"/>
                    </Border>

                    <Grid Margin="0,0,0,30">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <CheckBox Content="{loc:Loc LoginRememberMe}" Foreground="#94A3B8" FontSize="13" VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="1" Text="{loc:Loc LoginForgotPassword}" Foreground="#6A7D90" FontSize="13" FontWeight="SemiBold" Cursor="Hand" VerticalAlignment="Center"/>
                    </Grid>

                    <Button Command="{Binding LoginCommand}" Content="{loc:Loc LoginButton}" Height="50"
                            Background="#6A7D90" Foreground="White" FontSize="15" FontWeight="Bold" BorderThickness="0" Cursor="Hand">
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="8"/>
                            </Style>
                        </Button.Resources>
                    </Button>
                </StackPanel>

                <TextBlock Grid.Row="2" HorizontalAlignment="Center" Foreground="#94A3B8" FontSize="13">
                    <Run Text="{loc:Loc LoginNeedHelp}"/> <Run Text="{loc:Loc LoginContactSupport}" Foreground="#6A7D90" FontWeight="SemiBold" Cursor="Hand"/>
                </TextBlock>
            </Grid>
        </Grid>
    </Border>
</Window>
