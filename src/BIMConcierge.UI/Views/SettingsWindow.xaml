<Window x:Class="BIMConcierge.UI.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:loc="clr-namespace:BIMConcierge.UI.Localization"
        mc:Ignorable="d"
        Title="{loc:Loc NavSettings}" Height="768" Width="1280"
        WindowStartupLocation="CenterScreen" WindowStyle="None"
        AllowsTransparency="True" Background="Transparent" FontFamily="Segoe UI">

    <Border CornerRadius="16" Background="#17191B" BorderBrush="#1E293B" BorderThickness="1" MouseLeftButtonDown="Border_MouseLeftButtonDown">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="260"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Sidebar -->
            <Border Grid.Column="0" Background="#0F172A" CornerRadius="16,0,0,16" BorderBrush="#1E293B" BorderThickness="0,0,1,0" Padding="20">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Logo -->
                    <StackPanel Grid.Row="0" Margin="0,0,0,30" Orientation="Horizontal" VerticalAlignment="Center">
                        <Border Width="32" Height="32" Background="#1E293B" CornerRadius="8" Margin="0,0,12,0">
                            <TextBlock Text="BIM" Foreground="#6A7D90" FontWeight="Black" FontSize="12" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock Text="BIM CONCIERGE" FontSize="15" FontWeight="Bold" Foreground="#6A7D90" VerticalAlignment="Center"/>
                    </StackPanel>

                    <!-- Navigation -->
                    <StackPanel Grid.Row="1">
                        <Border Background="Transparent" CornerRadius="8" Padding="12,10" Margin="0,0,0,4" Cursor="Hand"
                                MouseLeftButtonUp="SidebarDashboard_Click">
                            <StackPanel Orientation="Horizontal">
                                <Path Data="M2,2 H7 V7 H2Z M9,2 H14 V7 H9Z M2,9 H7 V14 H2Z M9,9 H14 V14 H9Z"
                                      Fill="#94A3B8" Width="16" Height="16" Stretch="Uniform" Margin="0,0,12,0" VerticalAlignment="Center"/>
                                <TextBlock Text="{loc:Loc NavDashboard}" Foreground="#94A3B8" FontWeight="Medium" FontSize="13" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                        <Border Background="Transparent" CornerRadius="8" Padding="12,10" Margin="0,0,0,4" Cursor="Hand"
                                MouseLeftButtonUp="SidebarTutorials_Click">
                            <StackPanel Orientation="Horizontal">
                                <Path Data="M2,3 H10 V5 H2Z M2,7 H14 V9 H2Z M2,11 H12 V13 H2Z"
                                      Fill="#94A3B8" Width="16" Height="16" Stretch="Uniform" Margin="0,0,12,0" VerticalAlignment="Center"/>
                                <TextBlock Text="{loc:Loc NavTutorials}" Foreground="#94A3B8" FontWeight="Medium" FontSize="13" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                        <Border Background="Transparent" CornerRadius="8" Padding="12,10" Margin="0,0,0,4" Cursor="Hand"
                                MouseLeftButtonUp="SidebarStandards_Click">
                            <StackPanel Orientation="Horizontal">
                                <Path Data="M8,1 L14,3.5 V8 C14,11.5 8,15 8,15 C8,15 2,11.5 2,8 V3.5Z"
                                      Fill="#94A3B8" Width="16" Height="16" Stretch="Uniform" Margin="0,0,12,0" VerticalAlignment="Center"/>
                                <TextBlock Text="{loc:Loc NavStandards}" Foreground="#94A3B8" FontWeight="Medium" FontSize="13" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                        <Border Background="Transparent" CornerRadius="8" Padding="12,10" Margin="0,0,0,4" Cursor="Hand"
                                MouseLeftButtonUp="SidebarProgress_Click">
                            <StackPanel Orientation="Horizontal">
                                <Path Data="M2,14 V9 H5 V14Z M6.5,14 V6 H9.5 V14Z M11,14 V2 H14 V14Z"
                                      Fill="#94A3B8" Width="16" Height="16" Stretch="Uniform" Margin="0,0,12,0" VerticalAlignment="Center"/>
                                <TextBlock Text="{loc:Loc NavProgress}" Foreground="#94A3B8" FontWeight="Medium" FontSize="13" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                        <Border Background="Transparent" CornerRadius="8" Padding="12,10" Margin="0,0,0,4" Cursor="Hand"
                                MouseLeftButtonUp="SidebarAchievements_Click">
                            <StackPanel Orientation="Horizontal">
                                <Path Data="M5,1 H11 L12,5 L8,8 L4,5Z M6,9 H10 V11 H6Z M4,11.5 H12 V13 H4Z"
                                      Fill="#94A3B8" Width="16" Height="16" Stretch="Uniform" Margin="0,0,12,0" VerticalAlignment="Center"/>
                                <TextBlock Text="{loc:Loc NavAchievements}" Foreground="#94A3B8" FontWeight="Medium" FontSize="13" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>

                        <Border Height="1" Background="#1E293B" Margin="0,8,0,8"/>

                        <!-- Settings (active) -->
                        <Border Background="#1E293B" CornerRadius="8" Padding="12,10" Margin="0,0,0,4" Cursor="Hand">
                            <StackPanel Orientation="Horizontal">
                                <Path Data="M7,0 H9 V2.5 L10.5,3 L12.5,1.5 L14,3 L12.5,5 L13,6.5 H15.5 V8.5 H13 L12.5,10.5 L14,12.5 L12.5,14 L10.5,12.5 L9,13 V15.5 H7 V13 L5,12.5 L3,14 L1.5,12.5 L3,10.5 L2.5,8.5 H0 V6.5 H2.5 L3,5 L1.5,3 L3,1.5 L5,3 L7,2.5Z M8,5.5 A2.5,2.5 0 1,0 8,10.5 A2.5,2.5 0 1,0 8,5.5Z"
                                      Fill="#6A7D90" Width="16" Height="16" Stretch="Uniform" Margin="0,0,12,0" VerticalAlignment="Center"/>
                                <TextBlock Text="{loc:Loc NavSettings}" Foreground="White" FontWeight="SemiBold" FontSize="13" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>

                    <!-- User Card -->
                    <Border Grid.Row="2" Background="#17191B" BorderBrush="#1E293B" BorderThickness="1" CornerRadius="12" Padding="12">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0" Width="36" Height="36" Background="#6A7D90" CornerRadius="18" Margin="0,0,12,0">
                                <TextBlock Text="FF" Foreground="White" FontWeight="Bold" FontSize="14" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                <TextBlock Text="{Binding UserName, FallbackValue='Usu&#225;rio'}" Foreground="White" FontWeight="SemiBold" FontSize="13"/>
                                <TextBlock Text="{Binding UserRole, FallbackValue=''}" Foreground="#94A3B8" FontSize="12"/>
                            </StackPanel>
                        </Grid>
                    </Border>
                </Grid>
            </Border>

            <!-- Main Content -->
            <ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Auto">
                <Grid Margin="40">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Close Button -->
                    <Button Grid.Row="0" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,-20,-20,0"
                            Content="&#x2715;" FontSize="16" Foreground="#94A3B8" Background="Transparent" BorderThickness="0"
                            Cursor="Hand" Click="BtnClose_Click"/>

                    <!-- Header -->
                    <StackPanel Grid.Row="0" Margin="0,0,0,30">
                        <TextBlock Text="{loc:Loc NavSettings}" FontSize="28" FontWeight="Bold" Foreground="White" Margin="0,0,0,6"/>
                        <TextBlock Text="{loc:Loc SettingsSubtitle}" FontSize="14" Foreground="#94A3B8"/>
                    </StackPanel>

                    <!-- Language Section -->
                    <Border Grid.Row="1" Background="#121820" BorderBrush="#1E293B" BorderThickness="1" CornerRadius="12" Padding="24" Margin="0,0,0,20">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                                <Path Data="M8,1 A7,7 0 1,0 8,15 A7,7 0 1,0 8,1Z M1,8 H15 M8,1 C5,4 5,12 8,15 M8,1 C11,4 11,12 8,15"
                                      Stroke="#6A7D90" StrokeThickness="1.2" Fill="Transparent" Width="20" Height="20" Stretch="Uniform" Margin="0,0,10,0" VerticalAlignment="Center"/>
                                <TextBlock Text="{loc:Loc SettingsLanguage}" FontSize="16" FontWeight="Bold" Foreground="White"/>
                            </StackPanel>
                            <TextBlock Text="{loc:Loc SettingsLanguageDesc}" Foreground="#94A3B8" FontSize="12" Margin="0,0,0,16"/>
                            <StackPanel Orientation="Horizontal">
                                <Border CornerRadius="8" Padding="16,10" Margin="0,0,12,0" Cursor="Hand"
                                        MouseLeftButtonUp="LangPtBr_Click">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Background" Value="#1E293B"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding SelectedLanguage}" Value="pt-BR">
                                                    <Setter Property="Background" Value="#6A7D90"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <TextBlock FontSize="13" FontWeight="SemiBold">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Foreground" Value="#94A3B8"/>
                                                <Setter Property="Text" Value="Portugu&#234;s (BR)"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding SelectedLanguage}" Value="pt-BR">
                                                        <Setter Property="Foreground" Value="White"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </Border>
                                <Border CornerRadius="8" Padding="16,10" Cursor="Hand"
                                        MouseLeftButtonUp="LangEn_Click">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Background" Value="#1E293B"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding SelectedLanguage}" Value="en">
                                                    <Setter Property="Background" Value="#6A7D90"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <TextBlock Text="English" FontSize="13" FontWeight="SemiBold">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Foreground" Value="#94A3B8"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding SelectedLanguage}" Value="en">
                                                        <Setter Property="Foreground" Value="White"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </Border>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- Theme Section -->
                    <Border Grid.Row="2" Background="#121820" BorderBrush="#1E293B" BorderThickness="1" CornerRadius="12" Padding="24" Margin="0,0,0,20">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                                <Path Data="M8,1 A7,7 0 0,0 8,15 A4,4 0 0,1 8,1Z"
                                      Fill="#6A7D90" Width="20" Height="20" Stretch="Uniform" Margin="0,0,10,0" VerticalAlignment="Center"/>
                                <TextBlock Text="{loc:Loc SettingsTheme}" FontSize="16" FontWeight="Bold" Foreground="White"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal">
                                <Border Background="#6A7D90" CornerRadius="8" Padding="16,10" Margin="0,0,12,0">
                                    <TextBlock Text="Dark" Foreground="White" FontSize="13" FontWeight="SemiBold"/>
                                </Border>
                                <Border Background="#1E293B" CornerRadius="8" Padding="16,10" Opacity="0.5">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="Light" Foreground="#64748B" FontSize="13" FontWeight="SemiBold"/>
                                        <TextBlock Text=" (em breve)" Foreground="#64748B" FontSize="11" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- Account Section -->
                    <Border Grid.Row="3" Background="#121820" BorderBrush="#1E293B" BorderThickness="1" CornerRadius="12" Padding="24" Margin="0,0,0,20">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                                <Path Data="M8,1 A3,3 0 1,0 8,7 A3,3 0 1,0 8,1Z M2,14 C2,11 5,9 8,9 C11,9 14,11 14,14"
                                      Stroke="#6A7D90" StrokeThickness="1.5" Fill="Transparent" Width="20" Height="20" Stretch="Uniform" Margin="0,0,10,0" VerticalAlignment="Center"/>
                                <TextBlock Text="{loc:Loc SettingsAccount}" FontSize="16" FontWeight="Bold" Foreground="White"/>
                            </StackPanel>

                            <Grid Margin="0,0,0,14">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="{loc:Loc SettingsName}" Foreground="#94A3B8" FontSize="12" FontWeight="Bold" VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="1" Text="{Binding UserName, FallbackValue='—'}" Foreground="White" FontSize="13" VerticalAlignment="Center"/>
                            </Grid>
                            <Grid Margin="0,0,0,14">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Email" Foreground="#94A3B8" FontSize="12" FontWeight="Bold" VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="1" Text="{Binding UserEmail, FallbackValue='—'}" Foreground="White" FontSize="13" VerticalAlignment="Center"/>
                            </Grid>
                            <Grid Margin="0,0,0,14">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="{loc:Loc SettingsRole}" Foreground="#94A3B8" FontSize="12" FontWeight="Bold" VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="1" Text="{Binding UserRole, FallbackValue='—'}" Foreground="White" FontSize="13" VerticalAlignment="Center"/>
                            </Grid>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="{loc:Loc SettingsPlan}" Foreground="#94A3B8" FontSize="12" FontWeight="Bold" VerticalAlignment="Center"/>
                                <Border Grid.Column="1" Background="#6A7D9033" CornerRadius="4" Padding="8,3" HorizontalAlignment="Left">
                                    <TextBlock Text="{Binding PlanName, FallbackValue='—'}" Foreground="#6A7D90" FontSize="12" FontWeight="Bold"/>
                                </Border>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <!-- About Section -->
                    <Border Grid.Row="4" Background="#121820" BorderBrush="#1E293B" BorderThickness="1" CornerRadius="12" Padding="24">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                                <Path Data="M8,1 A7,7 0 1,0 8,15 A7,7 0 1,0 8,1Z M7.5,6 H8.5 V7 H7.5Z M7.5,8.5 H8.5 V12 H7.5Z"
                                      Stroke="#6A7D90" StrokeThickness="1.2" Fill="Transparent" Width="20" Height="20" Stretch="Uniform" Margin="0,0,10,0" VerticalAlignment="Center"/>
                                <TextBlock Text="{loc:Loc SettingsAbout}" FontSize="16" FontWeight="Bold" Foreground="White"/>
                            </StackPanel>
                            <Grid Margin="0,0,0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="{loc:Loc SettingsVersion}" Foreground="#94A3B8" FontSize="12" FontWeight="Bold" VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="1" Text="{Binding AppVersion}" Foreground="White" FontSize="13" FontFamily="Consolas" VerticalAlignment="Center"/>
                            </Grid>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="{loc:Loc SettingsSupport}" Foreground="#94A3B8" FontSize="12" FontWeight="Bold" VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="1" Text="contato@bimconcierge.io" Foreground="#6A7D90" FontSize="13" VerticalAlignment="Center"/>
                            </Grid>
                        </StackPanel>
                    </Border>
                </Grid>
            </ScrollViewer>
        </Grid>
    </Border>
</Window>
