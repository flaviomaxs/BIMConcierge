<Window x:Class="BIMConcierge.UI.Views.TutorialLibraryWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        mc:Ignorable="d"
        Title="BIMConcierge - Biblioteca de Tutoriais" Height="768" Width="1280"
        WindowStartupLocation="CenterScreen" WindowStyle="None" 
        AllowsTransparency="True" Background="Transparent" FontFamily="Segoe UI">

    <Border CornerRadius="16" Background="#17191B" BorderBrush="#1E293B" BorderThickness="1" MouseLeftButtonDown="Border_MouseLeftButtonDown">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="280" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="#0F172A" CornerRadius="16,0,0,16" BorderBrush="#1E293B" BorderThickness="0,0,1,0" Padding="24">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Margin="0,0,0,40" Orientation="Horizontal" VerticalAlignment="Center">
                        <Border Width="32" Height="32" Background="#1E293B" CornerRadius="8" Margin="0,0,12,0">
                            <TextBlock Text="BIM" Foreground="#6A7D90" FontWeight="Black" FontSize="12" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock Text="BIM CONCIERGE" FontSize="15" FontWeight="Bold" Foreground="#6A7D90" VerticalAlignment="Center"/>
                    </StackPanel>

                    <StackPanel Grid.Row="1">
                        <Border Background="Transparent" CornerRadius="8" Padding="12,10" Margin="0,0,0,5" Cursor="Hand">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="⊞" Foreground="#94A3B8" FontSize="18" Margin="0,0,12,0" VerticalAlignment="Center"/>
                                <TextBlock Text="Painel Principal" Foreground="#94A3B8" FontWeight="Medium" FontSize="14" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>

                        <Border Background="#1E293B" CornerRadius="8" Padding="12,10" Margin="0,0,0,5" Cursor="Hand">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="▶" Foreground="#6A7D90" FontSize="16" Margin="0,0,12,0" VerticalAlignment="Center"/>
                                <TextBlock Text="Tutoriais" Foreground="White" FontWeight="SemiBold" FontSize="14" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>

                        <Border Background="Transparent" CornerRadius="8" Padding="12,10" Margin="0,0,0,5" Cursor="Hand">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="★" Foreground="#94A3B8" FontSize="18" Margin="0,0,12,0" VerticalAlignment="Center"/>
                                <TextBlock Text="Padrões da Empresa" Foreground="#94A3B8" FontWeight="Medium" FontSize="14" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>

                        <Border Background="Transparent" CornerRadius="8" Padding="12,10" Margin="0,0,0,5" Cursor="Hand">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="⚙" Foreground="#94A3B8" FontSize="18" Margin="0,0,12,0" VerticalAlignment="Center"/>
                                <TextBlock Text="Configurações" Foreground="#94A3B8" FontWeight="Medium" FontSize="14" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>

                    <Border Grid.Row="2" Background="#17191B" BorderBrush="#1E293B" BorderThickness="1" CornerRadius="12" Padding="12">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <Border Grid.Column="0" Width="36" Height="36" Background="#6A7D90" CornerRadius="18" Margin="0,0,12,0">
                                <TextBlock Text="FF" Foreground="White" FontWeight="Bold" FontSize="14" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>

                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                <TextBlock Text="Flávio Filho" Foreground="White" FontWeight="SemiBold" FontSize="13"/>
                                <TextBlock Text="Arquiteto" Foreground="#94A3B8" FontSize="12"/>
                            </StackPanel>

                            <TextBlock Grid.Column="2" Text="⋮" Foreground="#94A3B8" FontSize="18" FontWeight="Bold" VerticalAlignment="Center" Cursor="Hand"/>
                        </Grid>
                    </Border>
                </Grid>
            </Border>

            <Grid Grid.Column="1" Margin="40">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Button Grid.Row="0" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,-20,-20,0"
                        Content="✕" FontSize="16" Foreground="#94A3B8" Background="Transparent" BorderThickness="0"
                        Cursor="Hand" Click="BtnClose_Click"/>

                <StackPanel Grid.Row="0" Margin="0,0,0,30">
                    <TextBlock Text="Biblioteca de Treinamentos" FontSize="28" FontWeight="Bold" Foreground="White" Margin="0,0,0,8"/>
                    <TextBlock Text="Aprimore suas habilidades com tutoriais interativos guiados diretamente no Revit." FontSize="15" Foreground="#94A3B8"/>
                </StackPanel>

                <Grid Grid.Row="1" Margin="0,0,0,30">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="350"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" Background="#121820" BorderBrush="#1E293B" BorderThickness="1" CornerRadius="8" Height="45">
                        <Grid>
                            <TextBlock Text="⌕" Foreground="#94A3B8" FontSize="20" VerticalAlignment="Center" Margin="15,0,0,0"/>
                            <TextBox Background="Transparent" Foreground="White" BorderThickness="0" 
                                     VerticalContentAlignment="Center" Padding="40,0,15,0" FontSize="14"
                                     Text="Buscar tutoriais..."/>
                        </Grid>
                    </Border>

                    <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Content="Todos" Height="40" Padding="20,0" Margin="0,0,10,0"
                                Background="#6A7D90" Foreground="White" FontSize="13" FontWeight="SemiBold" BorderThickness="0" Cursor="Hand">
                            <Button.Resources>
                                <Style TargetType="Border">
                                    <Setter Property="CornerRadius" Value="20"/>
                                </Style>
                            </Button.Resources>
                        </Button>

                        <Button Content="Arquitetura" Height="40" Padding="20,0" Margin="0,0,10,0"
                                Background="#1E293B" Foreground="#94A3B8" FontSize="13" FontWeight="SemiBold" BorderThickness="0" Cursor="Hand">
                            <Button.Resources>
                                <Style TargetType="Border">
                                    <Setter Property="CornerRadius" Value="20"/>
                                </Style>
                            </Button.Resources>
                        </Button>

                        <Button Content="Estrutura" Height="40" Padding="20,0" Margin="0,0,10,0"
                                Background="#1E293B" Foreground="#94A3B8" FontSize="13" FontWeight="SemiBold" BorderThickness="0" Cursor="Hand">
                            <Button.Resources>
                                <Style TargetType="Border">
                                    <Setter Property="CornerRadius" Value="20"/>
                                </Style>
                            </Button.Resources>
                        </Button>

                        <Button Content="Padrões" Height="40" Padding="20,0" Margin="0,0,0,0"
                                Background="#1E293B" Foreground="#94A3B8" FontSize="13" FontWeight="SemiBold" BorderThickness="0" Cursor="Hand">
                            <Button.Resources>
                                <Style TargetType="Border">
                                    <Setter Property="CornerRadius" Value="20"/>
                                </Style>
                            </Button.Resources>
                        </Button>
                    </StackPanel>
                </Grid>

                <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                    <WrapPanel Margin="0,0,0,20">

                        <Border Background="#121820" BorderBrush="#1E293B" BorderThickness="1" CornerRadius="12" Padding="20" Width="300" Margin="0,0,20,20">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <Border Grid.Row="0" Height="140" Background="#1E293B" CornerRadius="8" Margin="0,0,0,15">
                                    <TextBlock Text="[Preview do Tutorial]" Foreground="#6A7D90" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>

                                <StackPanel Grid.Row="1" Margin="0,0,0,10">
                                    <Border Background="#0F172A" BorderBrush="#1E293B" BorderThickness="1" CornerRadius="4" Padding="6,2" HorizontalAlignment="Left" Margin="0,0,0,10">
                                        <TextBlock Text="ARQUITETURA" Foreground="#6A7D90" FontSize="10" FontWeight="Bold"/>
                                    </Border>
                                    <TextBlock Text="Modelagem Avançada de Paredes" FontSize="16" FontWeight="Bold" Foreground="White" TextWrapping="Wrap"/>
                                </StackPanel>

                                <TextBlock Grid.Row="2" Text="Aprenda fluxos de trabalho adequados para desenhar e modificar paredes multicamadas de acordo com o padrão do escritório." 
                                           Foreground="#94A3B8" FontSize="13" TextWrapping="Wrap" LineHeight="18" Margin="0,0,0,20"/>

                                <StackPanel Grid.Row="3">
                                    <Grid Margin="0,0,0,8">
                                        <TextBlock Text="2/8 Passos" Foreground="#94A3B8" FontSize="11" FontWeight="Bold" HorizontalAlignment="Left"/>
                                        <TextBlock Text="45 min" Foreground="#94A3B8" FontSize="11" HorizontalAlignment="Right"/>
                                    </Grid>

                                    <Border Height="6" Background="#1E293B" CornerRadius="3" Margin="0,0,0,15">
                                        <Border Width="70" Background="#6A7D90" CornerRadius="3" HorizontalAlignment="Left"/>
                                    </Border>

                                    <Button Content="CONTINUAR TRILHA" Height="35" 
                                            Background="#1E293B" Foreground="White" FontSize="12" FontWeight="Bold" BorderThickness="0" Cursor="Hand">
                                        <Button.Resources>
                                            <Style TargetType="Border">
                                                <Setter Property="CornerRadius" Value="6"/>
                                            </Style>
                                        </Button.Resources>
                                    </Button>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <Border Background="#121820" BorderBrush="#1E293B" BorderThickness="1" CornerRadius="12" Padding="20" Width="300" Margin="0,0,20,20">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <Border Grid.Row="0" Height="140" Background="#1E293B" CornerRadius="8" Margin="0,0,0,15">
                                    <TextBlock Text="[Preview do Tutorial]" Foreground="#6A7D90" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>

                                <StackPanel Grid.Row="1" Margin="0,0,0,10">
                                    <Border Background="#0F172A" BorderBrush="#1E293B" BorderThickness="1" CornerRadius="4" Padding="6,2" HorizontalAlignment="Left" Margin="0,0,0,10">
                                        <TextBlock Text="PARAMÉTRICA" Foreground="#6A7D90" FontSize="10" FontWeight="Bold"/>
                                    </Border>
                                    <TextBlock Text="Fundamentos de Famílias" FontSize="16" FontWeight="Bold" Foreground="White" TextWrapping="Wrap"/>
                                </StackPanel>

                                <TextBlock Grid.Row="2" Text="Famílias aninhadas, tabelas de pesquisa e parametrização complexa sem quebrar a geometria." 
                                           Foreground="#94A3B8" FontSize="13" TextWrapping="Wrap" LineHeight="18" Margin="0,0,0,20"/>

                                <StackPanel Grid.Row="3">
                                    <Grid Margin="0,0,0,8">
                                        <TextBlock Text="0/6 Passos" Foreground="#94A3B8" FontSize="11" FontWeight="Bold" HorizontalAlignment="Left"/>
                                        <TextBlock Text="3h 50m" Foreground="#94A3B8" FontSize="11" HorizontalAlignment="Right"/>
                                    </Grid>

                                    <Border Height="6" Background="#1E293B" CornerRadius="3" Margin="0,0,0,15">
                                        <Border Width="0" Background="#6A7D90" CornerRadius="3" HorizontalAlignment="Left"/>
                                    </Border>

                                    <Button Content="INICIAR TRILHA" Height="35" 
                                            Background="#1E293B" Foreground="White" FontSize="12" FontWeight="Bold" BorderThickness="0" Cursor="Hand">
                                        <Button.Resources>
                                            <Style TargetType="Border">
                                                <Setter Property="CornerRadius" Value="6"/>
                                            </Style>
                                        </Button.Resources>
                                    </Button>
                                </StackPanel>
                            </Grid>
                        </Border>

                    </WrapPanel>
                </ScrollViewer>
            </Grid>
        </Grid>
    </Border>
</Window>
