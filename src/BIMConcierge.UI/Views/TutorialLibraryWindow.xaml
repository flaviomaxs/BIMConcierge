<Window x:Class="BIMConcierge.UI.Views.TutorialLibraryWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:loc="clr-namespace:BIMConcierge.UI.Localization"
        xmlns:conv="clr-namespace:BIMConcierge.UI.Converters"
        mc:Ignorable="d"
        Title="{loc:Loc TutorialsTitle}" Height="768" Width="1280"
        WindowStartupLocation="CenterScreen" WindowStyle="None"
        AllowsTransparency="True" Background="Transparent" FontFamily="Segoe UI">

    <Window.Resources>
        <conv:LocalizedStringFormatConverter x:Key="LocalizedFormat"/>
    </Window.Resources>

    <Border CornerRadius="16" Background="#17191B" BorderBrush="#1E293B" BorderThickness="1" MouseLeftButtonDown="Border_MouseLeftButtonDown">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="280" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- ══ Sidebar ══════════════════════════════════════════════════ -->
            <Border Grid.Column="0" Background="#0F172A" CornerRadius="16,0,0,16" BorderBrush="#1E293B" BorderThickness="0,0,1,0" Padding="24">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Margin="0,0,0,40" Orientation="Horizontal" VerticalAlignment="Center">
                        <Border Width="32" Height="32" Background="#1E293B" CornerRadius="8" Margin="0,0,12,0">
                            <TextBlock Text="BIM" Foreground="#6A7D90" FontWeight="Black" FontSize="12" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock Text="BIM CONCIERGE" FontSize="15" FontWeight="Bold" Foreground="#6A7D90" VerticalAlignment="Center"/>
                    </StackPanel>

                    <StackPanel Grid.Row="1">
                        <Border Background="Transparent" CornerRadius="8" Padding="12,10" Margin="0,0,0,5" Cursor="Hand"
                                MouseLeftButtonDown="SidebarDashboard_Click">
                            <StackPanel Orientation="Horizontal">
                                <Path Data="M2,2 H7 V7 H2Z M9,2 H14 V7 H9Z M2,9 H7 V14 H2Z M9,9 H14 V14 H9Z"
                                      Fill="#94A3B8" Width="16" Height="16" Stretch="Uniform" Margin="0,0,12,0" VerticalAlignment="Center"/>
                                <TextBlock Text="{loc:Loc NavDashboard}" Foreground="#94A3B8" FontWeight="Medium" FontSize="14" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>

                        <Border Background="#1E293B" CornerRadius="8" Padding="12,10" Margin="0,0,0,5" Cursor="Hand">
                            <StackPanel Orientation="Horizontal">
                                <Path Data="M2,3 H10 V5 H2Z M2,7 H14 V9 H2Z M2,11 H12 V13 H2Z"
                                      Fill="#6A7D90" Width="16" Height="16" Stretch="Uniform" Margin="0,0,12,0" VerticalAlignment="Center"/>
                                <TextBlock Text="{loc:Loc NavTutorials}" Foreground="White" FontWeight="SemiBold" FontSize="14" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>

                        <Border Background="Transparent" CornerRadius="8" Padding="12,10" Margin="0,0,0,5" Cursor="Hand"
                                MouseLeftButtonDown="SidebarStandards_Click">
                            <StackPanel Orientation="Horizontal">
                                <Path Data="M8,1 L14,3.5 V8 C14,11.5 8,15 8,15 C8,15 2,11.5 2,8 V3.5Z"
                                      Fill="#94A3B8" Width="16" Height="16" Stretch="Uniform" Margin="0,0,12,0" VerticalAlignment="Center"/>
                                <TextBlock Text="{loc:Loc NavStandards}" Foreground="#94A3B8" FontWeight="Medium" FontSize="14" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>

                        <Border Background="Transparent" CornerRadius="8" Padding="12,10" Margin="0,0,0,5" Cursor="Hand"
                                MouseLeftButtonDown="SidebarSettings_Click">
                            <StackPanel Orientation="Horizontal">
                                <Path Data="M7,0 H9 V2.5 L10.5,3 L12.5,1.5 L14,3 L12.5,5 L13,6.5 H15.5 V8.5 H13 L12.5,10.5 L14,12.5 L12.5,14 L10.5,12.5 L9,13 V15.5 H7 V13 L5,12.5 L3,14 L1.5,12.5 L3,10.5 L2.5,8.5 H0 V6.5 H2.5 L3,5 L1.5,3 L3,1.5 L5,3 L7,2.5Z M8,5.5 A2.5,2.5 0 1,0 8,10.5 A2.5,2.5 0 1,0 8,5.5Z"
                                      Fill="#94A3B8" Width="16" Height="16" Stretch="Uniform" Margin="0,0,12,0" VerticalAlignment="Center"/>
                                <TextBlock Text="{loc:Loc NavSettings}" Foreground="#94A3B8" FontWeight="Medium" FontSize="14" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>

                    <Border Grid.Row="2" Background="#17191B" BorderBrush="#1E293B" BorderThickness="1" CornerRadius="12" Padding="12">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <Border Grid.Column="0" Width="36" Height="36" Background="#6A7D90" CornerRadius="18" Margin="0,0,12,0">
                                <TextBlock Text="{Binding UserInitials, FallbackValue='?'}" Foreground="White" FontWeight="Bold" FontSize="14" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>

                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                <TextBlock Text="{Binding UserName, FallbackValue=''}" Foreground="White" FontWeight="SemiBold" FontSize="13"/>
                                <TextBlock Text="{Binding UserRole, FallbackValue=''}" Foreground="#94A3B8" FontSize="12"/>
                            </StackPanel>

                            <TextBlock Grid.Column="2" Text="&#x22EE;" Foreground="#94A3B8" FontSize="18" FontWeight="Bold" VerticalAlignment="Center"/>
                        </Grid>
                    </Border>
                </Grid>
            </Border>

            <!-- ══ Main Content ═════════════════════════════════════════════ -->
            <Grid Grid.Column="1" Margin="40">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Button Grid.Row="0" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,-20,-20,0"
                        Content="&#x2715;" FontSize="16" Foreground="#94A3B8" Background="Transparent" BorderThickness="0"
                        Cursor="Hand" Click="BtnClose_Click"/>

                <StackPanel Grid.Row="0" Margin="0,0,0,30">
                    <TextBlock Text="{loc:Loc TutorialsHeading}" FontSize="28" FontWeight="Bold" Foreground="White" Margin="0,0,0,8"/>
                    <TextBlock Text="{loc:Loc TutorialsSubtitle}" FontSize="15" Foreground="#94A3B8"/>
                </StackPanel>

                <!-- ── Search + Filters ──────────────────────────────────── -->
                <Grid Grid.Row="1" Margin="0,0,0,30">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="350"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" Background="#232629" BorderBrush="#1E293B" BorderThickness="1" CornerRadius="8" Height="45">
                        <Grid>
                            <TextBlock Text="&#x2315;" Foreground="#94A3B8" FontSize="20" VerticalAlignment="Center" Margin="15,0,0,0" IsHitTestVisible="False"/>
                            <TextBox x:Name="SearchBox" Background="Transparent" Foreground="White" BorderThickness="0"
                                     VerticalContentAlignment="Center" Padding="40,0,15,0" FontSize="14"
                                     Text="{Binding SearchQuery, UpdateSourceTrigger=PropertyChanged}"/>
                        </Grid>
                    </Border>

                    <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Content="{loc:Loc TutorialsFilterAll}" Height="40" Padding="20,0" Margin="0,0,10,0"
                                FontSize="13" FontWeight="SemiBold" BorderThickness="0" Cursor="Hand"
                                Command="{Binding SetFilterCommand}" CommandParameter="Todos">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Background" Value="#1E293B"/>
                                    <Setter Property="Foreground" Value="#94A3B8"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="Button">
                                                <Border Background="{TemplateBinding Background}" CornerRadius="20" Padding="{TemplateBinding Padding}">
                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding SelectedCategory}" Value="Todos">
                                            <Setter Property="Background" Value="#6A7D90"/>
                                            <Setter Property="Foreground" Value="White"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>

                        <Button Content="{loc:Loc TutorialsFilterArchitecture}" Height="40" Padding="20,0" Margin="0,0,10,0"
                                FontSize="13" FontWeight="SemiBold" BorderThickness="0" Cursor="Hand"
                                Command="{Binding SetFilterCommand}" CommandParameter="Arquitetura">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Background" Value="#1E293B"/>
                                    <Setter Property="Foreground" Value="#94A3B8"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="Button">
                                                <Border Background="{TemplateBinding Background}" CornerRadius="20" Padding="{TemplateBinding Padding}">
                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding SelectedCategory}" Value="Arquitetura">
                                            <Setter Property="Background" Value="#6A7D90"/>
                                            <Setter Property="Foreground" Value="White"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>

                        <Button Content="{loc:Loc TutorialsFilterStructure}" Height="40" Padding="20,0" Margin="0,0,10,0"
                                FontSize="13" FontWeight="SemiBold" BorderThickness="0" Cursor="Hand"
                                Command="{Binding SetFilterCommand}" CommandParameter="Estrutura">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Background" Value="#1E293B"/>
                                    <Setter Property="Foreground" Value="#94A3B8"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="Button">
                                                <Border Background="{TemplateBinding Background}" CornerRadius="20" Padding="{TemplateBinding Padding}">
                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding SelectedCategory}" Value="Estrutura">
                                            <Setter Property="Background" Value="#6A7D90"/>
                                            <Setter Property="Foreground" Value="White"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>

                        <Button Content="{loc:Loc TutorialsFilterStandards}" Height="40" Padding="20,0" Margin="0,0,0,0"
                                FontSize="13" FontWeight="SemiBold" BorderThickness="0" Cursor="Hand"
                                Command="{Binding SetFilterCommand}" CommandParameter="Padr&#245;es">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Background" Value="#1E293B"/>
                                    <Setter Property="Foreground" Value="#94A3B8"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="Button">
                                                <Border Background="{TemplateBinding Background}" CornerRadius="20" Padding="{TemplateBinding Padding}">
                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding SelectedCategory}" Value="Padr&#245;es">
                                            <Setter Property="Background" Value="#6A7D90"/>
                                            <Setter Property="Foreground" Value="White"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                    </StackPanel>
                </Grid>

                <!-- ── Loading Indicator ─────────────────────────────────── -->
                <TextBlock Grid.Row="2" Text="{loc:Loc TutorialsLoading}" FontSize="16" Foreground="#94A3B8"
                           HorizontalAlignment="Center" VerticalAlignment="Center"
                           Visibility="{Binding IsBusy, Converter={StaticResource BoolToVisibility}}"/>

                <!-- ── Error Message ─────────────────────────────────────── -->
                <TextBlock Grid.Row="2" Text="{Binding ErrorMessage}" FontSize="14" Foreground="#EF4444"
                           HorizontalAlignment="Center" VerticalAlignment="Top" Margin="0,10,0,0"
                           Visibility="{Binding ErrorMessage, Converter={StaticResource StringToVisibility}}"/>

                <!-- ── Tutorial Cards Grid ───────────────────────────────── -->
                <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                    <ItemsControl ItemsSource="{Binding Tutorials}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel Margin="0,0,0,20"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="#232629" BorderBrush="#1E293B" BorderThickness="1" CornerRadius="12" Padding="20" Width="300" Margin="0,0,20,20">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="*"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>

                                        <!-- Preview area -->
                                        <Border Grid.Row="0" Height="140" Background="#1E293B" CornerRadius="8" Margin="0,0,0,15">
                                            <TextBlock Text="{loc:Loc TutorialsPreview}" Foreground="#6A7D90" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>

                                        <!-- Category badge + Title -->
                                        <StackPanel Grid.Row="1" Margin="0,0,0,10">
                                            <Border Background="#0F172A" BorderBrush="#1E293B" BorderThickness="1" CornerRadius="4" Padding="6,2" HorizontalAlignment="Left" Margin="0,0,0,10">
                                                <TextBlock Text="{Binding Category}" Foreground="#6A7D90" FontSize="10" FontWeight="Bold">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Typography.Capitals" Value="AllSmallCaps"/>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                            </Border>
                                            <TextBlock Text="{Binding Title}" FontSize="16" FontWeight="Bold" Foreground="White" TextWrapping="Wrap"/>
                                        </StackPanel>

                                        <!-- Description -->
                                        <TextBlock Grid.Row="2" Text="{Binding Description}"
                                                   Foreground="#94A3B8" FontSize="13" TextWrapping="Wrap" LineHeight="18" Margin="0,0,0,20"/>

                                        <!-- Progress + Button -->
                                        <StackPanel Grid.Row="3">
                                            <Grid Margin="0,0,0,8">
                                                <TextBlock Foreground="#94A3B8" FontSize="11" FontWeight="Bold" HorizontalAlignment="Left"
                                                           Text="{Binding StepCount, Converter={StaticResource LocalizedFormat}, ConverterParameter=TutorialsSteps}"/>
                                                <TextBlock Foreground="#94A3B8" FontSize="11" HorizontalAlignment="Right"
                                                           Text="{Binding DurationMins, Converter={StaticResource LocalizedFormat}, ConverterParameter=TutorialsMinutes}"/>
                                            </Grid>

                                            <Border Height="6" Background="#1E293B" CornerRadius="3" Margin="0,0,0,15">
                                                <Border Background="#6A7D90" CornerRadius="3" HorizontalAlignment="Left">
                                                    <Border.Style>
                                                        <Style TargetType="Border">
                                                            <Setter Property="Width" Value="0"/>
                                                        </Style>
                                                    </Border.Style>
                                                </Border>
                                            </Border>

                                            <Button Content="{loc:Loc TutorialsStartTrack}" Height="35"
                                                    Background="#1E293B" Foreground="White" FontSize="12" FontWeight="Bold" BorderThickness="0" Cursor="Hand"
                                                    Command="{Binding DataContext.OpenTutorialCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                    CommandParameter="{Binding}">
                                                <Button.Resources>
                                                    <Style TargetType="Border">
                                                        <Setter Property="CornerRadius" Value="6"/>
                                                    </Style>
                                                </Button.Resources>
                                            </Button>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>
        </Grid>
    </Border>
</Window>
