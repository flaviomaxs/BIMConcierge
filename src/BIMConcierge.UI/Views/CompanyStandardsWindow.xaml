<Window x:Class="BIMConcierge.UI.Views.CompanyStandardsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:vm="clr-namespace:BIMConcierge.UI.ViewModels"
        xmlns:conv="clr-namespace:BIMConcierge.UI.Converters"
        mc:Ignorable="d"
        Title="BIMConcierge - Padrões da Empresa" Height="768" Width="1280"
        WindowStartupLocation="CenterScreen" WindowStyle="None"
        AllowsTransparency="True" Background="Transparent" FontFamily="Segoe UI">

    <Window.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVis"/>
        <conv:NullToVisibilityConverter x:Key="NullToVis"/>
    </Window.Resources>

    <Border CornerRadius="16" Background="#17191B" BorderBrush="#1E293B" BorderThickness="1" MouseLeftButtonDown="Border_MouseLeftButtonDown">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="260"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Sidebar -->
            <Border Grid.Column="0" Background="#0F172A" CornerRadius="16,0,0,16" BorderBrush="#1E293B" BorderThickness="0,0,1,0" Padding="20">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Logo -->
                    <StackPanel Grid.Row="0" Margin="0,0,0,30" Orientation="Horizontal" VerticalAlignment="Center">
                        <Border Width="32" Height="32" Background="#1E293B" CornerRadius="8" Margin="0,0,12,0">
                            <TextBlock Text="BIM" Foreground="#6A7D90" FontWeight="Black" FontSize="12" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock Text="BIM CONCIERGE" FontSize="15" FontWeight="Bold" Foreground="#6A7D90" VerticalAlignment="Center"/>
                    </StackPanel>

                    <!-- App Navigation -->
                    <StackPanel Grid.Row="1" Margin="0,0,0,20">
                        <Border Background="Transparent" CornerRadius="8" Padding="12,10" Margin="0,0,0,4" Cursor="Hand"
                                MouseLeftButtonUp="SidebarDashboard_Click">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="⊞" Foreground="#94A3B8" FontSize="16" Margin="0,0,12,0" VerticalAlignment="Center"/>
                                <TextBlock Text="Dashboard" Foreground="#94A3B8" FontWeight="Medium" FontSize="13" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                        <Border Background="#1E293B" CornerRadius="8" Padding="12,10" Margin="0,0,0,4" Cursor="Hand">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="★" Foreground="White" FontSize="16" Margin="0,0,12,0" VerticalAlignment="Center"/>
                                <TextBlock Text="Padrões da Empresa" Foreground="White" FontWeight="SemiBold" FontSize="13" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                        <Border Background="Transparent" CornerRadius="8" Padding="12,10" Margin="0,0,0,4" Cursor="Hand"
                                MouseLeftButtonUp="SidebarProgress_Click">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="📊" Foreground="#94A3B8" FontSize="14" Margin="0,0,12,0" VerticalAlignment="Center"/>
                                <TextBlock Text="Progresso" Foreground="#94A3B8" FontWeight="Medium" FontSize="13" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                        <Border Background="Transparent" CornerRadius="8" Padding="12,10" Margin="0,0,0,4" Cursor="Hand"
                                MouseLeftButtonUp="SidebarAchievements_Click">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="🏆" Foreground="#94A3B8" FontSize="14" Margin="0,0,12,0" VerticalAlignment="Center"/>
                                <TextBlock Text="Conquistas" Foreground="#94A3B8" FontWeight="Medium" FontSize="13" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>

                        <Border Height="1" Background="#1E293B" Margin="0,8,0,8"/>

                        <TextBlock Text="CONFIGURAÇÕES" Foreground="#94A3B8" FontSize="10" FontWeight="Bold" Margin="4,0,0,8" Opacity="0.6"/>
                    </StackPanel>

                    <!-- Category Navigation -->
                    <StackPanel Grid.Row="2">
                        <Border Background="#1E293B" CornerRadius="8" Padding="12,10" Margin="0,0,0,4" Cursor="Hand">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="✎" Foreground="White" FontSize="16" Margin="0,0,12,0" VerticalAlignment="Center"/>
                                <TextBlock Text="Convenções de Nomenclatura" Foreground="White" FontWeight="SemiBold" FontSize="13" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>

                        <Border Background="Transparent" CornerRadius="8" Padding="12,10" Margin="0,0,0,4" Cursor="Hand">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="▧" Foreground="#94A3B8" FontSize="16" Margin="0,0,12,0" VerticalAlignment="Center"/>
                                <TextBlock Text="Requisitos de LOD" Foreground="#94A3B8" FontWeight="Medium" FontSize="13" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>

                        <Border Background="Transparent" CornerRadius="8" Padding="12,10" Margin="0,0,0,4" Cursor="Hand">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="▣" Foreground="#94A3B8" FontSize="16" Margin="0,0,12,0" VerticalAlignment="Center"/>
                                <TextBlock Text="Regras de Workset" Foreground="#94A3B8" FontWeight="Medium" FontSize="13" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>

                        <Border Background="Transparent" CornerRadius="8" Padding="12,10" Margin="0,0,0,4" Cursor="Hand">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="✓" Foreground="#94A3B8" FontSize="16" Margin="0,0,12,0" VerticalAlignment="Center"/>
                                <TextBlock Text="Boas Práticas" Foreground="#94A3B8" FontWeight="Medium" FontSize="13" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>

                    <!-- Auto-Correction Toggle -->
                    <Border Grid.Row="3" Background="#17191B" BorderBrush="#1E293B" BorderThickness="1" CornerRadius="12" Padding="16">
                        <StackPanel>
                            <Grid Margin="0,0,0,8">
                                <TextBlock Text="Auto-Correção" Foreground="#94A3B8" FontSize="12" FontWeight="SemiBold" HorizontalAlignment="Left" VerticalAlignment="Center"/>
                                <CheckBox x:Name="ChkAutoCorrection" IsChecked="True" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                            </Grid>
                            <TextBlock Text="Aplicar padrões de nomenclatura automaticamente durante a criação de elementos."
                                       Foreground="#64748B" FontSize="10" TextWrapping="Wrap" LineHeight="16"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>

            <!-- Main Content -->
            <Grid Grid.Column="1">
                <!-- Error Banner -->
                <Border Background="#7F1D1D" CornerRadius="8" Padding="12,8" Margin="40,12,40,0"
                        VerticalAlignment="Top" Panel.ZIndex="5"
                        Visibility="{Binding ErrorMessage, Converter={StaticResource NullToVis}}">
                    <TextBlock Text="{Binding ErrorMessage}" Foreground="#FCA5A5" FontSize="12" FontWeight="Medium" TextWrapping="Wrap"/>
                </Border>

                <!-- Loading Overlay -->
                <Border Background="#17191BCC" CornerRadius="0,16,16,0" Panel.ZIndex="10"
                        Visibility="{Binding IsBusy, Converter={StaticResource BoolToVis}}">
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                        <Border Width="48" Height="48" Background="#1E293B" CornerRadius="24" Margin="0,0,0,12">
                            <TextBlock Text="⟳" Foreground="#6A7D90" FontSize="24" HorizontalAlignment="Center" VerticalAlignment="Center"
                                       RenderTransformOrigin="0.5,0.5">
                                <TextBlock.RenderTransform>
                                    <RotateTransform x:Name="SpinTransform"/>
                                </TextBlock.RenderTransform>
                            </TextBlock>
                        </Border>
                        <TextBlock Text="Carregando..." Foreground="#94A3B8" FontSize="14" FontWeight="Medium" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>

            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <Grid Margin="40">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Close Button -->
                    <Button Grid.Row="0" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,-20,-20,0"
                            Content="✕" FontSize="16" Foreground="#94A3B8" Background="Transparent" BorderThickness="0"
                            Cursor="Hand" Click="BtnClose_Click"/>

                    <!-- Header -->
                    <Grid Grid.Row="0" Margin="0,0,0,30">
                        <StackPanel HorizontalAlignment="Left">
                            <TextBlock Text="Convenções de Nomenclatura" FontSize="24" FontWeight="Bold" Foreground="White" Margin="0,0,0,6"/>
                            <TextBlock Text="Defina regras estruturais e padrões regex para categorias de elementos Revit." FontSize="13" Foreground="#94A3B8"/>
                        </StackPanel>
                        <StackPanel HorizontalAlignment="Right" Orientation="Horizontal" VerticalAlignment="Center">
                            <Button Content="Exportar JSON" Height="36" Padding="16,0" Margin="0,0,10,0"
                                    Background="Transparent" Foreground="#6A7D90" FontSize="12" FontWeight="SemiBold"
                                    BorderBrush="#6A7D90" BorderThickness="1" Cursor="Hand">
                                <Button.Resources>
                                    <Style TargetType="Border"><Setter Property="CornerRadius" Value="8"/></Style>
                                </Button.Resources>
                            </Button>
                            <Button Content="Salvar Alterações" Height="36" Padding="20,0"
                                    Background="#6A7D90" Foreground="White" FontSize="12" FontWeight="SemiBold"
                                    BorderThickness="0" Cursor="Hand">
                                <Button.Resources>
                                    <Style TargetType="Border"><Setter Property="CornerRadius" Value="8"/></Style>
                                </Button.Resources>
                            </Button>
                        </StackPanel>
                    </Grid>

                    <!-- Wall Categories Card -->
                    <Border Grid.Row="1" Background="#121820" BorderBrush="#1E293B" BorderThickness="1" CornerRadius="12" Margin="0,0,0,20">
                        <StackPanel>
                            <Border Background="#0F172A" CornerRadius="12,12,0,0" Padding="16,12" BorderBrush="#1E293B" BorderThickness="0,0,0,1">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="▦" Foreground="#6A7D90" FontSize="16" Margin="0,0,10,0" VerticalAlignment="Center"/>
                                    <TextBlock Text="Categorias de Parede" Foreground="White" FontSize="13" FontWeight="Bold" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Border>
                            <Grid Margin="20">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="16"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="16"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="REGRA DE PREFIXO" Foreground="#94A3B8" FontSize="10" FontWeight="Bold" Margin="0,0,0,8"/>
                                    <TextBox Text="EXT_" Background="#0F172A" Foreground="White" FontSize="13" Padding="12,8"
                                             BorderBrush="#1E293B" BorderThickness="1">
                                        <TextBox.Resources>
                                            <Style TargetType="Border"><Setter Property="CornerRadius" Value="8"/></Style>
                                        </TextBox.Resources>
                                    </TextBox>
                                </StackPanel>
                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="REGRA DE SUFIXO" Foreground="#94A3B8" FontSize="10" FontWeight="Bold" Margin="0,0,0,8"/>
                                    <TextBox Text="_WALL" Background="#0F172A" Foreground="White" FontSize="13" Padding="12,8"
                                             BorderBrush="#1E293B" BorderThickness="1">
                                        <TextBox.Resources>
                                            <Style TargetType="Border"><Setter Property="CornerRadius" Value="8"/></Style>
                                        </TextBox.Resources>
                                    </TextBox>
                                </StackPanel>
                                <StackPanel Grid.Column="4">
                                    <TextBlock Text="PADRÃO REGEX" Foreground="#94A3B8" FontSize="10" FontWeight="Bold" Margin="0,0,0,8"/>
                                    <TextBox Text="^[A-Z]{3}_.*" Background="#0F172A" Foreground="White" FontSize="13" FontFamily="Consolas" Padding="12,8"
                                             BorderBrush="#1E293B" BorderThickness="1">
                                        <TextBox.Resources>
                                            <Style TargetType="Border"><Setter Property="CornerRadius" Value="8"/></Style>
                                        </TextBox.Resources>
                                    </TextBox>
                                </StackPanel>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <!-- Door & Window Categories Card -->
                    <Border Grid.Row="2" Background="#121820" BorderBrush="#1E293B" BorderThickness="1" CornerRadius="12" Margin="0,0,0,30">
                        <StackPanel>
                            <Border Background="#0F172A" CornerRadius="12,12,0,0" Padding="16,12" BorderBrush="#1E293B" BorderThickness="0,0,0,1">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="☐" Foreground="#6A7D90" FontSize="16" Margin="0,0,10,0" VerticalAlignment="Center"/>
                                    <TextBlock Text="Categorias de Portas e Janelas" Foreground="White" FontSize="13" FontWeight="Bold" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Border>
                            <Grid Margin="20">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="16"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="16"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="REGRA DE PREFIXO" Foreground="#94A3B8" FontSize="10" FontWeight="Bold" Margin="0,0,0,8"/>
                                    <TextBox Text="DR_" Background="#0F172A" Foreground="White" FontSize="13" Padding="12,8"
                                             BorderBrush="#1E293B" BorderThickness="1">
                                        <TextBox.Resources>
                                            <Style TargetType="Border"><Setter Property="CornerRadius" Value="8"/></Style>
                                        </TextBox.Resources>
                                    </TextBox>
                                </StackPanel>
                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="REGRA DE SUFIXO" Foreground="#94A3B8" FontSize="10" FontWeight="Bold" Margin="0,0,0,8"/>
                                    <TextBox Text="(Size)" Background="#0F172A" Foreground="White" FontSize="13" Padding="12,8"
                                             BorderBrush="#1E293B" BorderThickness="1">
                                        <TextBox.Resources>
                                            <Style TargetType="Border"><Setter Property="CornerRadius" Value="8"/></Style>
                                        </TextBox.Resources>
                                    </TextBox>
                                </StackPanel>
                                <StackPanel Grid.Column="4">
                                    <TextBlock Text="PADRÃO REGEX" Foreground="#94A3B8" FontSize="10" FontWeight="Bold" Margin="0,0,0,8"/>
                                    <TextBox Text="DR-[0-9]{2}-.*" Background="#0F172A" Foreground="White" FontSize="13" FontFamily="Consolas" Padding="12,8"
                                             BorderBrush="#1E293B" BorderThickness="1">
                                        <TextBox.Resources>
                                            <Style TargetType="Border"><Setter Property="CornerRadius" Value="8"/></Style>
                                        </TextBox.Resources>
                                    </TextBox>
                                </StackPanel>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <!-- LOD Requirements Matrix -->
                    <StackPanel Grid.Row="3" Margin="0,0,0,30">
                        <Grid Margin="0,0,0,16">
                            <TextBlock Text="Matriz de Requisitos de LOD" FontSize="20" FontWeight="Bold" Foreground="White" HorizontalAlignment="Left"/>
                            <TextBlock Text="+ Adicionar Categoria" FontSize="11" FontWeight="Bold" Foreground="#6A7D90" HorizontalAlignment="Right"
                                       VerticalAlignment="Center" Cursor="Hand"/>
                        </Grid>

                        <Border Background="#121820" BorderBrush="#1E293B" BorderThickness="1" CornerRadius="12">
                            <StackPanel>
                                <!-- Table Header -->
                                <Border Background="#0F172A" CornerRadius="12,12,0,0" Padding="20,14" BorderBrush="#1E293B" BorderThickness="0,0,0,1">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="2*"/>
                                            <ColumnDefinition Width="2*"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="60"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="CATEGORIA" Foreground="#94A3B8" FontSize="10" FontWeight="Bold"/>
                                        <TextBlock Grid.Column="1" Text="FASE" Foreground="#94A3B8" FontSize="10" FontWeight="Bold"/>
                                        <TextBlock Grid.Column="2" Text="LOD" Foreground="#94A3B8" FontSize="10" FontWeight="Bold" HorizontalAlignment="Center"/>
                                        <TextBlock Grid.Column="3" Text="AÇÃO" Foreground="#94A3B8" FontSize="10" FontWeight="Bold" HorizontalAlignment="Center"/>
                                    </Grid>
                                </Border>

                                <!-- Row 1 -->
                                <Border Padding="20,14" BorderBrush="#1E293B" BorderThickness="0,0,0,1">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="2*"/>
                                            <ColumnDefinition Width="2*"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="60"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="Paredes - Externas" Foreground="White" FontSize="13" FontWeight="Medium" VerticalAlignment="Center"/>
                                        <TextBlock Grid.Column="1" Text="Documentação de Construção" Foreground="#94A3B8" FontSize="13" VerticalAlignment="Center"/>
                                        <Border Grid.Column="2" Background="#0F172A" CornerRadius="6" Padding="10,4" HorizontalAlignment="Center">
                                            <TextBlock Text="LOD 300" Foreground="White" FontSize="11" FontWeight="Bold"/>
                                        </Border>
                                        <TextBlock Grid.Column="3" Text="✕" Foreground="#64748B" FontSize="16" HorizontalAlignment="Center" VerticalAlignment="Center" Cursor="Hand"/>
                                    </Grid>
                                </Border>

                                <!-- Row 2 -->
                                <Border Padding="20,14" BorderBrush="#1E293B" BorderThickness="0,0,0,1">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="2*"/>
                                            <ColumnDefinition Width="2*"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="60"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="Colunas Estruturais" Foreground="White" FontSize="13" FontWeight="Medium" VerticalAlignment="Center"/>
                                        <TextBlock Grid.Column="1" Text="Desenvolvimento de Projeto" Foreground="#94A3B8" FontSize="13" VerticalAlignment="Center"/>
                                        <Border Grid.Column="2" Background="#0F172A" CornerRadius="6" Padding="10,4" HorizontalAlignment="Center">
                                            <TextBlock Text="LOD 350" Foreground="White" FontSize="11" FontWeight="Bold"/>
                                        </Border>
                                        <TextBlock Grid.Column="3" Text="✕" Foreground="#64748B" FontSize="16" HorizontalAlignment="Center" VerticalAlignment="Center" Cursor="Hand"/>
                                    </Grid>
                                </Border>

                                <!-- Row 3 -->
                                <Border Padding="20,14" BorderBrush="#1E293B" BorderThickness="0,0,0,1">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="2*"/>
                                            <ColumnDefinition Width="2*"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="60"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="Equipamentos Mecânicos" Foreground="White" FontSize="13" FontWeight="Medium" VerticalAlignment="Center"/>
                                        <TextBlock Grid.Column="1" Text="As-Built" Foreground="#94A3B8" FontSize="13" VerticalAlignment="Center"/>
                                        <Border Grid.Column="2" Background="#0F172A" CornerRadius="6" Padding="10,4" HorizontalAlignment="Center">
                                            <TextBlock Text="LOD 400" Foreground="White" FontSize="11" FontWeight="Bold"/>
                                        </Border>
                                        <TextBlock Grid.Column="3" Text="✕" Foreground="#64748B" FontSize="16" HorizontalAlignment="Center" VerticalAlignment="Center" Cursor="Hand"/>
                                    </Grid>
                                </Border>

                                <!-- Row 4 -->
                                <Border Padding="20,14">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="2*"/>
                                            <ColumnDefinition Width="2*"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="60"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="Mobiliário" Foreground="White" FontSize="13" FontWeight="Medium" VerticalAlignment="Center"/>
                                        <TextBlock Grid.Column="1" Text="Planejamento Espacial" Foreground="#94A3B8" FontSize="13" VerticalAlignment="Center"/>
                                        <Border Grid.Column="2" Background="#0F172A" CornerRadius="6" Padding="10,4" HorizontalAlignment="Center">
                                            <TextBlock Text="LOD 200" Foreground="White" FontSize="11" FontWeight="Bold"/>
                                        </Border>
                                        <TextBlock Grid.Column="3" Text="✕" Foreground="#64748B" FontSize="16" HorizontalAlignment="Center" VerticalAlignment="Center" Cursor="Hand"/>
                                    </Grid>
                                </Border>
                            </StackPanel>
                        </Border>
                    </StackPanel>

                    <!-- Info Cards -->
                    <Grid Grid.Row="4" Margin="0,0,0,20">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="20"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- Audit Mode Card -->
                        <Border Grid.Column="0" Background="#121820" BorderBrush="#1E293B" BorderThickness="1" CornerRadius="12" Padding="20">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Border Grid.Column="0" Width="44" Height="44" Background="#422006" CornerRadius="8" Margin="0,0,16,0">
                                    <TextBlock Text="⚠" Foreground="#F59E0B" FontSize="20" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                    <TextBlock Text="Modo Auditoria: Ativado" Foreground="White" FontSize="13" FontWeight="Bold" Margin="0,0,0,4"/>
                                    <TextBlock Text="O sistema sinalizará componentes que excedam 5MB ou contenham mais de 20.000 polígonos."
                                               Foreground="#94A3B8" FontSize="11" TextWrapping="Wrap" LineHeight="18"/>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <!-- Standard Enforcement Card -->
                        <Border Grid.Column="2" Background="#121820" BorderBrush="#1E293B" BorderThickness="1" CornerRadius="12" Padding="20">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Border Grid.Column="0" Width="44" Height="44" Background="#052e16" CornerRadius="8" Margin="0,0,16,0">
                                    <TextBlock Text="✓" Foreground="#10B981" FontSize="20" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                    <TextBlock Text="Aplicação de Padrões" Foreground="White" FontSize="13" FontWeight="Bold" Margin="0,0,0,4"/>
                                    <TextBlock Text="Monitoramento ativo garantindo que todos os Revit Links estejam como 'Overlay' ao invés de 'Attachment'."
                                               Foreground="#94A3B8" FontSize="11" TextWrapping="Wrap" LineHeight="18"/>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </Grid>
                </Grid>
            </ScrollViewer>
            </Grid>
        </Grid>
    </Border>
</Window>
