<Window x:Class="BIMConcierge.UI.Views.CompanyStandardsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:vm="clr-namespace:BIMConcierge.UI.ViewModels"
        xmlns:conv="clr-namespace:BIMConcierge.UI.Converters"
        xmlns:loc="clr-namespace:BIMConcierge.UI.Localization"
        mc:Ignorable="d"
        Title="{loc:Loc StandardsTitle}" Height="768" Width="1280"
        WindowStartupLocation="CenterScreen" WindowStyle="None"
        AllowsTransparency="True" Background="Transparent" FontFamily="Segoe UI">

    <Window.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVis"/>
        <conv:NullToVisibilityConverter x:Key="NullToVis"/>
    </Window.Resources>

    <Border CornerRadius="16" Background="#17191B" BorderBrush="#1E293B" BorderThickness="1" MouseLeftButtonDown="Border_MouseLeftButtonDown">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="260"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Sidebar -->
            <Border Grid.Column="0" Background="#0F172A" CornerRadius="16,0,0,16" BorderBrush="#1E293B" BorderThickness="0,0,1,0" Padding="20">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Logo -->
                    <StackPanel Grid.Row="0" Margin="0,0,0,30" Orientation="Horizontal" VerticalAlignment="Center">
                        <Border Width="32" Height="32" Background="#1E293B" CornerRadius="8" Margin="0,0,12,0">
                            <TextBlock Text="BIM" Foreground="#6A7D90" FontWeight="Black" FontSize="12" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock Text="BIM CONCIERGE" FontSize="15" FontWeight="Bold" Foreground="#6A7D90" VerticalAlignment="Center"/>
                    </StackPanel>

                    <!-- App Navigation -->
                    <StackPanel Grid.Row="1" Margin="0,0,0,20">
                        <Border Background="Transparent" CornerRadius="8" Padding="12,10" Margin="0,0,0,4" Cursor="Hand"
                                MouseLeftButtonDown="SidebarDashboard_Click">
                            <StackPanel Orientation="Horizontal">
                                <Path Data="M2,2 H7 V7 H2Z M9,2 H14 V7 H9Z M2,9 H7 V14 H2Z M9,9 H14 V14 H9Z"
                                      Fill="#94A3B8" Width="16" Height="16" Stretch="Uniform" Margin="0,0,12,0" VerticalAlignment="Center"/>
                                <TextBlock Text="{loc:Loc NavDashboard}" Foreground="#94A3B8" FontWeight="Medium" FontSize="13" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                        <Border Background="#1E293B" CornerRadius="8" Padding="12,10" Margin="0,0,0,4" Cursor="Hand">
                            <StackPanel Orientation="Horizontal">
                                <Path Data="M8,1 L14,3.5 V8 C14,11.5 8,15 8,15 C8,15 2,11.5 2,8 V3.5Z"
                                      Fill="White" Width="16" Height="16" Stretch="Uniform" Margin="0,0,12,0" VerticalAlignment="Center"/>
                                <TextBlock Text="{loc:Loc NavStandards}" Foreground="White" FontWeight="SemiBold" FontSize="13" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                        <Border Background="Transparent" CornerRadius="8" Padding="12,10" Margin="0,0,0,4" Cursor="Hand"
                                MouseLeftButtonDown="SidebarProgress_Click">
                            <StackPanel Orientation="Horizontal">
                                <Path Data="M2,14 V9 H5 V14Z M6.5,14 V6 H9.5 V14Z M11,14 V2 H14 V14Z"
                                      Fill="#94A3B8" Width="16" Height="16" Stretch="Uniform" Margin="0,0,12,0" VerticalAlignment="Center"/>
                                <TextBlock Text="{loc:Loc NavProgress}" Foreground="#94A3B8" FontWeight="Medium" FontSize="13" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                        <Border Background="Transparent" CornerRadius="8" Padding="12,10" Margin="0,0,0,4" Cursor="Hand"
                                MouseLeftButtonDown="SidebarAchievements_Click">
                            <StackPanel Orientation="Horizontal">
                                <Path Data="M5,1 H11 L12,5 L8,8 L4,5Z M6,9 H10 V11 H6Z M4,11.5 H12 V13 H4Z"
                                      Fill="#94A3B8" Width="16" Height="16" Stretch="Uniform" Margin="0,0,12,0" VerticalAlignment="Center"/>
                                <TextBlock Text="{loc:Loc NavAchievements}" Foreground="#94A3B8" FontWeight="Medium" FontSize="13" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>

                        <Border Height="1" Background="#1E293B" Margin="0,8,0,8"/>

                        <TextBlock Text="{loc:Loc NavSettings}" Foreground="#94A3B8" FontSize="10" FontWeight="Bold" Margin="4,0,0,8" Opacity="0.6"/>
                    </StackPanel>

                    <!-- Category Navigation -->
                    <StackPanel Grid.Row="2">
                        <Border CornerRadius="8" Padding="12,10" Margin="0,0,0,4" Cursor="Hand"
                                MouseLeftButtonUp="CategoryNaming_Click">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Background" Value="Transparent"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding SelectedCategory}" Value="Naming Conventions">
                                            <Setter Property="Background" Value="#1E293B"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#x270E;" FontSize="16" Margin="0,0,12,0" VerticalAlignment="Center">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Foreground" Value="#94A3B8"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding SelectedCategory}" Value="Naming Conventions">
                                                    <Setter Property="Foreground" Value="White"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                                <TextBlock Text="{loc:Loc StandardsNaming}" FontSize="13" VerticalAlignment="Center">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Foreground" Value="#94A3B8"/>
                                            <Setter Property="FontWeight" Value="Medium"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding SelectedCategory}" Value="Naming Conventions">
                                                    <Setter Property="Foreground" Value="White"/>
                                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </StackPanel>
                        </Border>

                        <Border CornerRadius="8" Padding="12,10" Margin="0,0,0,4" Cursor="Hand"
                                MouseLeftButtonUp="CategoryLOD_Click">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Background" Value="Transparent"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding SelectedCategory}" Value="LOD Requirements">
                                            <Setter Property="Background" Value="#1E293B"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#x25A7;" FontSize="16" Margin="0,0,12,0" VerticalAlignment="Center">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Foreground" Value="#94A3B8"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding SelectedCategory}" Value="LOD Requirements">
                                                    <Setter Property="Foreground" Value="White"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                                <TextBlock Text="{loc:Loc StandardsLOD}" FontSize="13" VerticalAlignment="Center">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Foreground" Value="#94A3B8"/>
                                            <Setter Property="FontWeight" Value="Medium"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding SelectedCategory}" Value="LOD Requirements">
                                                    <Setter Property="Foreground" Value="White"/>
                                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </StackPanel>
                        </Border>

                        <Border CornerRadius="8" Padding="12,10" Margin="0,0,0,4" Cursor="Hand"
                                MouseLeftButtonUp="CategoryWorkset_Click">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Background" Value="Transparent"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding SelectedCategory}" Value="Workset Rules">
                                            <Setter Property="Background" Value="#1E293B"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#x25A3;" FontSize="16" Margin="0,0,12,0" VerticalAlignment="Center">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Foreground" Value="#94A3B8"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding SelectedCategory}" Value="Workset Rules">
                                                    <Setter Property="Foreground" Value="White"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                                <TextBlock Text="{loc:Loc StandardsWorkset}" FontSize="13" VerticalAlignment="Center">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Foreground" Value="#94A3B8"/>
                                            <Setter Property="FontWeight" Value="Medium"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding SelectedCategory}" Value="Workset Rules">
                                                    <Setter Property="Foreground" Value="White"/>
                                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </StackPanel>
                        </Border>

                        <Border CornerRadius="8" Padding="12,10" Margin="0,0,0,4" Cursor="Hand"
                                MouseLeftButtonUp="CategoryBestPractices_Click">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Background" Value="Transparent"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding SelectedCategory}" Value="Best Practices">
                                            <Setter Property="Background" Value="#1E293B"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#x2713;" FontSize="16" Margin="0,0,12,0" VerticalAlignment="Center">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Foreground" Value="#94A3B8"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding SelectedCategory}" Value="Best Practices">
                                                    <Setter Property="Foreground" Value="White"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                                <TextBlock Text="{loc:Loc StandardsBestPractices}" FontSize="13" VerticalAlignment="Center">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Foreground" Value="#94A3B8"/>
                                            <Setter Property="FontWeight" Value="Medium"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding SelectedCategory}" Value="Best Practices">
                                                    <Setter Property="Foreground" Value="White"/>
                                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </StackPanel>
                        </Border>
                    </StackPanel>

                    <!-- Auto-Correction Toggle -->
                    <Border Grid.Row="3" Background="#17191B" BorderBrush="#1E293B" BorderThickness="1" CornerRadius="12" Padding="16">
                        <StackPanel>
                            <Grid Margin="0,0,0,8">
                                <TextBlock Text="{loc:Loc StandardsAutoCorrection}" Foreground="#94A3B8" FontSize="12" FontWeight="SemiBold" HorizontalAlignment="Left" VerticalAlignment="Center"/>
                                <CheckBox IsChecked="{Binding IsAutoCorrectionEnabled}" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                            </Grid>
                            <TextBlock Text="{loc:Loc StandardsAutoCorrectDesc}"
                                       Foreground="#64748B" FontSize="10" TextWrapping="Wrap" LineHeight="16"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>

            <!-- Main Content -->
            <Grid Grid.Column="1">
                <!-- Error Banner -->
                <Border Background="#7F1D1D" CornerRadius="8" Padding="12,8" Margin="40,12,40,0"
                        VerticalAlignment="Top" Panel.ZIndex="5"
                        Visibility="{Binding ErrorMessage, Converter={StaticResource NullToVis}}">
                    <TextBlock Text="{Binding ErrorMessage}" Foreground="#FCA5A5" FontSize="12" FontWeight="Medium" TextWrapping="Wrap"/>
                </Border>

                <!-- Loading Overlay -->
                <Border Background="#17191BCC" CornerRadius="0,16,16,0" Panel.ZIndex="10"
                        Visibility="{Binding IsBusy, Converter={StaticResource BoolToVis}}">
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                        <Border Width="48" Height="48" Background="#1E293B" CornerRadius="24" Margin="0,0,0,12">
                            <TextBlock Text="⟳" Foreground="#6A7D90" FontSize="24" HorizontalAlignment="Center" VerticalAlignment="Center"
                                       RenderTransformOrigin="0.5,0.5">
                                <TextBlock.RenderTransform>
                                    <RotateTransform x:Name="SpinTransform"/>
                                </TextBlock.RenderTransform>
                            </TextBlock>
                        </Border>
                        <TextBlock Text="{loc:Loc Loading}" Foreground="#94A3B8" FontSize="14" FontWeight="Medium" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>

            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <Grid Margin="40">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Close Button -->
                    <Button Grid.Row="0" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,-20,-20,0"
                            Content="✕" FontSize="16" Foreground="#94A3B8" Background="Transparent" BorderThickness="0"
                            Cursor="Hand" Click="BtnClose_Click"/>

                    <!-- Header -->
                    <Grid Grid.Row="0" Margin="0,0,0,30">
                        <StackPanel HorizontalAlignment="Left">
                            <TextBlock Text="{loc:Loc StandardsNaming}" FontSize="24" FontWeight="Bold" Foreground="White" Margin="0,0,0,6"/>
                            <TextBlock Text="{loc:Loc StandardsNamingSubtitle}" FontSize="13" Foreground="#94A3B8"/>
                        </StackPanel>
                        <StackPanel HorizontalAlignment="Right" Orientation="Horizontal" VerticalAlignment="Center">
                            <Button Content="{loc:Loc StandardsExportJson}" Height="36" Padding="16,0" Margin="0,0,10,0"
                                    Background="Transparent" Foreground="#6A7D90" FontSize="12" FontWeight="SemiBold"
                                    BorderBrush="#6A7D90" BorderThickness="1" Cursor="Hand"
                                    Click="BtnExportJson_Click">
                                <Button.Resources>
                                    <Style TargetType="Border"><Setter Property="CornerRadius" Value="8"/></Style>
                                </Button.Resources>
                            </Button>
                            <Button Content="{loc:Loc StandardsSaveChanges}" Height="36" Padding="20,0"
                                    Background="#6A7D90" Foreground="White" FontSize="12" FontWeight="SemiBold"
                                    BorderThickness="0" Cursor="Hand"
                                    Command="{Binding RunValidationCommand}">
                                <Button.Resources>
                                    <Style TargetType="Border"><Setter Property="CornerRadius" Value="8"/></Style>
                                </Button.Resources>
                            </Button>
                        </StackPanel>
                    </Grid>

                    <!-- Wall Categories Card -->
                    <Border Grid.Row="1" Background="#232629" BorderBrush="#1E293B" BorderThickness="1" CornerRadius="12" Margin="0,0,0,20">
                        <StackPanel>
                            <Border Background="#0F172A" CornerRadius="12,12,0,0" Padding="16,12" BorderBrush="#1E293B" BorderThickness="0,0,0,1">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="▦" Foreground="#6A7D90" FontSize="16" Margin="0,0,10,0" VerticalAlignment="Center"/>
                                    <TextBlock Text="{loc:Loc StandardsWallCategories}" Foreground="White" FontSize="13" FontWeight="Bold" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Border>
                            <Grid Margin="20">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="16"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="16"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="{loc:Loc StandardsPrefixRule}" Foreground="#94A3B8" FontSize="10" FontWeight="Bold" Margin="0,0,0,8"/>
                                    <TextBox Text="EXT_" Background="#0F172A" Foreground="White" FontSize="13" Padding="12,8"
                                             BorderBrush="#1E293B" BorderThickness="1">
                                        <TextBox.Resources>
                                            <Style TargetType="Border"><Setter Property="CornerRadius" Value="8"/></Style>
                                        </TextBox.Resources>
                                    </TextBox>
                                </StackPanel>
                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="{loc:Loc StandardsSuffixRule}" Foreground="#94A3B8" FontSize="10" FontWeight="Bold" Margin="0,0,0,8"/>
                                    <TextBox Text="_WALL" Background="#0F172A" Foreground="White" FontSize="13" Padding="12,8"
                                             BorderBrush="#1E293B" BorderThickness="1">
                                        <TextBox.Resources>
                                            <Style TargetType="Border"><Setter Property="CornerRadius" Value="8"/></Style>
                                        </TextBox.Resources>
                                    </TextBox>
                                </StackPanel>
                                <StackPanel Grid.Column="4">
                                    <TextBlock Text="{loc:Loc StandardsRegexPattern}" Foreground="#94A3B8" FontSize="10" FontWeight="Bold" Margin="0,0,0,8"/>
                                    <TextBox Text="^[A-Z]{3}_.*" Background="#0F172A" Foreground="White" FontSize="13" FontFamily="Consolas" Padding="12,8"
                                             BorderBrush="#1E293B" BorderThickness="1">
                                        <TextBox.Resources>
                                            <Style TargetType="Border"><Setter Property="CornerRadius" Value="8"/></Style>
                                        </TextBox.Resources>
                                    </TextBox>
                                </StackPanel>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <!-- Door & Window Categories Card -->
                    <Border Grid.Row="2" Background="#232629" BorderBrush="#1E293B" BorderThickness="1" CornerRadius="12" Margin="0,0,0,30">
                        <StackPanel>
                            <Border Background="#0F172A" CornerRadius="12,12,0,0" Padding="16,12" BorderBrush="#1E293B" BorderThickness="0,0,0,1">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="☐" Foreground="#6A7D90" FontSize="16" Margin="0,0,10,0" VerticalAlignment="Center"/>
                                    <TextBlock Text="{loc:Loc StandardsDoorWindowCategories}" Foreground="White" FontSize="13" FontWeight="Bold" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Border>
                            <Grid Margin="20">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="16"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="16"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="{loc:Loc StandardsPrefixRule}" Foreground="#94A3B8" FontSize="10" FontWeight="Bold" Margin="0,0,0,8"/>
                                    <TextBox Text="DR_" Background="#0F172A" Foreground="White" FontSize="13" Padding="12,8"
                                             BorderBrush="#1E293B" BorderThickness="1">
                                        <TextBox.Resources>
                                            <Style TargetType="Border"><Setter Property="CornerRadius" Value="8"/></Style>
                                        </TextBox.Resources>
                                    </TextBox>
                                </StackPanel>
                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="{loc:Loc StandardsSuffixRule}" Foreground="#94A3B8" FontSize="10" FontWeight="Bold" Margin="0,0,0,8"/>
                                    <TextBox Text="(Size)" Background="#0F172A" Foreground="White" FontSize="13" Padding="12,8"
                                             BorderBrush="#1E293B" BorderThickness="1">
                                        <TextBox.Resources>
                                            <Style TargetType="Border"><Setter Property="CornerRadius" Value="8"/></Style>
                                        </TextBox.Resources>
                                    </TextBox>
                                </StackPanel>
                                <StackPanel Grid.Column="4">
                                    <TextBlock Text="{loc:Loc StandardsRegexPattern}" Foreground="#94A3B8" FontSize="10" FontWeight="Bold" Margin="0,0,0,8"/>
                                    <TextBox Text="DR-[0-9]{2}-.*" Background="#0F172A" Foreground="White" FontSize="13" FontFamily="Consolas" Padding="12,8"
                                             BorderBrush="#1E293B" BorderThickness="1">
                                        <TextBox.Resources>
                                            <Style TargetType="Border"><Setter Property="CornerRadius" Value="8"/></Style>
                                        </TextBox.Resources>
                                    </TextBox>
                                </StackPanel>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <!-- LOD Requirements Matrix -->
                    <StackPanel Grid.Row="3" Margin="0,0,0,30">
                        <Grid Margin="0,0,0,16">
                            <TextBlock Text="{loc:Loc StandardsLODMatrix}" FontSize="20" FontWeight="Bold" Foreground="White" HorizontalAlignment="Left"/>
                            <TextBlock Text="{loc:Loc StandardsAddCategory}" FontSize="11" FontWeight="Bold" Foreground="#6A7D90" HorizontalAlignment="Right"
                                       VerticalAlignment="Center" Cursor="Hand" MouseLeftButtonUp="AddCategory_Click"/>
                        </Grid>

                        <Border Background="#232629" BorderBrush="#1E293B" BorderThickness="1" CornerRadius="12">
                            <StackPanel>
                                <!-- Table Header -->
                                <Border Background="#0F172A" CornerRadius="12,12,0,0" Padding="20,14" BorderBrush="#1E293B" BorderThickness="0,0,0,1">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="2*"/>
                                            <ColumnDefinition Width="2*"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="60"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="{loc:Loc StandardsColumnCategory}" Foreground="#94A3B8" FontSize="10" FontWeight="Bold"/>
                                        <TextBlock Grid.Column="1" Text="{loc:Loc StandardsColumnPhase}" Foreground="#94A3B8" FontSize="10" FontWeight="Bold"/>
                                        <TextBlock Grid.Column="2" Text="LOD" Foreground="#94A3B8" FontSize="10" FontWeight="Bold" HorizontalAlignment="Center"/>
                                        <TextBlock Grid.Column="3" Text="{loc:Loc StandardsColumnAction}" Foreground="#94A3B8" FontSize="10" FontWeight="Bold" HorizontalAlignment="Center"/>
                                    </Grid>
                                </Border>

                                <!-- Row 1 -->
                                <Border Padding="20,14" BorderBrush="#1E293B" BorderThickness="0,0,0,1">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="2*"/>
                                            <ColumnDefinition Width="2*"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="60"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="Paredes - Externas" Foreground="White" FontSize="13" FontWeight="Medium" VerticalAlignment="Center"/>
                                        <TextBlock Grid.Column="1" Text="Documentação de Construção" Foreground="#94A3B8" FontSize="13" VerticalAlignment="Center"/>
                                        <Border Grid.Column="2" Background="#0F172A" CornerRadius="6" Padding="10,4" HorizontalAlignment="Center">
                                            <TextBlock Text="LOD 300" Foreground="White" FontSize="11" FontWeight="Bold"/>
                                        </Border>
                                        <TextBlock Grid.Column="3" Text="✕" Foreground="#64748B" FontSize="16" HorizontalAlignment="Center" VerticalAlignment="Center" Cursor="Hand"/>
                                    </Grid>
                                </Border>

                                <!-- Row 2 -->
                                <Border Padding="20,14" BorderBrush="#1E293B" BorderThickness="0,0,0,1">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="2*"/>
                                            <ColumnDefinition Width="2*"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="60"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="Colunas Estruturais" Foreground="White" FontSize="13" FontWeight="Medium" VerticalAlignment="Center"/>
                                        <TextBlock Grid.Column="1" Text="Desenvolvimento de Projeto" Foreground="#94A3B8" FontSize="13" VerticalAlignment="Center"/>
                                        <Border Grid.Column="2" Background="#0F172A" CornerRadius="6" Padding="10,4" HorizontalAlignment="Center">
                                            <TextBlock Text="LOD 350" Foreground="White" FontSize="11" FontWeight="Bold"/>
                                        </Border>
                                        <TextBlock Grid.Column="3" Text="✕" Foreground="#64748B" FontSize="16" HorizontalAlignment="Center" VerticalAlignment="Center" Cursor="Hand"/>
                                    </Grid>
                                </Border>

                                <!-- Row 3 -->
                                <Border Padding="20,14" BorderBrush="#1E293B" BorderThickness="0,0,0,1">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="2*"/>
                                            <ColumnDefinition Width="2*"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="60"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="Equipamentos Mecânicos" Foreground="White" FontSize="13" FontWeight="Medium" VerticalAlignment="Center"/>
                                        <TextBlock Grid.Column="1" Text="As-Built" Foreground="#94A3B8" FontSize="13" VerticalAlignment="Center"/>
                                        <Border Grid.Column="2" Background="#0F172A" CornerRadius="6" Padding="10,4" HorizontalAlignment="Center">
                                            <TextBlock Text="LOD 400" Foreground="White" FontSize="11" FontWeight="Bold"/>
                                        </Border>
                                        <TextBlock Grid.Column="3" Text="✕" Foreground="#64748B" FontSize="16" HorizontalAlignment="Center" VerticalAlignment="Center" Cursor="Hand"/>
                                    </Grid>
                                </Border>

                                <!-- Row 4 -->
                                <Border Padding="20,14">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="2*"/>
                                            <ColumnDefinition Width="2*"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="60"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="Mobiliário" Foreground="White" FontSize="13" FontWeight="Medium" VerticalAlignment="Center"/>
                                        <TextBlock Grid.Column="1" Text="Planejamento Espacial" Foreground="#94A3B8" FontSize="13" VerticalAlignment="Center"/>
                                        <Border Grid.Column="2" Background="#0F172A" CornerRadius="6" Padding="10,4" HorizontalAlignment="Center">
                                            <TextBlock Text="LOD 200" Foreground="White" FontSize="11" FontWeight="Bold"/>
                                        </Border>
                                        <TextBlock Grid.Column="3" Text="✕" Foreground="#64748B" FontSize="16" HorizontalAlignment="Center" VerticalAlignment="Center" Cursor="Hand"/>
                                    </Grid>
                                </Border>
                            </StackPanel>
                        </Border>
                    </StackPanel>

                    <!-- Info Cards -->
                    <Grid Grid.Row="4" Margin="0,0,0,20">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="20"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- Audit Mode Card -->
                        <Border Grid.Column="0" Background="#232629" BorderBrush="#1E293B" BorderThickness="1" CornerRadius="12" Padding="20">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Border Grid.Column="0" Width="44" Height="44" Background="#422006" CornerRadius="8" Margin="0,0,16,0">
                                    <TextBlock Text="⚠" Foreground="#F59E0B" FontSize="20" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                    <TextBlock Text="{loc:Loc StandardsAuditMode}" Foreground="White" FontSize="13" FontWeight="Bold" Margin="0,0,0,4"/>
                                    <TextBlock Text="{loc:Loc StandardsAuditModeDesc}"
                                               Foreground="#94A3B8" FontSize="11" TextWrapping="Wrap" LineHeight="18"/>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <!-- Standard Enforcement Card -->
                        <Border Grid.Column="2" Background="#232629" BorderBrush="#1E293B" BorderThickness="1" CornerRadius="12" Padding="20">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Border Grid.Column="0" Width="44" Height="44" Background="#052e16" CornerRadius="8" Margin="0,0,16,0">
                                    <TextBlock Text="✓" Foreground="#10B981" FontSize="20" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                    <TextBlock Text="{loc:Loc StandardsEnforcement}" Foreground="White" FontSize="13" FontWeight="Bold" Margin="0,0,0,4"/>
                                    <TextBlock Text="{loc:Loc StandardsEnforcementDesc}"
                                               Foreground="#94A3B8" FontSize="11" TextWrapping="Wrap" LineHeight="18"/>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </Grid>
                </Grid>
            </ScrollViewer>
            </Grid>
        </Grid>
    </Border>
</Window>
