<Window x:Class="BIMConcierge.UI.Views.CorrectionWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:conv="clr-namespace:BIMConcierge.UI.Converters"
        mc:Ignorable="d"
        Title="BIMConcierge - Correção em Tempo Real" Height="768" Width="1280"
        WindowStartupLocation="CenterScreen" WindowStyle="None"
        AllowsTransparency="True" Background="Transparent" FontFamily="Segoe UI">

    <Window.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVisibility"/>
        <conv:NullToVisibilityConverter x:Key="StringToVisibility"/>
        <conv:SeverityToBrushConverter x:Key="SeverityToBrush"/>
    </Window.Resources>

    <Border CornerRadius="16" Background="#17191B" BorderBrush="#1E293B" BorderThickness="1" MouseLeftButtonDown="Border_MouseLeftButtonDown">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="280" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- == Sidebar ===================================================== -->
            <Border Grid.Column="0" Background="#0F172A" CornerRadius="16,0,0,16" BorderBrush="#1E293B" BorderThickness="0,0,1,0" Padding="24">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Margin="0,0,0,40" Orientation="Horizontal" VerticalAlignment="Center">
                        <Border Width="32" Height="32" Background="#1E293B" CornerRadius="8" Margin="0,0,12,0">
                            <TextBlock Text="BIM" Foreground="#6A7D90" FontWeight="Black" FontSize="12" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock Text="BIM CONCIERGE" FontSize="15" FontWeight="Bold" Foreground="#6A7D90" VerticalAlignment="Center"/>
                    </StackPanel>

                    <StackPanel Grid.Row="1">
                        <Border Background="Transparent" CornerRadius="8" Padding="12,10" Margin="0,0,0,5" Cursor="Hand"
                                MouseLeftButtonUp="SidebarDashboard_Click">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#x229E;" Foreground="#94A3B8" FontSize="18" Margin="0,0,12,0" VerticalAlignment="Center"/>
                                <TextBlock Text="Painel Principal" Foreground="#94A3B8" FontWeight="Medium" FontSize="14" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>

                        <Border Background="Transparent" CornerRadius="8" Padding="12,10" Margin="0,0,0,5" Cursor="Hand"
                                MouseLeftButtonUp="SidebarTutorials_Click">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#x25B6;" Foreground="#94A3B8" FontSize="16" Margin="0,0,12,0" VerticalAlignment="Center"/>
                                <TextBlock Text="Tutoriais" Foreground="#94A3B8" FontWeight="Medium" FontSize="14" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>

                        <!-- Active item: Correções -->
                        <Border Background="#1E293B" CornerRadius="8" Padding="12,10" Margin="0,0,0,5" Cursor="Hand">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="&#x26A0;" Foreground="#6A7D90" FontSize="16" Margin="0,0,12,0" VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="1" Text="Corre&#231;&#245;es" Foreground="White" FontWeight="SemiBold" FontSize="14" VerticalAlignment="Center"/>
                                <Border Grid.Column="2" Background="#6A7D90" CornerRadius="10" Padding="7,2" MinWidth="22">
                                    <TextBlock Text="{Binding ActiveCount}" Foreground="White" FontSize="10" FontWeight="Bold" HorizontalAlignment="Center"/>
                                </Border>
                            </Grid>
                        </Border>

                        <Border Background="Transparent" CornerRadius="8" Padding="12,10" Margin="0,0,0,5" Cursor="Hand"
                                MouseLeftButtonUp="SidebarStandards_Click">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#x2605;" Foreground="#94A3B8" FontSize="18" Margin="0,0,12,0" VerticalAlignment="Center"/>
                                <TextBlock Text="Padr&#245;es da Empresa" Foreground="#94A3B8" FontWeight="Medium" FontSize="14" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>

                        <Border Background="Transparent" CornerRadius="8" Padding="12,10" Margin="0,0,0,5" Cursor="Hand"
                                MouseLeftButtonUp="SidebarProgress_Click">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#x1F4CA;" Foreground="#94A3B8" FontSize="18" Margin="0,0,12,0" VerticalAlignment="Center"/>
                                <TextBlock Text="Progresso do Aluno" Foreground="#94A3B8" FontWeight="Medium" FontSize="14" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>

                        <Border Background="Transparent" CornerRadius="8" Padding="12,10" Margin="0,0,0,5" Cursor="Hand"
                                MouseLeftButtonUp="SidebarAchievements_Click">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#x1F3C6;" Foreground="#94A3B8" FontSize="18" Margin="0,0,12,0" VerticalAlignment="Center"/>
                                <TextBlock Text="Conquistas" Foreground="#94A3B8" FontWeight="Medium" FontSize="14" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>

                    <!-- System status card -->
                    <Border Grid.Row="2" Background="#121820" BorderBrush="#1E293B" BorderThickness="1" CornerRadius="12" Padding="15">
                        <StackPanel>
                            <Grid Margin="0,0,0,6">
                                <TextBlock Text="STATUS DO SISTEMA" Foreground="#6A7D90" FontSize="10" FontWeight="Bold" HorizontalAlignment="Left" VerticalAlignment="Center"/>
                                <Ellipse Width="8" Height="8" Fill="#22C55E" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                            </Grid>
                            <TextBlock Foreground="#94A3B8" FontSize="11" TextWrapping="Wrap">
                                <Run Text="Monitoramento em tempo real ativo."/>
                            </TextBlock>
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>

            <!-- == Main Content ================================================ -->
            <Grid Grid.Column="1" Margin="40">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Close button -->
                <Button Grid.Row="0" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,-20,-20,0"
                        Content="&#x2715;" FontSize="16" Foreground="#94A3B8" Background="Transparent" BorderThickness="0"
                        Cursor="Hand" Click="BtnClose_Click"/>

                <!-- Header -->
                <StackPanel Grid.Row="0" Margin="0,0,0,25">
                    <TextBlock Text="Corre&#231;&#227;o em Tempo Real" FontSize="28" FontWeight="Bold" Foreground="White" Margin="0,0,0,8"/>
                    <TextBlock Text="Monitore e corrija viola&#231;&#245;es de padr&#245;es BIM detectadas automaticamente no modelo." FontSize="15" Foreground="#94A3B8"/>
                </StackPanel>

                <!-- Auto-fix toggle + severity filters -->
                <Grid Grid.Row="1" Margin="0,0,0,25">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Auto-fix toggle -->
                    <Border Grid.Column="0" Background="#121820" BorderBrush="#1E293B" BorderThickness="1" CornerRadius="10" Padding="15,10">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#x26A1;" FontSize="16" Margin="0,0,10,0" VerticalAlignment="Center"/>
                            <StackPanel VerticalAlignment="Center" Margin="0,0,15,0">
                                <TextBlock Text="Corre&#231;&#245;es Autom&#225;ticas" Foreground="White" FontSize="13" FontWeight="SemiBold"/>
                                <TextBlock Text="Corrigir viola&#231;&#245;es triviais automaticamente" Foreground="#94A3B8" FontSize="11"/>
                            </StackPanel>
                            <CheckBox IsChecked="{Binding IsAutoFixEnabled}" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>

                    <!-- Severity filter buttons -->
                    <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                        <Button Content="Todos" Height="36" Padding="18,0" Margin="0,0,8,0"
                                FontSize="12" FontWeight="SemiBold" BorderThickness="0" Cursor="Hand"
                                Command="{Binding SetFilterCommand}" CommandParameter="Todos">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Background" Value="#1E293B"/>
                                    <Setter Property="Foreground" Value="#94A3B8"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="Button">
                                                <Border Background="{TemplateBinding Background}" CornerRadius="18" Padding="{TemplateBinding Padding}">
                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding SelectedSeverity}" Value="Todos">
                                            <Setter Property="Background" Value="#6A7D90"/>
                                            <Setter Property="Foreground" Value="White"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>

                        <Button Height="36" Padding="18,0" Margin="0,0,8,0"
                                FontSize="12" FontWeight="SemiBold" BorderThickness="0" Cursor="Hand"
                                Command="{Binding SetFilterCommand}" CommandParameter="Error">
                            <Button.Content>
                                <TextBlock><Run Text="&#x1F6D1; "/><Run Text="Erro"/></TextBlock>
                            </Button.Content>
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Background" Value="#1E293B"/>
                                    <Setter Property="Foreground" Value="#94A3B8"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="Button">
                                                <Border Background="{TemplateBinding Background}" CornerRadius="18" Padding="{TemplateBinding Padding}">
                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding SelectedSeverity}" Value="Error">
                                            <Setter Property="Background" Value="#EF4444"/>
                                            <Setter Property="Foreground" Value="White"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>

                        <Button Height="36" Padding="18,0" Margin="0,0,8,0"
                                FontSize="12" FontWeight="SemiBold" BorderThickness="0" Cursor="Hand"
                                Command="{Binding SetFilterCommand}" CommandParameter="Warning">
                            <Button.Content>
                                <TextBlock><Run Text="&#x26A0;&#xFE0F; "/><Run Text="Aviso"/></TextBlock>
                            </Button.Content>
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Background" Value="#1E293B"/>
                                    <Setter Property="Foreground" Value="#94A3B8"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="Button">
                                                <Border Background="{TemplateBinding Background}" CornerRadius="18" Padding="{TemplateBinding Padding}">
                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding SelectedSeverity}" Value="Warning">
                                            <Setter Property="Background" Value="#F59E0B"/>
                                            <Setter Property="Foreground" Value="White"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>

                        <Button Height="36" Padding="18,0"
                                FontSize="12" FontWeight="SemiBold" BorderThickness="0" Cursor="Hand"
                                Command="{Binding SetFilterCommand}" CommandParameter="Info">
                            <Button.Content>
                                <TextBlock><Run Text="&#x2139;&#xFE0F; "/><Run Text="Info"/></TextBlock>
                            </Button.Content>
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Background" Value="#1E293B"/>
                                    <Setter Property="Foreground" Value="#94A3B8"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="Button">
                                                <Border Background="{TemplateBinding Background}" CornerRadius="18" Padding="{TemplateBinding Padding}">
                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding SelectedSeverity}" Value="Info">
                                            <Setter Property="Background" Value="#6A7D90"/>
                                            <Setter Property="Foreground" Value="White"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                    </StackPanel>
                </Grid>

                <!-- Summary bar -->
                <Border Grid.Row="2" Background="#121820" BorderBrush="#1E293B" BorderThickness="1" CornerRadius="8" Padding="20,12" Margin="0,0,0,20">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Foreground="#94A3B8" FontSize="13" VerticalAlignment="Center" Margin="0,0,20,0">
                            <Run Text="Ativas: "/><Run Text="{Binding ActiveCount, Mode=OneWay}" Foreground="#EF4444" FontWeight="Bold"/>
                        </TextBlock>
                        <TextBlock Foreground="#94A3B8" FontSize="13" VerticalAlignment="Center">
                            <Run Text="Corrigidas: "/><Run Text="{Binding FixedCount, Mode=OneWay}" Foreground="#22C55E" FontWeight="Bold"/>
                        </TextBlock>
                    </StackPanel>
                </Border>

                <!-- Loading Indicator -->
                <TextBlock Grid.Row="3" Text="Carregando corre&#231;&#245;es..." FontSize="16" Foreground="#94A3B8"
                           HorizontalAlignment="Center" VerticalAlignment="Center"
                           Visibility="{Binding IsBusy, Converter={StaticResource BoolToVisibility}}"/>

                <!-- Error Message -->
                <TextBlock Grid.Row="3" Text="{Binding ErrorMessage}" FontSize="14" Foreground="#EF4444"
                           HorizontalAlignment="Center" VerticalAlignment="Top" Margin="0,10,0,0"
                           Visibility="{Binding ErrorMessage, Converter={StaticResource StringToVisibility}}"/>

                <!-- Correction Cards List -->
                <ScrollViewer Grid.Row="3" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                    <ItemsControl ItemsSource="{Binding Corrections}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="#121820" CornerRadius="12" Margin="0,0,0,12"
                                        BorderBrush="{Binding Severity, Converter={StaticResource SeverityToBrush}}"
                                        BorderThickness="4,0,0,0" Padding="20">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <!-- Severity icon -->
                                        <Border Grid.Column="0" Width="40" Height="40" CornerRadius="20" Margin="0,0,15,0" VerticalAlignment="Top">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="Background" Value="#1E293B"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Severity}" Value="Error">
                                                            <Setter Property="Background" Value="#3B1111"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Severity}" Value="Warning">
                                                            <Setter Property="Background" Value="#3B2E11"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <TextBlock HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="16">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Text" Value="&#x2139;&#xFE0F;"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding Severity}" Value="Error">
                                                                <Setter Property="Text" Value="&#x1F6D1;"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding Severity}" Value="Warning">
                                                                <Setter Property="Text" Value="&#x26A0;&#xFE0F;"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </Border>

                                        <!-- Content -->
                                        <StackPanel Grid.Column="1" VerticalAlignment="Top">
                                            <Grid Margin="0,0,0,4">
                                                <TextBlock Text="{Binding Title}" FontSize="14" FontWeight="Bold" Foreground="White" HorizontalAlignment="Left"/>
                                                <TextBlock Text="{Binding OccurredAt, StringFormat='{}{0:HH:mm}'}" FontSize="10" Foreground="#64748B" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                                            </Grid>

                                            <TextBlock Text="{Binding Description}" Foreground="#94A3B8" FontSize="13" TextWrapping="Wrap" LineHeight="18" Margin="0,0,0,10"/>

                                            <!-- Element ID -->
                                            <TextBlock Foreground="#64748B" FontSize="11" Margin="0,0,0,10">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding ElementId}" Value="{x:Null}">
                                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                                <Run Text="Elemento: "/><Run Text="{Binding ElementId, Mode=OneWay}" FontFamily="Consolas" Foreground="#6A7D90"/>
                                            </TextBlock>

                                            <!-- Rule info box -->
                                            <Border Background="#0F172A" CornerRadius="6" Padding="12,8" Margin="0,0,0,12"
                                                    BorderBrush="#1E293B" BorderThickness="1">
                                                <StackPanel>
                                                    <TextBlock Text="REGRA VIOLADA" Foreground="#64748B" FontSize="9" FontWeight="Bold" Margin="0,0,0,4"/>
                                                    <TextBlock Text="{Binding Title}" Foreground="#6A7D90" FontSize="12" FontWeight="SemiBold"/>
                                                </StackPanel>
                                            </Border>
                                        </StackPanel>

                                        <!-- Action buttons -->
                                        <StackPanel Grid.Column="2" VerticalAlignment="Center" Margin="15,0,0,0">
                                            <Button Content="Ignorar" Height="32" Padding="15,0" Margin="0,0,0,8"
                                                    Background="#1E293B" Foreground="#94A3B8" FontSize="12" FontWeight="Bold" BorderThickness="0" Cursor="Hand"
                                                    Command="{Binding DataContext.DismissCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                    CommandParameter="{Binding}">
                                                <Button.Resources>
                                                    <Style TargetType="Border">
                                                        <Setter Property="CornerRadius" Value="6"/>
                                                    </Style>
                                                </Button.Resources>
                                            </Button>

                                            <Button Height="32" Padding="15,0"
                                                    FontSize="12" FontWeight="Bold" BorderThickness="0" Cursor="Hand"
                                                    IsEnabled="{Binding CanAutoFix}"
                                                    Command="{Binding DataContext.AutoFixCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                    CommandParameter="{Binding}">
                                                <Button.Content>
                                                    <TextBlock>
                                                        <Run Text="&#x26A1; "/><Run Text="Auto-Fix"/>
                                                    </TextBlock>
                                                </Button.Content>
                                                <Button.Style>
                                                    <Style TargetType="Button">
                                                        <Setter Property="Background" Value="#6A7D90"/>
                                                        <Setter Property="Foreground" Value="White"/>
                                                        <Style.Triggers>
                                                            <Trigger Property="IsEnabled" Value="False">
                                                                <Setter Property="Background" Value="#1E293B"/>
                                                                <Setter Property="Foreground" Value="#64748B"/>
                                                            </Trigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Button.Style>
                                                <Button.Resources>
                                                    <Style TargetType="Border">
                                                        <Setter Property="CornerRadius" Value="6"/>
                                                    </Style>
                                                </Button.Resources>
                                            </Button>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>

                <!-- Empty state -->
                <StackPanel Grid.Row="3" HorizontalAlignment="Center" VerticalAlignment="Center"
                            Visibility="{Binding IsBusy, Converter={StaticResource BoolToVisibility}, ConverterParameter=Inverse}">
                    <StackPanel.Style>
                        <Style TargetType="StackPanel">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding Corrections.Count}" Value="0">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </StackPanel.Style>
                    <TextBlock Text="&#x2705;" FontSize="48" HorizontalAlignment="Center" Margin="0,0,0,15"/>
                    <TextBlock Text="Nenhuma viola&#231;&#227;o encontrada" FontSize="18" FontWeight="SemiBold" Foreground="#94A3B8" HorizontalAlignment="Center" Margin="0,0,0,5"/>
                    <TextBlock Text="O modelo est&#225; em conformidade com os padr&#245;es da empresa." FontSize="13" Foreground="#64748B" HorizontalAlignment="Center"/>
                </StackPanel>
            </Grid>
        </Grid>
    </Border>
</Window>
