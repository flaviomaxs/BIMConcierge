<Window x:Class="BIMConcierge.UI.Views.StudentProgressWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:vm="clr-namespace:BIMConcierge.UI.ViewModels"
        xmlns:conv="clr-namespace:BIMConcierge.UI.Converters"
        xmlns:loc="clr-namespace:BIMConcierge.UI.Localization"
        mc:Ignorable="d"
        Title="{loc:Loc ProgressTitle}" Height="768" Width="1280"
        WindowStartupLocation="CenterScreen" WindowStyle="None"
        AllowsTransparency="True" Background="Transparent" FontFamily="Segoe UI">

    <Window.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVis"/>
        <conv:NullToVisibilityConverter x:Key="NullToVis"/>
        <conv:PercentToWidthConverter x:Key="PctToWidth"/>
    </Window.Resources>

    <Border CornerRadius="16" Background="#17191B" BorderBrush="#1E293B" BorderThickness="1" MouseLeftButtonDown="Border_MouseLeftButtonDown">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="260"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Sidebar -->
            <Border Grid.Column="0" Background="#0F172A" CornerRadius="16,0,0,16" BorderBrush="#1E293B" BorderThickness="0,0,1,0" Padding="20">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Profile Summary -->
                    <StackPanel Grid.Row="0" Margin="0,0,0,30">
                        <Grid Margin="0,0,0,20">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0" Width="40" Height="40" Background="#6A7D90" CornerRadius="20" Margin="0,0,12,0">
                                <TextBlock Text="FF" Foreground="White" FontWeight="Bold" FontSize="14" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                <TextBlock Text="{Binding UserName, FallbackValue='Flávio Filho'}" Foreground="White" FontWeight="SemiBold" FontSize="13"/>
                                <TextBlock Text="{Binding UserRole, FallbackValue='Arquiteto'}" Foreground="#6A7D90" FontSize="11"/>
                            </StackPanel>
                        </Grid>

                        <!-- Navigation -->
                        <Border Background="Transparent" CornerRadius="8" Padding="12,10" Margin="0,0,0,4" Cursor="Hand"
                                MouseLeftButtonUp="SidebarDashboard_Click">
                            <StackPanel Orientation="Horizontal">
                                <Path Data="M2,2 H7 V7 H2Z M9,2 H14 V7 H9Z M2,9 H7 V14 H2Z M9,9 H14 V14 H9Z"
                                      Fill="#94A3B8" Width="16" Height="16" Stretch="Uniform" Margin="0,0,12,0" VerticalAlignment="Center"/>
                                <TextBlock Text="{loc:Loc NavDashboard}" Foreground="#94A3B8" FontWeight="Medium" FontSize="13" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                        <Border Background="Transparent" CornerRadius="8" Padding="12,10" Margin="0,0,0,4" Cursor="Hand"
                                MouseLeftButtonUp="SidebarTutorials_Click">
                            <StackPanel Orientation="Horizontal">
                                <Path Data="M2,3 H10 V5 H2Z M2,7 H14 V9 H2Z M2,11 H12 V13 H2Z"
                                      Fill="#94A3B8" Width="16" Height="16" Stretch="Uniform" Margin="0,0,12,0" VerticalAlignment="Center"/>
                                <TextBlock Text="{loc:Loc NavTutorials}" Foreground="#94A3B8" FontWeight="Medium" FontSize="13" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                        <Border Background="Transparent" CornerRadius="8" Padding="12,10" Margin="0,0,0,4" Cursor="Hand"
                                MouseLeftButtonUp="SidebarStandards_Click">
                            <StackPanel Orientation="Horizontal">
                                <Path Data="M8,1 L14,3.5 V8 C14,11.5 8,15 8,15 C8,15 2,11.5 2,8 V3.5Z"
                                      Fill="#94A3B8" Width="16" Height="16" Stretch="Uniform" Margin="0,0,12,0" VerticalAlignment="Center"/>
                                <TextBlock Text="{loc:Loc NavStandards}" Foreground="#94A3B8" FontWeight="Medium" FontSize="13" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                        <Border Background="#1E293B" CornerRadius="8" Padding="12,10" Margin="0,0,0,4" Cursor="Hand">
                            <StackPanel Orientation="Horizontal">
                                <Path Data="M2,14 V9 H5 V14Z M6.5,14 V6 H9.5 V14Z M11,14 V2 H14 V14Z"
                                      Fill="White" Width="16" Height="16" Stretch="Uniform" Margin="0,0,12,0" VerticalAlignment="Center"/>
                                <TextBlock Text="{loc:Loc NavProgress}" Foreground="White" FontWeight="SemiBold" FontSize="13" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                        <Border Background="Transparent" CornerRadius="8" Padding="12,10" Margin="0,0,0,4" Cursor="Hand"
                                MouseLeftButtonUp="SidebarAchievements_Click">
                            <StackPanel Orientation="Horizontal">
                                <Path Data="M5,1 H11 L12,5 L8,8 L4,5Z M6,9 H10 V11 H6Z M4,11.5 H12 V13 H4Z"
                                      Fill="#94A3B8" Width="16" Height="16" Stretch="Uniform" Margin="0,0,12,0" VerticalAlignment="Center"/>
                                <TextBlock Text="{loc:Loc NavAchievements}" Foreground="#94A3B8" FontWeight="Medium" FontSize="13" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>

                    <!-- Next Milestone -->
                    <StackPanel Grid.Row="2">
                        <Border Background="#17191B" BorderBrush="#1E293B" BorderThickness="1" CornerRadius="12" Padding="16" Margin="0,0,0,12">
                            <StackPanel>
                                <TextBlock Text="{loc:Loc ProgressNextMilestone}" Foreground="#6A7D90" FontSize="10" FontWeight="Bold" Margin="0,0,0,8"/>
                                <TextBlock Text="Coordenador BIM I" Foreground="White" FontSize="13" FontWeight="Bold" Margin="0,0,0,8"/>
                                <Grid Margin="0,0,0,4">
                                    <Border Height="6" Background="#1E293B" CornerRadius="3">
                                        <Border Background="#6A7D90" CornerRadius="3" HorizontalAlignment="Left"
                                                Width="{Binding NextLevelPercent, Converter={StaticResource PctToWidth}, ConverterParameter=180}"/>
                                    </Border>
                                </Grid>
                                <TextBlock Foreground="#94A3B8" FontSize="10" HorizontalAlignment="Right">
                                    <TextBlock.Text>
                                        <Binding Path="NextLevelPercent" StringFormat="{}{0:F0}% Completo" FallbackValue="0% Completo"/>
                                    </TextBlock.Text>
                                </TextBlock>
                            </StackPanel>
                        </Border>

                        <Button Content="{loc:Loc ProgressResumeLearning}" Height="40" Background="#6A7D90" Foreground="White"
                                FontSize="13" FontWeight="Bold" BorderThickness="0" Cursor="Hand"
                                Click="BtnResumeLearning_Click">
                            <Button.Resources>
                                <Style TargetType="Border"><Setter Property="CornerRadius" Value="8"/></Style>
                            </Button.Resources>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Main Content -->
            <Grid Grid.Column="1">
                <!-- Error Banner -->
                <Border Background="#7F1D1D" CornerRadius="8" Padding="12,8" Margin="40,12,40,0"
                        VerticalAlignment="Top" Panel.ZIndex="5"
                        Visibility="{Binding ErrorMessage, Converter={StaticResource NullToVis}}">
                    <TextBlock Text="{Binding ErrorMessage}" Foreground="#FCA5A5" FontSize="12" FontWeight="Medium" TextWrapping="Wrap"/>
                </Border>

                <!-- Loading Overlay -->
                <Border Background="#17191BCC" CornerRadius="0,16,16,0" Panel.ZIndex="10"
                        Visibility="{Binding IsBusy, Converter={StaticResource BoolToVis}}">
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                        <Border Width="48" Height="48" Background="#1E293B" CornerRadius="24" Margin="0,0,0,12">
                            <TextBlock Text="⟳" Foreground="#6A7D90" FontSize="24" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock Text="{loc:Loc Loading}" Foreground="#94A3B8" FontSize="14" FontWeight="Medium" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>

            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <Grid Margin="40">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Close Button -->
                    <Button Grid.Row="0" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,-20,-20,0"
                            Content="✕" FontSize="16" Foreground="#94A3B8" Background="Transparent" BorderThickness="0"
                            Cursor="Hand" Click="BtnClose_Click"/>

                    <!-- Header -->
                    <StackPanel Grid.Row="0" Margin="0,0,0,20">
                        <TextBlock Text="{loc:Loc ProgressStudentPanel}" FontSize="28" FontWeight="Bold" Foreground="White" Margin="0,0,0,6"/>
                        <TextBlock Text="{loc:Loc ProgressWelcomeBack}" FontSize="14" Foreground="#94A3B8"/>
                    </StackPanel>

                    <!-- Quick Stats Cards -->
                    <Grid Grid.Row="1" Margin="0,0,0,24">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="16"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="16"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="16"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0" Background="#232629" BorderBrush="#323639" BorderThickness="1" CornerRadius="12" Padding="20">
                            <StackPanel>
                                <Path Data="M3,8 L6.5,11.5 L13,4" Stroke="#6A7D90" StrokeThickness="2.5" StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round"
                                      Width="16" Height="16" Stretch="Uniform" Margin="0,0,0,12"/>
                                <TextBlock Text="{loc:Loc ProgressCompleted}" Foreground="#94A3B8" FontSize="10" FontWeight="Bold" Margin="0,0,0,6"/>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="{Binding CompletedCount, FallbackValue='24'}" FontSize="28" FontWeight="Bold" Foreground="White"/>
                                    <TextBlock Text=" / 50" FontSize="13" Foreground="#94A3B8" VerticalAlignment="Bottom" Margin="0,0,0,4"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <Border Grid.Column="2" Background="#232629" BorderBrush="#323639" BorderThickness="1" CornerRadius="12" Padding="20">
                            <StackPanel>
                                <Path Data="M9,1 L4,9 H8 L7,15 L12,7 H8Z" Fill="#6A7D90"
                                      Width="16" Height="16" Stretch="Uniform" Margin="0,0,0,12"/>
                                <TextBlock Text="{loc:Loc ProgressXpPoints}" Foreground="#94A3B8" FontSize="10" FontWeight="Bold" Margin="0,0,0,6"/>
                                <TextBlock Text="{Binding XpPoints, FallbackValue='12.450', StringFormat=N0}" FontSize="28" FontWeight="Bold" Foreground="White"/>
                            </StackPanel>
                        </Border>

                        <Border Grid.Column="4" Background="#232629" BorderBrush="#323639" BorderThickness="1" CornerRadius="12" Padding="20">
                            <StackPanel>
                                <Path Data="M8,1 A7,7 0 1,0 8,15 A7,7 0 1,0 8,1Z M8,4 V8.5 L11,10.5" Stroke="#6A7D90" StrokeThickness="1.5" Fill="Transparent"
                                      Width="16" Height="16" Stretch="Uniform" Margin="0,0,0,12"/>
                                <TextBlock Text="{loc:Loc ProgressStudyHours}" Foreground="#94A3B8" FontSize="10" FontWeight="Bold" Margin="0,0,0,6"/>
                                <TextBlock Text="{Binding LearningHours, FallbackValue='86', StringFormat={}{0}h}" FontSize="28" FontWeight="Bold" Foreground="White"/>
                            </StackPanel>
                        </Border>

                        <Border Grid.Column="6" Background="#232629" BorderBrush="#323639" BorderThickness="1" CornerRadius="12" Padding="20">
                            <StackPanel>
                                <Path Data="M5,1 H11 L12,5 L8,8 L4,5Z M6,9 H10 V11 H6Z M4,11.5 H12 V13 H4Z" Fill="#6A7D90"
                                      Width="16" Height="16" Stretch="Uniform" Margin="0,0,0,12"/>
                                <TextBlock Text="{loc:Loc ProgressCertificates}" Foreground="#94A3B8" FontSize="10" FontWeight="Bold" Margin="0,0,0,6"/>
                                <TextBlock Text="{Binding CertificateCount, FallbackValue='3'}" FontSize="28" FontWeight="Bold" Foreground="White"/>
                            </StackPanel>
                        </Border>
                    </Grid>

                    <!-- Skills + In Progress Row -->
                    <Grid Grid.Row="2" Margin="0,0,0,24">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="2*"/>
                            <ColumnDefinition Width="20"/>
                            <ColumnDefinition Width="3*"/>
                        </Grid.ColumnDefinitions>

                        <!-- Skill Proficiency -->
                        <Border Grid.Column="0" Background="#232629" BorderBrush="#323639" BorderThickness="1" CornerRadius="12" Padding="24">
                            <StackPanel>
                                <Grid Margin="0,0,0,20">
                                    <TextBlock Text="{loc:Loc ProgressSkillProficiency}" FontSize="16" FontWeight="Bold" Foreground="White" HorizontalAlignment="Left"/>
                                    <TextBlock Text="+12% este mês" FontSize="11" FontWeight="Bold" Foreground="#10B981" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                                </Grid>

                                <!-- Modeling -->
                                <StackPanel Margin="0,0,0,18">
                                    <Grid Margin="0,0,0,6">
                                        <TextBlock Text="{loc:Loc ProgressModeling}" Foreground="#94A3B8" FontSize="10" FontWeight="Bold" HorizontalAlignment="Left"/>
                                        <TextBlock Text="80%" Foreground="#94A3B8" FontSize="10" FontWeight="Bold" HorizontalAlignment="Right"/>
                                    </Grid>
                                    <Border Height="8" Background="#1E293B" CornerRadius="4">
                                        <Border Width="240" Background="#6A7D90" CornerRadius="4" HorizontalAlignment="Left"/>
                                    </Border>
                                </StackPanel>

                                <!-- Documentation -->
                                <StackPanel Margin="0,0,0,18">
                                    <Grid Margin="0,0,0,6">
                                        <TextBlock Text="{loc:Loc ProgressDocumentation}" Foreground="#94A3B8" FontSize="10" FontWeight="Bold" HorizontalAlignment="Left"/>
                                        <TextBlock Text="40%" Foreground="#94A3B8" FontSize="10" FontWeight="Bold" HorizontalAlignment="Right"/>
                                    </Grid>
                                    <Border Height="8" Background="#1E293B" CornerRadius="4">
                                        <Border Width="120" Background="#6A7D90" CornerRadius="4" HorizontalAlignment="Left" Opacity="0.6"/>
                                    </Border>
                                </StackPanel>

                                <!-- Coordination -->
                                <StackPanel Margin="0,0,0,18">
                                    <Grid Margin="0,0,0,6">
                                        <TextBlock Text="{loc:Loc ProgressCoordination}" Foreground="#94A3B8" FontSize="10" FontWeight="Bold" HorizontalAlignment="Left"/>
                                        <TextBlock Text="80%" Foreground="#94A3B8" FontSize="10" FontWeight="Bold" HorizontalAlignment="Right"/>
                                    </Grid>
                                    <Border Height="8" Background="#1E293B" CornerRadius="4">
                                        <Border Width="240" Background="#6A7D90" CornerRadius="4" HorizontalAlignment="Left"/>
                                    </Border>
                                </StackPanel>

                                <!-- Family Creation -->
                                <StackPanel Margin="0,0,0,18">
                                    <Grid Margin="0,0,0,6">
                                        <TextBlock Text="{loc:Loc ProgressFamilyCreation}" Foreground="#94A3B8" FontSize="10" FontWeight="Bold" HorizontalAlignment="Left"/>
                                        <TextBlock Text="70%" Foreground="#94A3B8" FontSize="10" FontWeight="Bold" HorizontalAlignment="Right"/>
                                    </Grid>
                                    <Border Height="8" Background="#1E293B" CornerRadius="4">
                                        <Border Width="210" Background="#6A7D90" CornerRadius="4" HorizontalAlignment="Left" Opacity="0.8"/>
                                    </Border>
                                </StackPanel>

                                <!-- Data Management -->
                                <StackPanel>
                                    <Grid Margin="0,0,0,6">
                                        <TextBlock Text="{loc:Loc ProgressDataManagement}" Foreground="#94A3B8" FontSize="10" FontWeight="Bold" HorizontalAlignment="Left"/>
                                        <TextBlock Text="100%" Foreground="#94A3B8" FontSize="10" FontWeight="Bold" HorizontalAlignment="Right"/>
                                    </Grid>
                                    <Border Height="8" Background="#1E293B" CornerRadius="4">
                                        <Border Background="#6A7D90" CornerRadius="4" HorizontalAlignment="Stretch"/>
                                    </Border>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <!-- In Progress Tutorials -->
                        <StackPanel Grid.Column="2">
                            <Border Background="#232629" BorderBrush="#323639" BorderThickness="1" CornerRadius="12" Padding="24" Margin="0,0,0,20">
                                <StackPanel>
                                    <TextBlock Text="{loc:Loc ProgressInProgress}" FontSize="16" FontWeight="Bold" Foreground="White" Margin="0,0,0,16"/>

                                    <!-- Tutorial 1 -->
                                    <Border Background="#FFFFFF0A" BorderBrush="#FFFFFF0A" BorderThickness="1" CornerRadius="8" Padding="16" Margin="0,0,0,12">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <Border Grid.Column="0" Width="48" Height="48" Background="#323639" CornerRadius="8" Margin="0,0,16,0">
                                                <Path Data="M2,14 L2,2 L14,14Z M5,11 H11" Stroke="White" StrokeThickness="1.5" Fill="Transparent"
                                                      Width="20" Height="20" Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                <TextBlock Text="Famílias Paramétricas Avançadas" Foreground="White" FontSize="13" FontWeight="Bold" Margin="0,0,0,8"/>
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <Border Grid.Column="0" Height="6" Background="#323639" CornerRadius="3" Margin="0,0,12,0">
                                                        <Border Background="#6A7D90" CornerRadius="3" HorizontalAlignment="Left" Width="180"/>
                                                    </Border>
                                                    <TextBlock Grid.Column="1" Text="65%" Foreground="#94A3B8" FontSize="10" FontWeight="Bold"/>
                                                </Grid>
                                            </StackPanel>
                                            <Border Grid.Column="2" Width="32" Height="32" Background="#FFFFFF0A" CornerRadius="16" Margin="12,0,0,0" Cursor="Hand"
                                                    MouseLeftButtonUp="PlayTutorial_Click">
                                                <Path Data="M4,2 L13,8 L4,14Z" Fill="White" Width="12" Height="12" Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                        </Grid>
                                    </Border>

                                    <!-- Tutorial 2 -->
                                    <Border Background="#FFFFFF0A" BorderBrush="#FFFFFF0A" BorderThickness="1" CornerRadius="8" Padding="16">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <Border Grid.Column="0" Width="48" Height="48" Background="#323639" CornerRadius="8" Margin="0,0,16,0">
                                                <Path Data="M6,10 L10,6 M5,7 L3,9 A3,3 0 0,0 7,13 L9,11 M11,9 L13,7 A3,3 0 0,0 9,3 L7,5" Stroke="White" StrokeThickness="1.5" Fill="Transparent"
                                                      Width="20" Height="20" Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                <TextBlock Text="Fluxos de Coordenação Estrutural" Foreground="White" FontSize="13" FontWeight="Bold" Margin="0,0,0,8"/>
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <Border Grid.Column="0" Height="6" Background="#323639" CornerRadius="3" Margin="0,0,12,0">
                                                        <Border Background="#6A7D90" CornerRadius="3" HorizontalAlignment="Left" Width="42"/>
                                                    </Border>
                                                    <TextBlock Grid.Column="1" Text="15%" Foreground="#94A3B8" FontSize="10" FontWeight="Bold"/>
                                                </Grid>
                                            </StackPanel>
                                            <Border Grid.Column="2" Width="32" Height="32" Background="#FFFFFF0A" CornerRadius="16" Margin="12,0,0,0" Cursor="Hand"
                                                    MouseLeftButtonUp="PlayTutorial_Click">
                                                <Path Data="M4,2 L13,8 L4,14Z" Fill="White" Width="12" Height="12" Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                        </Grid>
                                    </Border>
                                </StackPanel>
                            </Border>

                            <!-- Next Recommended Lessons -->
                            <Border Background="#232629" BorderBrush="#323639" BorderThickness="1" CornerRadius="12" Padding="24">
                                <StackPanel>
                                    <TextBlock Text="{loc:Loc ProgressNextLessons}" FontSize="16" FontWeight="Bold" Foreground="White" Margin="0,0,0,16"/>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="16"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>

                                        <Border Grid.Column="0" Background="#17191B" BorderBrush="#323639" BorderThickness="1" CornerRadius="8" Padding="16" Cursor="Hand">
                                            <StackPanel>
                                                <Grid Margin="0,0,0,10">
                                                    <Border Background="#6A7D9033" CornerRadius="4" Padding="8,3" HorizontalAlignment="Left">
                                                        <TextBlock Text="Intermediário" Foreground="#6A7D90" FontSize="10" FontWeight="Bold"/>
                                                    </Border>
                                                    <TextBlock Text="15 min" Foreground="#94A3B8" FontSize="10" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                                                </Grid>
                                                <TextBlock Text="Fundamentos da API Revit para Modeladores" Foreground="White" FontSize="13" FontWeight="Bold" Margin="0,0,0,6"/>
                                                <TextBlock Text="Desbloqueie o potencial de automação no seu fluxo BIM." Foreground="#94A3B8" FontSize="11" TextWrapping="Wrap"/>
                                            </StackPanel>
                                        </Border>

                                        <Border Grid.Column="2" Background="#17191B" BorderBrush="#323639" BorderThickness="1" CornerRadius="8" Padding="16" Cursor="Hand">
                                            <StackPanel>
                                                <Grid Margin="0,0,0,10">
                                                    <Border Background="#6A7D9033" CornerRadius="4" Padding="8,3" HorizontalAlignment="Left">
                                                        <TextBlock Text="Avançado" Foreground="#6A7D90" FontSize="10" FontWeight="Bold"/>
                                                    </Border>
                                                    <TextBlock Text="45 min" Foreground="#94A3B8" FontSize="10" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                                                </Grid>
                                                <TextBlock Text="Padrões de Detalhamento LOD 400" Foreground="White" FontSize="13" FontWeight="Bold" Margin="0,0,0,6"/>
                                                <TextBlock Text="Domine práticas de documentação em nível de construção." Foreground="#94A3B8" FontSize="11" TextWrapping="Wrap"/>
                                            </StackPanel>
                                        </Border>
                                    </Grid>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Grid>

                    <!-- Recent Achievements -->
                    <Border Grid.Row="3" Background="#232629" BorderBrush="#323639" BorderThickness="1" CornerRadius="12" Padding="24">
                        <StackPanel>
                            <Grid Margin="0,0,0,20">
                                <TextBlock Text="{loc:Loc ProgressRecentAchievements}" FontSize="16" FontWeight="Bold" Foreground="White" HorizontalAlignment="Left"/>
                                <TextBlock Text="{loc:Loc ProgressViewAllBadges}" FontSize="11" FontWeight="Bold" Foreground="#6A7D90" HorizontalAlignment="Right"
                                           VerticalAlignment="Center" Cursor="Hand" MouseLeftButtonUp="ViewAllBadges_Click"/>
                            </Grid>

                            <StackPanel Orientation="Horizontal">
                                <!-- Badge 1 - Fast Learner -->
                                <StackPanel Width="80" Margin="0,0,24,0" HorizontalAlignment="Center">
                                    <Border Width="64" Height="64" CornerRadius="32" Background="#F59E0B1A" BorderBrush="#F59E0B4D" BorderThickness="2" HorizontalAlignment="Center" Margin="0,0,0,8">
                                        <Path Data="M8,2 L9.8,5.6 L13.8,6.2 L10.9,9 L11.6,13 L8,11.1 L4.4,13 L5.1,9 L2.2,6.2 L6.2,5.6Z" Fill="#F59E0B"
                                              Width="28" Height="28" Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <TextBlock Text="Aprendiz Rápido" Foreground="#E2E8F0" FontSize="11" FontWeight="Bold" HorizontalAlignment="Center" TextAlignment="Center"/>
                                </StackPanel>

                                <!-- Badge 2 - Data Master -->
                                <StackPanel Width="80" Margin="0,0,24,0" HorizontalAlignment="Center">
                                    <Border Width="64" Height="64" CornerRadius="32" Background="#3B82F61A" BorderBrush="#3B82F64D" BorderThickness="2" HorizontalAlignment="Center" Margin="0,0,0,8">
