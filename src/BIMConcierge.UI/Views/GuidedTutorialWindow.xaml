<Window x:Class="BIMConcierge.UI.Views.GuidedTutorialWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:conv="clr-namespace:BIMConcierge.UI.Converters"
        mc:Ignorable="d"
        Title="BIMConcierge - Tutorial Guiado"
        Width="380" SizeToContent="Height"
        WindowStartupLocation="Manual" WindowStyle="None"
        AllowsTransparency="True" Background="Transparent" FontFamily="Segoe UI"
        Topmost="True">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        <conv:NullToVisibilityConverter x:Key="NullToVis"/>
        <conv:PercentToWidthConverter x:Key="PercentToWidth"/>
    </Window.Resources>

    <Border CornerRadius="12" Background="#17191B" BorderBrush="#1E293B" BorderThickness="1" Margin="10" MouseLeftButtonDown="Border_MouseLeftButtonDown">
        <Border.Effect>
            <DropShadowEffect Color="Black" BlurRadius="15" Opacity="0.4" Direction="270" ShadowDepth="5"/>
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Header: Tutorial title + close -->
            <Border Grid.Row="0" Background="#0F172A" CornerRadius="12,12,0,0" BorderBrush="#1E293B" BorderThickness="0,0,0,1" Padding="15,10">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0" Text="⠿" Foreground="#64748B" FontSize="14" Margin="0,0,10,0" VerticalAlignment="Center" Cursor="SizeAll"/>
                    <TextBlock Grid.Column="1" Text="{Binding Tutorial.Title, FallbackValue='Carregando...'}"
                               Foreground="White" FontSize="14" FontWeight="Bold" VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>

                    <Button Grid.Column="2" Content="✕" FontSize="14" Foreground="#94A3B8" Background="Transparent" BorderThickness="0"
                            Cursor="Hand" Click="BtnClose_Click" Padding="5,0" VerticalAlignment="Center"/>
                </Grid>
            </Border>

            <!-- Progress bar -->
            <StackPanel Grid.Row="1" Margin="20,15,20,5">
                <Grid Margin="0,0,0,8">
                    <TextBlock Foreground="#94A3B8" FontSize="12" FontWeight="SemiBold" HorizontalAlignment="Left"
                               Text="{Binding StepLabel, FallbackValue='Passo 0 de 0'}"/>
                    <TextBlock Foreground="#10B981" FontSize="12" FontWeight="Bold" HorizontalAlignment="Right"
                               Text="{Binding ProgressLabel, FallbackValue='0%'}"/>
                </Grid>
                <Border Height="6" Background="#1E293B" CornerRadius="3">
                    <Border Background="#10B981" CornerRadius="3" HorizontalAlignment="Left"
                            Width="{Binding ProgressPercent, Converter={StaticResource PercentToWidth}, ConverterParameter=320}"/>
                </Border>
            </StackPanel>

            <!-- Step content -->
            <StackPanel Grid.Row="2" Margin="20,15">

                <TextBlock Text="{Binding CurrentStep.Title, FallbackValue='Aguardando tutorial...'}"
                           FontSize="18" FontWeight="Bold" Foreground="White" Margin="0,0,0,15" TextWrapping="Wrap"/>

                <Border Background="#1E293B" CornerRadius="8" Height="160" Margin="0,0,0,15" BorderBrush="#334155" BorderThickness="1">
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                        <TextBlock Text="▶" Foreground="#6A7D90" FontSize="32" HorizontalAlignment="Center" Margin="0,0,0,5"/>
                        <TextBlock Text="{Binding CurrentStep.HighlightZone, FallbackValue='[Animação Demonstrativa]'}"
                                   Foreground="#94A3B8" FontSize="12" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>

                <TextBlock Text="{Binding CurrentStep.Instruction, FallbackValue='Selecione um tutorial para começar.'}"
                           Foreground="#CBD5E1" FontSize="14" TextWrapping="Wrap" LineHeight="20" Margin="0,0,0,20"/>

                <!-- Validation rule hint -->
                <Border Background="#1E293B" BorderBrush="#F59E0B" BorderThickness="1,0,0,0" CornerRadius="0,6,6,0" Padding="15"
                        Visibility="{Binding CurrentStep.ValidationRule, Converter={StaticResource NullToVis}, FallbackValue=Collapsed}">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="⚡" Foreground="#F59E0B" FontSize="16" Margin="0,0,10,0" VerticalAlignment="Top"/>
                        <TextBlock Text="{Binding CurrentStep.ValidationRule}"
                                   Foreground="#94A3B8" FontSize="12" TextWrapping="Wrap" Width="260"/>
                    </StackPanel>
                </Border>

                <!-- Completion overlay -->
                <Border Background="#0F172ACC" CornerRadius="8" Padding="0,30"
                        Visibility="{Binding IsCompleted, Converter={StaticResource BoolToVis}, FallbackValue=Collapsed}">
                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock Text="🎉" FontSize="48" HorizontalAlignment="Center" Margin="0,0,0,15"/>
                        <TextBlock Text="Tutorial Concluído!" FontSize="22" FontWeight="Bold" Foreground="#10B981" HorizontalAlignment="Center" Margin="0,0,0,8"/>
                        <TextBlock Text="Parabéns! Você completou todas as etapas." Foreground="#94A3B8" FontSize="14" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>
            </StackPanel>

            <!-- Footer: navigation buttons -->
            <Border Grid.Row="3" Background="#0F172A" CornerRadius="0,0,12,12" BorderBrush="#1E293B" BorderThickness="0,1,0,0" Padding="20,15">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <Button Grid.Column="0" Content="❮" Width="40" Height="40"
                            Command="{Binding PreviousStepCommand}"
                            Background="#1E293B" Foreground="White" FontSize="16" FontWeight="Bold" BorderThickness="0" Cursor="Hand">
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="6"/>
                            </Style>
                        </Button.Resources>
                    </Button>

                    <Button Grid.Column="1" Content="APLICAR AUTO-FIX" Height="40" Margin="10,0"
                            Command="{Binding ApplyAutoFixCommand}"
                            Background="#6A7D90" Foreground="White" FontSize="12" FontWeight="Bold" BorderThickness="0" Cursor="Hand">
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="6"/>
                            </Style>
                        </Button.Resources>
                    </Button>

                    <Button Grid.Column="2" Content="❯" Width="40" Height="40"
                            Command="{Binding NextStepCommand}"
                            Background="#10B981" Foreground="White" FontSize="16" FontWeight="Bold" BorderThickness="0" Cursor="Hand">
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="6"/>
                            </Style>
                        </Button.Resources>
                    </Button>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>
