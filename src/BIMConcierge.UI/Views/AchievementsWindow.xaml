<Window x:Class="BIMConcierge.UI.Views.AchievementsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:vm="clr-namespace:BIMConcierge.UI.ViewModels"
        xmlns:conv="clr-namespace:BIMConcierge.UI.Converters"
        mc:Ignorable="d"
        Title="BIMConcierge - Conquistas e Gamificação" Height="768" Width="1280"
        WindowStartupLocation="CenterScreen" WindowStyle="None"
        AllowsTransparency="True" Background="Transparent" FontFamily="Segoe UI">

    <Window.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVis"/>
        <conv:NullToVisibilityConverter x:Key="NullToVis"/>
        <conv:PercentToWidthConverter x:Key="PctToWidth"/>
    </Window.Resources>

    <Border CornerRadius="16" Background="#17191B" BorderBrush="#1E293B" BorderThickness="1" MouseLeftButtonDown="Border_MouseLeftButtonDown">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="260"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Sidebar -->
            <Border Grid.Column="0" Background="#0F172A" CornerRadius="16,0,0,16" BorderBrush="#1E293B" BorderThickness="0,0,1,0" Padding="20">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Logo -->
                    <StackPanel Grid.Row="0" Margin="0,0,0,30" Orientation="Horizontal" VerticalAlignment="Center">
                        <Border Width="32" Height="32" Background="#6A7D90" CornerRadius="8" Margin="0,0,12,0">
                            <TextBlock Text="BIM" Foreground="White" FontWeight="Black" FontSize="10" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock Text="BIM CONCIERGE" FontSize="15" FontWeight="Bold" Foreground="White" VerticalAlignment="Center"/>
                    </StackPanel>

                    <!-- Navigation -->
                    <StackPanel Grid.Row="1">
                        <Border Background="Transparent" CornerRadius="8" Padding="12,10" Margin="0,0,0,4" Cursor="Hand"
                                MouseLeftButtonUp="SidebarDashboard_Click">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="⊞" Foreground="#94A3B8" FontSize="16" Margin="0,0,12,0" VerticalAlignment="Center"/>
                                <TextBlock Text="Dashboard" Foreground="#94A3B8" FontWeight="Medium" FontSize="13" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                        <Border Background="Transparent" CornerRadius="8" Padding="12,10" Margin="0,0,0,4" Cursor="Hand">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="▶" Foreground="#94A3B8" FontSize="14" Margin="0,0,12,0" VerticalAlignment="Center"/>
                                <TextBlock Text="Tutoriais" Foreground="#94A3B8" FontWeight="Medium" FontSize="13" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                        <Border Background="Transparent" CornerRadius="8" Padding="12,10" Margin="0,0,0,4" Cursor="Hand"
                                MouseLeftButtonUp="SidebarStandards_Click">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="★" Foreground="#94A3B8" FontSize="16" Margin="0,0,12,0" VerticalAlignment="Center"/>
                                <TextBlock Text="Padrões" Foreground="#94A3B8" FontWeight="Medium" FontSize="13" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                        <Border Background="Transparent" CornerRadius="8" Padding="12,10" Margin="0,0,0,4" Cursor="Hand"
                                MouseLeftButtonUp="SidebarProgress_Click">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="📊" Foreground="#94A3B8" FontSize="14" Margin="0,0,12,0" VerticalAlignment="Center"/>
                                <TextBlock Text="Progresso" Foreground="#94A3B8" FontWeight="Medium" FontSize="13" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                        <Border Background="#6A7D90" CornerRadius="8" Padding="12,10" Margin="0,0,0,4" Cursor="Hand">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="🏆" Foreground="White" FontSize="14" Margin="0,0,12,0" VerticalAlignment="Center"/>
                                <TextBlock Text="Conquistas" Foreground="White" FontWeight="SemiBold" FontSize="13" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>

                    <!-- Pro Status -->
                    <Border Grid.Row="2" Background="#17191B" BorderBrush="#1E293B" BorderThickness="1" CornerRadius="12" Padding="16">
                        <StackPanel>
                            <Grid Margin="0,0,0,6">
                                <TextBlock Text="STATUS PRO" Foreground="#6A7D90" FontSize="10" FontWeight="Bold" HorizontalAlignment="Left" VerticalAlignment="Center"/>
                                <Border Background="#6A7D9033" CornerRadius="4" Padding="6,2" HorizontalAlignment="Right">
                                    <TextBlock Text="Ativo" Foreground="#6A7D90" FontSize="10" FontWeight="Bold"/>
                                </Border>
                            </Grid>
                            <TextBlock Text="Próxima Renovação: Out 2024" Foreground="#94A3B8" FontSize="11"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>

            <!-- Main Content -->
            <Grid Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Error Banner -->
                <Border Grid.RowSpan="2" Background="#7F1D1D" CornerRadius="8" Padding="12,8" Margin="32,12,32,0"
                        VerticalAlignment="Top" Panel.ZIndex="5"
                        Visibility="{Binding ErrorMessage, Converter={StaticResource NullToVis}}">
                    <TextBlock Text="{Binding ErrorMessage}" Foreground="#FCA5A5" FontSize="12" FontWeight="Medium" TextWrapping="Wrap"/>
                </Border>

                <!-- Loading Overlay -->
                <Border Grid.RowSpan="2" Background="#17191BCC" CornerRadius="0,16,16,0" Panel.ZIndex="10"
                        Visibility="{Binding IsBusy, Converter={StaticResource BoolToVis}}">
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                        <Border Width="48" Height="48" Background="#1E293B" CornerRadius="24" Margin="0,0,0,12">
                            <TextBlock Text="⟳" Foreground="#6A7D90" FontSize="24" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock Text="Carregando..." Foreground="#94A3B8" FontSize="14" FontWeight="Medium" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>

                <!-- Header Bar -->
                <Border Grid.Row="0" BorderBrush="#1E293B" BorderThickness="0,0,0,1" Padding="32,12">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <!-- Search -->
                        <Border Grid.Column="0" Background="#232629" CornerRadius="8" Padding="12,8" MaxWidth="400" HorizontalAlignment="Left">
                            <Grid>
                                <TextBlock Text="🔍  Buscar conquistas, missões ou padrões..." Foreground="#64748B" FontSize="12"
                                           VerticalAlignment="Center" IsHitTestVisible="False"/>
                            </Grid>
                        </Border>

                        <!-- XP + Profile + Close -->
                        <StackPanel Grid.Column="1" Orientation="Horizontal">
                            <Border Background="#6A7D901A" CornerRadius="16" Padding="12,6" Margin="0,0,16,0">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="⭐" FontSize="14" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                    <TextBlock Text="{Binding CurrentXp, FallbackValue='1.250 XP', StringFormat={}{0:N0} XP}" Foreground="#6A7D90" FontSize="12" FontWeight="Bold" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Border>

                            <StackPanel Orientation="Horizontal" Margin="0,0,16,0">
                                <StackPanel VerticalAlignment="Center" Margin="0,0,10,0">
                                    <TextBlock Text="{Binding UserName, FallbackValue='Flávio Filho'}" Foreground="White" FontSize="12" FontWeight="Bold" HorizontalAlignment="Right"/>
                                    <TextBlock Text="{Binding LevelTitle, FallbackValue='COORDENADOR BIM I'}" Foreground="#94A3B8" FontSize="9" FontWeight="Bold" HorizontalAlignment="Right"/>
                                </StackPanel>
                                <Border Width="36" Height="36" Background="#6A7D90" CornerRadius="18" BorderBrush="#6A7D90" BorderThickness="2">
                                    <TextBlock Text="FF" Foreground="White" FontWeight="Bold" FontSize="12" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                            </StackPanel>

                            <Button Content="✕" FontSize="16" Foreground="#94A3B8" Background="Transparent" BorderThickness="0"
                                    Cursor="Hand" Click="BtnClose_Click" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Scrollable Content -->
                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="32,24,32,32">

                        <!-- Level Progression Hero -->
                        <Border Background="#6A7D9033" BorderBrush="#6A7D9033" BorderThickness="1" CornerRadius="12" Padding="32" Margin="0,0,0,28">
                            <StackPanel>
                                <Grid Margin="0,0,0,16">
                                    <StackPanel HorizontalAlignment="Left">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="Nível 15" FontSize="28" FontWeight="Bold" Foreground="White"/>
                                            <TextBlock Text=" • " FontSize="28" Foreground="#6A7D90" Margin="4,0"/>
                                            <TextBlock Text="Coordenador BIM I" FontSize="28" FontWeight="Bold" Foreground="White"/>
                                        </StackPanel>
                                        <TextBlock Text="Você está entre os 5% melhores modeladores este mês. Continue assim!" Foreground="#94A3B8" FontSize="13" Margin="0,6,0,0"/>
                                    </StackPanel>
                                    <StackPanel HorizontalAlignment="Right" VerticalAlignment="Center">
                                        <TextBlock Text="PROGRESSO PARA NÍVEL 16" Foreground="#94A3B8" FontSize="10" FontWeight="Bold" HorizontalAlignment="Right"/>
                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                            <TextBlock Text="750" FontSize="24" FontWeight="Bold" Foreground="White"/>
                                            <TextBlock Text=" / 1.000 XP" FontSize="16" Foreground="#94A3B8" VerticalAlignment="Bottom" Margin="0,0,0,2"/>
                                        </StackPanel>
                                    </StackPanel>
                                </Grid>

                                <!-- XP Progress Bar -->
                                <Border Height="16" Background="#1E293B" CornerRadius="8" BorderBrush="#334155" BorderThickness="1" Padding="2">
                                    <Border Background="#6A7D90" CornerRadius="6" HorizontalAlignment="Left"
                                            Width="{Binding LevelProgressPercent, Converter={StaticResource PctToWidth}, ConverterParameter=700}"/>
                                </Border>
                                <Grid Margin="0,8,0,0">
                                    <TextBlock Text="NÍVEL 15" Foreground="#64748B" FontSize="10" FontWeight="Bold" HorizontalAlignment="Left"/>
                                    <TextBlock Text="250 XP PARA PRÓXIMO RANK: COORDENADOR BIM II" Foreground="#64748B" FontSize="10" FontWeight="Bold" HorizontalAlignment="Center"/>
                                    <TextBlock Text="NÍVEL 16" Foreground="#64748B" FontSize="10" FontWeight="Bold" HorizontalAlignment="Right"/>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <!-- Quests + Leaderboard (Left) | Achievements Gallery (Right) -->
                        <Grid Margin="0,0,0,28">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="300"/>
                                <ColumnDefinition Width="24"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0">
                                <!-- Active Quests -->
                                <Border Background="#121820" BorderBrush="#1E293B" BorderThickness="1" CornerRadius="12" Padding="20" Margin="0,0,0,20">
                                    <StackPanel>
                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                                            <TextBlock Text="📋" FontSize="14" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                            <TextBlock Text="Missões Ativas" FontSize="14" FontWeight="Bold" Foreground="White"/>
                                        </StackPanel>

                                        <!-- Quest 1 -->
                                        <Border Background="#0F172A" CornerRadius="8" Padding="14" Margin="0,0,0,10">
                                            <StackPanel>
                                                <Grid Margin="0,0,0,6">
                                                    <TextBlock Text="Guardião de Padrões" Foreground="White" FontSize="12" FontWeight="Bold" HorizontalAlignment="Left"/>
                                                    <TextBlock Text="+50 XP" Foreground="#6A7D90" FontSize="10" FontWeight="Bold" HorizontalAlignment="Right"/>
                                                </Grid>
                                                <TextBlock Text="Corrija 10 erros de nomenclatura no projeto Revit ativo." Foreground="#94A3B8" FontSize="11" TextWrapping="Wrap" Margin="0,0,0,10"/>
                                                <Border Height="6" Background="#1E293B" CornerRadius="3">
                                                    <Border Background="#6A7D90" CornerRadius="3" HorizontalAlignment="Left" Width="160"/>
                                                </Border>
                                                <TextBlock Text="6/10 concluídos" Foreground="#94A3B8" FontSize="10" HorizontalAlignment="Right" Margin="0,4,0,0"/>
                                            </StackPanel>
                                        </Border>

                                        <!-- Quest 2 -->
                                        <Border Background="#0F172A" CornerRadius="8" Padding="14">
                                            <StackPanel>
                                                <Grid Margin="0,0,0,6">
                                                    <TextBlock Text="Aprendiz Veloz" Foreground="White" FontSize="12" FontWeight="Bold" HorizontalAlignment="Left"/>
                                                    <TextBlock Text="+100 XP" Foreground="#6A7D90" FontSize="10" FontWeight="Bold" HorizontalAlignment="Right"/>
                                                </Grid>
                                                <TextBlock Text="Conclua 1 tutorial avançado 'Regex Ninja'." Foreground="#94A3B8" FontSize="11" TextWrapping="Wrap" Margin="0,0,0,10"/>
                                                <Border Height="6" Background="#1E293B" CornerRadius="3">
                                                    <Border Background="#6A7D9050" CornerRadius="3" HorizontalAlignment="Left" Width="0"/>
                                                </Border>
                                                <TextBlock Text="0/1 concluídos" Foreground="#94A3B8" FontSize="10" HorizontalAlignment="Right" Margin="0,4,0,0"/>
                                            </StackPanel>
                                        </Border>
                                    </StackPanel>
                                </Border>

                                <!-- Leaderboard -->
                                <Border Background="#121820" BorderBrush="#1E293B" BorderThickness="1" CornerRadius="12" Padding="20">
                                    <StackPanel>
                                        <Grid Margin="0,0,0,16">
                                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                                                <TextBlock Text="📊" FontSize="14" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                                <TextBlock Text="Ranking" FontSize="14" FontWeight="Bold" Foreground="White"/>
                                            </StackPanel>
                                            <TextBlock Text="VER TODOS" FontSize="9" FontWeight="Bold" Foreground="#6A7D90" HorizontalAlignment="Right" VerticalAlignment="Center" Cursor="Hand"/>
                                        </Grid>

                                        <!-- 1st Place -->
                                        <Border Background="#6A7D901A" BorderBrush="#6A7D9033" BorderThickness="1" CornerRadius="8" Padding="10" Margin="0,0,0,6">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="20"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0" Text="1" Foreground="#6A7D90" FontSize="11" FontWeight="Bold" VerticalAlignment="Center"/>
                                                <Border Grid.Column="1" Width="28" Height="28" Background="#334155" CornerRadius="14" Margin="0,0,8,0">
                                                    <TextBlock Text="SJ" Foreground="White" FontSize="10" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                                <StackPanel Grid.Column="2" VerticalAlignment="Center">
                                                    <TextBlock Text="Sarah Jenkins" Foreground="White" FontSize="11" FontWeight="Bold"/>
                                                    <TextBlock Text="LOD Master" Foreground="#94A3B8" FontSize="9"/>
                                                </StackPanel>
                                                <TextBlock Grid.Column="3" Text="2.480 XP" Foreground="#E2E8F0" FontSize="11" FontWeight="Bold" VerticalAlignment="Center"/>
                                            </Grid>
                                        </Border>

                                        <!-- 2nd Place -->
                                        <Border Padding="10" Margin="0,0,0,6">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="20"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0" Text="2" Foreground="#64748B" FontSize="11" FontWeight="Bold" VerticalAlignment="Center"/>
                                                <Border Grid.Column="1" Width="28" Height="28" Background="#334155" CornerRadius="14" Margin="0,0,8,0">
                                                    <TextBlock Text="MC" Foreground="White" FontSize="10" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                                <StackPanel Grid.Column="2" VerticalAlignment="Center">
                                                    <TextBlock Text="Michael Chen" Foreground="White" FontSize="11" FontWeight="Bold"/>
                                                    <TextBlock Text="Regex Guru" Foreground="#94A3B8" FontSize="9"/>
                                                </StackPanel>
                                                <TextBlock Grid.Column="3" Text="2.150 XP" Foreground="#E2E8F0" FontSize="11" FontWeight="Bold" VerticalAlignment="Center"/>
                                            </Grid>
                                        </Border>

                                        <!-- 3rd Place -->
                                        <Border Padding="10" Margin="0,0,0,6">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="20"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0" Text="3" Foreground="#64748B" FontSize="11" FontWeight="Bold" VerticalAlignment="Center"/>
                                                <Border Grid.Column="1" Width="28" Height="28" Background="#334155" CornerRadius="14" Margin="0,0,8,0">
                                                    <TextBlock Text="EW" Foreground="White" FontSize="10" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                                <StackPanel Grid.Column="2" VerticalAlignment="Center">
                                                    <TextBlock Text="Emma Watts" Foreground="White" FontSize="11" FontWeight="Bold"/>
                                                    <TextBlock Text="Wall Wizard" Foreground="#94A3B8" FontSize="9"/>
                                                </StackPanel>
                                                <TextBlock Grid.Column="3" Text="1.920 XP" Foreground="#E2E8F0" FontSize="11" FontWeight="Bold" VerticalAlignment="Center"/>
                                            </Grid>
                                        </Border>

                                        <!-- Current User -->
                                        <Border BorderBrush="#1E293B" BorderThickness="0,1,0,0" Padding="10,12,10,0" Margin="0,6,0,0" Opacity="0.6">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="20"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0" Text="12" Foreground="#64748B" FontSize="11" FontWeight="Bold" VerticalAlignment="Center"/>
                                                <Border Grid.Column="1" Width="28" Height="28" Background="#334155" CornerRadius="14" Margin="0,0,8,0">
                                                    <TextBlock Text="FF" Foreground="White" FontSize="10" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                                <StackPanel Grid.Column="2" VerticalAlignment="Center">
                                                    <TextBlock Text="Você (Flávio)" Foreground="White" FontSize="11" FontWeight="Bold" FontStyle="Italic"/>
                                                    <TextBlock Text="Coordenador BIM I" Foreground="#94A3B8" FontSize="9"/>
                                                </StackPanel>
                                                <TextBlock Grid.Column="3" Text="1.250 XP" Foreground="#E2E8F0" FontSize="11" FontWeight="Bold" VerticalAlignment="Center"/>
                                            </Grid>
                                        </Border>
                                    </StackPanel>
                                </Border>
                            </StackPanel>

                            <!-- Achievement Gallery -->
                            <StackPanel Grid.Column="2">
                                <Border Background="#121820" BorderBrush="#1E293B" BorderThickness="1" CornerRadius="12" Padding="24" Margin="0,0,0,20">
                                    <StackPanel>
                                        <Grid Margin="0,0,0,20">
                                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                                                <TextBlock Text="🏆" FontSize="16" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                                <TextBlock Text="Galeria de Conquistas" FontSize="18" FontWeight="Bold" Foreground="White"/>
                                            </StackPanel>
                                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                                <Border Background="#6A7D90" CornerRadius="4" Padding="8,4" Margin="0,0,6,0" Cursor="Hand">
                                                    <TextBlock Text="TODOS" Foreground="White" FontSize="9" FontWeight="Bold"/>
                                                </Border>
                                                <Border Background="#232629" CornerRadius="4" Padding="8,4" Margin="0,0,6,0" Cursor="Hand">
                                                    <TextBlock Text="DESBLOQUEADOS" Foreground="#94A3B8" FontSize="9" FontWeight="Bold"/>
                                                </Border>
                                                <Border Background="#232629" CornerRadius="4" Padding="8,4" Cursor="Hand">
                                                    <TextBlock Text="BLOQUEADOS" Foreground="#94A3B8" FontSize="9" FontWeight="Bold"/>
                                                </Border>
                                            </StackPanel>
                                        </Grid>

                                        <!-- Badge Grid - Row 1 -->
                                        <Grid Margin="0,0,0,12">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="12"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="12"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="12"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>

                                            <!-- Unlocked: Wall Master -->
                                            <Border Grid.Column="0" Background="#0F172A" BorderBrush="#6A7D9033" BorderThickness="1" CornerRadius="12" Padding="16" Cursor="Hand">
                                                <StackPanel HorizontalAlignment="Center">
                                                    <Border Width="56" Height="56" Background="#6A7D9033" CornerRadius="28" HorizontalAlignment="Center" Margin="0,0,0,10">
                                                        <TextBlock Text="▦" Foreground="#6A7D90" FontSize="28" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                    </Border>
                                                    <TextBlock Text="Wall Master" Foreground="White" FontSize="12" FontWeight="Bold" HorizontalAlignment="Center"/>
                                                    <TextBlock Text="OURO" Foreground="#94A3B8" FontSize="9" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,2,0,0"/>
                                                </StackPanel>
                                            </Border>

                                            <!-- Unlocked: Regex Ninja -->
                                            <Border Grid.Column="2" Background="#0F172A" BorderBrush="#6A7D9033" BorderThickness="1" CornerRadius="12" Padding="16" Cursor="Hand">
                                                <StackPanel HorizontalAlignment="Center">
                                                    <Border Width="56" Height="56" Background="#6A7D9033" CornerRadius="28" HorizontalAlignment="Center" Margin="0,0,0,10">
                                                        <TextBlock Text="&lt;/&gt;" Foreground="#6A7D90" FontSize="18" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                    </Border>
                                                    <TextBlock Text="Regex Ninja" Foreground="White" FontSize="12" FontWeight="Bold" HorizontalAlignment="Center"/>
                                                    <TextBlock Text="PRATA" Foreground="#94A3B8" FontSize="9" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,2,0,0"/>
                                                </StackPanel>
                                            </Border>

                                            <!-- Locked: LOD Expert -->
                                            <Border Grid.Column="4" Background="#17191B" BorderBrush="#1E293B" BorderThickness="1" CornerRadius="12" Padding="16" Opacity="0.5" Cursor="Hand">
                                                <StackPanel HorizontalAlignment="Center">
                                                    <Border Width="56" Height="56" Background="#334155" CornerRadius="28" HorizontalAlignment="Center" Margin="0,0,0,10">
                                                        <TextBlock Text="⚙" Foreground="#64748B" FontSize="24" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                    </Border>
                                                    <TextBlock Text="LOD Expert" Foreground="White" FontSize="12" FontWeight="Bold" HorizontalAlignment="Center"/>
                                                    <TextBlock Text="BLOQUEADO" Foreground="#64748B" FontSize="9" FontWeight="Bold" FontStyle="Italic" HorizontalAlignment="Center" Margin="0,2,0,0"/>
                                                </StackPanel>
                                            </Border>

                                            <!-- Unlocked: Standard Keeper -->
                                            <Border Grid.Column="6" Background="#0F172A" BorderBrush="#6A7D9033" BorderThickness="1" CornerRadius="12" Padding="16" Cursor="Hand">
                                                <StackPanel HorizontalAlignment="Center">
                                                    <Border Width="56" Height="56" Background="#6A7D9033" CornerRadius="28" HorizontalAlignment="Center" Margin="0,0,0,10">
                                                        <TextBlock Text="✓" Foreground="#6A7D90" FontSize="28" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                    </Border>
                                                    <TextBlock Text="Standard Keeper" Foreground="White" FontSize="12" FontWeight="Bold" HorizontalAlignment="Center"/>
                                                    <TextBlock Text="BRONZE" Foreground="#94A3B8" FontSize="9" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,2,0,0"/>
                                                </StackPanel>
                                            </Border>
                                        </Grid>

                                        <!-- Badge Grid - Row 2 -->
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="12"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="12"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="12"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>

                                            <!-- Locked: Flash Auditor -->
                                            <Border Grid.Column="0" Background="#17191B" BorderBrush="#1E293B" BorderThickness="1" CornerRadius="12" Padding="16" Opacity="0.5" Cursor="Hand">
