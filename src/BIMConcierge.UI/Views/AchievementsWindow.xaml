<Window x:Class="BIMConcierge.UI.Views.AchievementsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:vm="clr-namespace:BIMConcierge.UI.ViewModels"
        xmlns:conv="clr-namespace:BIMConcierge.UI.Converters"
        xmlns:loc="clr-namespace:BIMConcierge.UI.Localization"
        mc:Ignorable="d"
        Title="{loc:Loc AchievementsTitle}" Height="768" Width="1280"
        WindowStartupLocation="CenterScreen" WindowStyle="None"
        AllowsTransparency="True" Background="Transparent" FontFamily="Segoe UI">

    <Window.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVis"/>
        <conv:NullToVisibilityConverter x:Key="NullToVis"/>
        <conv:PercentToWidthConverter x:Key="PctToWidth"/>
        <conv:BoolToBackgroundConverter x:Key="BoolToBackground"/>
        <conv:BoolToOpacityConverter x:Key="BoolToOpacity"/>
        <conv:BoolToBadgeBgConverter x:Key="BoolToBadgeBg"/>
        <conv:BoolToBadgeFillConverter x:Key="BoolToBadgeFill"/>
        <conv:BoolToUnlockLabelConverter x:Key="BoolToUnlockLabel"/>
    </Window.Resources>

    <Border CornerRadius="16" Background="#17191B" BorderBrush="#1E293B" BorderThickness="1" MouseLeftButtonDown="Border_MouseLeftButtonDown">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="260"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Sidebar -->
            <Border Grid.Column="0" Background="#0F172A" CornerRadius="16,0,0,16" BorderBrush="#1E293B" BorderThickness="0,0,1,0" Padding="20">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Logo -->
                    <StackPanel Grid.Row="0" Margin="0,0,0,30" Orientation="Horizontal" VerticalAlignment="Center">
                        <Border Width="32" Height="32" Background="#6A7D90" CornerRadius="8" Margin="0,0,12,0">
                            <TextBlock Text="BIM" Foreground="White" FontWeight="Black" FontSize="10" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock Text="BIM CONCIERGE" FontSize="15" FontWeight="Bold" Foreground="White" VerticalAlignment="Center"/>
                    </StackPanel>

                    <!-- Navigation -->
                    <StackPanel Grid.Row="1">
                        <Border Background="Transparent" CornerRadius="8" Padding="12,10" Margin="0,0,0,4" Cursor="Hand"
                                MouseLeftButtonDown="SidebarDashboard_Click">
                            <StackPanel Orientation="Horizontal">
                                <Path Data="M2,2 H7 V7 H2Z M9,2 H14 V7 H9Z M2,9 H7 V14 H2Z M9,9 H14 V14 H9Z"
                                      Fill="#94A3B8" Width="16" Height="16" Stretch="Uniform" Margin="0,0,12,0" VerticalAlignment="Center"/>
                                <TextBlock Text="{loc:Loc NavDashboard}" Foreground="#94A3B8" FontWeight="Medium" FontSize="13" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                        <Border Background="Transparent" CornerRadius="8" Padding="12,10" Margin="0,0,0,4" Cursor="Hand">
                            <StackPanel Orientation="Horizontal">
                                <Path Data="M2,3 H10 V5 H2Z M2,7 H14 V9 H2Z M2,11 H12 V13 H2Z"
                                      Fill="#94A3B8" Width="16" Height="16" Stretch="Uniform" Margin="0,0,12,0" VerticalAlignment="Center"/>
                                <TextBlock Text="{loc:Loc NavTutorials}" Foreground="#94A3B8" FontWeight="Medium" FontSize="13" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                        <Border Background="Transparent" CornerRadius="8" Padding="12,10" Margin="0,0,0,4" Cursor="Hand"
                                MouseLeftButtonDown="SidebarStandards_Click">
                            <StackPanel Orientation="Horizontal">
                                <Path Data="M8,1 L14,3.5 V8 C14,11.5 8,15 8,15 C8,15 2,11.5 2,8 V3.5Z"
                                      Fill="#94A3B8" Width="16" Height="16" Stretch="Uniform" Margin="0,0,12,0" VerticalAlignment="Center"/>
                                <TextBlock Text="{loc:Loc NavStandards}" Foreground="#94A3B8" FontWeight="Medium" FontSize="13" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                        <Border Background="Transparent" CornerRadius="8" Padding="12,10" Margin="0,0,0,4" Cursor="Hand"
                                MouseLeftButtonDown="SidebarProgress_Click">
                            <StackPanel Orientation="Horizontal">
                                <Path Data="M2,14 V9 H5 V14Z M6.5,14 V6 H9.5 V14Z M11,14 V2 H14 V14Z"
                                      Fill="#94A3B8" Width="16" Height="16" Stretch="Uniform" Margin="0,0,12,0" VerticalAlignment="Center"/>
                                <TextBlock Text="{loc:Loc NavProgress}" Foreground="#94A3B8" FontWeight="Medium" FontSize="13" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                        <Border Background="#6A7D90" CornerRadius="8" Padding="12,10" Margin="0,0,0,4" Cursor="Hand">
                            <StackPanel Orientation="Horizontal">
                                <Path Data="M5,1 H11 L12,5 L8,8 L4,5Z M6,9 H10 V11 H6Z M4,11.5 H12 V13 H4Z"
                                      Fill="White" Width="16" Height="16" Stretch="Uniform" Margin="0,0,12,0" VerticalAlignment="Center"/>
                                <TextBlock Text="{loc:Loc NavAchievements}" Foreground="White" FontWeight="SemiBold" FontSize="13" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>

                    <!-- Pro Status -->
                    <Border Grid.Row="2" Background="#17191B" BorderBrush="#1E293B" BorderThickness="1" CornerRadius="12" Padding="16">
                        <StackPanel>
                            <Grid Margin="0,0,0,6">
                                <TextBlock Text="{loc:Loc AchievementsProStatus}" Foreground="#6A7D90" FontSize="10" FontWeight="Bold" HorizontalAlignment="Left" VerticalAlignment="Center"/>
                                <Border Background="#6A7D9033" CornerRadius="4" Padding="6,2" HorizontalAlignment="Right">
                                    <TextBlock Text="{loc:Loc AchievementsActive}" Foreground="#6A7D90" FontSize="10" FontWeight="Bold"/>
                                </Border>
                            </Grid>
                            <TextBlock Text="{loc:Loc AchievementsProRenewal}" Foreground="#94A3B8" FontSize="11"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>

            <!-- Main Content -->
            <Grid Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Error Banner -->
                <Border Grid.RowSpan="2" Background="#7F1D1D" CornerRadius="8" Padding="12,8" Margin="32,12,32,0"
                        VerticalAlignment="Top" Panel.ZIndex="5"
                        Visibility="{Binding ErrorMessage, Converter={StaticResource NullToVis}}">
                    <TextBlock Text="{Binding ErrorMessage}" Foreground="#FCA5A5" FontSize="12" FontWeight="Medium" TextWrapping="Wrap"/>
                </Border>

                <!-- Loading Overlay -->
                <Border Grid.RowSpan="2" Background="#17191BCC" CornerRadius="0,16,16,0" Panel.ZIndex="10"
                        Visibility="{Binding IsBusy, Converter={StaticResource BoolToVis}}">
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                        <Border Width="48" Height="48" Background="#1E293B" CornerRadius="24" Margin="0,0,0,12">
                            <TextBlock Text="⟳" Foreground="#6A7D90" FontSize="24" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock Text="{loc:Loc Loading}" Foreground="#94A3B8" FontSize="14" FontWeight="Medium" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>

                <!-- Header Bar -->
                <Border Grid.Row="0" BorderBrush="#1E293B" BorderThickness="0,0,0,1" Padding="32,12">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <!-- Search -->
                        <Border Grid.Column="0" Background="#232629" CornerRadius="8" Padding="12,8" MaxWidth="400" HorizontalAlignment="Left">
                            <Grid>
                                <TextBlock Text="{loc:Loc AchievementsSearch}" Foreground="#64748B" FontSize="12"
                                           VerticalAlignment="Center" IsHitTestVisible="False"/>
                            </Grid>
                        </Border>

                        <!-- XP + Profile + Close -->
                        <StackPanel Grid.Column="1" Orientation="Horizontal">
                            <Border Background="#6A7D901A" CornerRadius="16" Padding="12,6" Margin="0,0,16,0">
                                <StackPanel Orientation="Horizontal">
                                    <Path Data="M8,1 L9.8,5.6 L13.8,6.2 L10.9,9 L11.6,13 L8,11.1 L4.4,13 L5.1,9 L2.2,6.2 L6.2,5.6Z" Fill="#F59E0B"
                                          Width="14" Height="14" Stretch="Uniform" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                    <TextBlock Text="{Binding CurrentXp, FallbackValue='1.250 XP', StringFormat={}{0:N0} XP}" Foreground="#6A7D90" FontSize="12" FontWeight="Bold" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Border>

                            <StackPanel Orientation="Horizontal" Margin="0,0,16,0">
                                <StackPanel VerticalAlignment="Center" Margin="0,0,10,0">
                                    <TextBlock Text="{Binding UserName, FallbackValue='Flávio Filho'}" Foreground="White" FontSize="12" FontWeight="Bold" HorizontalAlignment="Right"/>
                                    <TextBlock Text="{Binding LevelTitle, FallbackValue='COORDENADOR BIM I'}" Foreground="#94A3B8" FontSize="9" FontWeight="Bold" HorizontalAlignment="Right"/>
                                </StackPanel>
                                <Border Width="36" Height="36" Background="#6A7D90" CornerRadius="18" BorderBrush="#6A7D90" BorderThickness="2">
                                    <TextBlock Text="{Binding UserInitials, FallbackValue='?'}" Foreground="White" FontWeight="Bold" FontSize="12" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                            </StackPanel>

                            <Button Content="✕" FontSize="16" Foreground="#94A3B8" Background="Transparent" BorderThickness="0"
                                    Cursor="Hand" Click="BtnClose_Click" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Scrollable Content -->
                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="32,24,32,32">

                        <!-- Level Progression Hero -->
                        <Border Background="#6A7D9033" BorderBrush="#6A7D9033" BorderThickness="1" CornerRadius="12" Padding="32" Margin="0,0,0,28">
                            <StackPanel>
                                <Grid Margin="0,0,0,16">
                                    <StackPanel HorizontalAlignment="Left">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="{Binding UserLevel, StringFormat='Nível {0}'}" FontSize="28" FontWeight="Bold" Foreground="White"/>
                                            <TextBlock Text=" • " FontSize="28" Foreground="#6A7D90" Margin="4,0"/>
                                            <TextBlock Text="{Binding LevelTitle}" FontSize="28" FontWeight="Bold" Foreground="White"/>
                                        </StackPanel>
                                    </StackPanel>
                                    <StackPanel HorizontalAlignment="Right" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding UserLevel, StringFormat='PROGRESSO PARA NÍVEL {0}'}" Foreground="#94A3B8" FontSize="10" FontWeight="Bold" HorizontalAlignment="Right"/>
                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                            <TextBlock Text="{Binding CurrentXp, StringFormat=N0}" FontSize="24" FontWeight="Bold" Foreground="White"/>
                                            <TextBlock Foreground="#94A3B8" FontSize="16" VerticalAlignment="Bottom" Margin="0,0,0,2">
                                                <TextBlock.Text>
                                                    <Binding Path="XpForNextLevel" StringFormat=" / {0:N0} XP"/>
                                                </TextBlock.Text>
                                            </TextBlock>
                                        </StackPanel>
                                    </StackPanel>
                                </Grid>

                                <!-- XP Progress Bar -->
                                <Border Height="16" Background="#1E293B" CornerRadius="8" BorderBrush="#334155" BorderThickness="1" Padding="2">
                                    <Border Background="#6A7D90" CornerRadius="6" HorizontalAlignment="Left"
                                            Width="{Binding LevelProgressPercent, Converter={StaticResource PctToWidth}, ConverterParameter=700}"/>
                                </Border>
                                <Grid Margin="0,8,0,0">
                                    <TextBlock Text="{Binding UserLevel, StringFormat='NÍVEL {0}'}" Foreground="#64748B" FontSize="10" FontWeight="Bold" HorizontalAlignment="Left"/>
                                    <TextBlock Text="{Binding NextLevel, StringFormat='NÍVEL {0}'}" Foreground="#64748B" FontSize="10" FontWeight="Bold" HorizontalAlignment="Right"/>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <!-- Quests + Leaderboard (Left) | Achievements Gallery (Right) -->
                        <Grid Margin="0,0,0,28">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="300"/>
                                <ColumnDefinition Width="24"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0">
                                <!-- Active Quests -->
                                <Border Background="#232629" BorderBrush="#1E293B" BorderThickness="1" CornerRadius="12" Padding="20" Margin="0,0,0,20">
                                    <StackPanel>
                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                                            <Path Data="M5,1 H13 V15 H3 V3Z M5,1 V3 H3 M6,7 H11 M6,9.5 H11 M6,12 H9" Stroke="#6A7D90" StrokeThickness="1.2" Fill="Transparent"
                                          Width="14" Height="14" Stretch="Uniform" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                            <TextBlock Text="{loc:Loc AchievementsDailyQuests}" FontSize="14" FontWeight="Bold" Foreground="White"/>
                                        </StackPanel>

                                        <ItemsControl ItemsSource="{Binding ActiveQuests}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Border Background="#0F172A" CornerRadius="8" Padding="14" Margin="0,0,0,10">
                                                        <StackPanel>
                                                            <Grid Margin="0,0,0,6">
                                                                <TextBlock Text="{Binding Title}" Foreground="White" FontSize="12" FontWeight="Bold" HorizontalAlignment="Left"/>
                                                                <TextBlock Foreground="#6A7D90" FontSize="10" FontWeight="Bold" HorizontalAlignment="Right">
                                                                    <TextBlock.Text>
                                                                        <Binding Path="XpReward" StringFormat="+{0} XP"/>
                                                                    </TextBlock.Text>
                                                                </TextBlock>
                                                            </Grid>
                                                            <TextBlock Text="{Binding Description}" Foreground="#94A3B8" FontSize="11" TextWrapping="Wrap" Margin="0,0,0,10"/>
                                                            <Border Height="6" Background="#1E293B" CornerRadius="3">
                                                                <Border Background="#6A7D90" CornerRadius="3" HorizontalAlignment="Left"
                                                                        Width="{Binding ProgressPercent, Converter={StaticResource PctToWidth}, ConverterParameter=260}"/>
                                                            </Border>
                                                            <TextBlock Foreground="#94A3B8" FontSize="10" HorizontalAlignment="Right" Margin="0,4,0,0">
                                                                <TextBlock.Text>
                                                                    <MultiBinding StringFormat="{}{0}/{1} concluídos">
                                                                        <Binding Path="Current"/>
                                                                        <Binding Path="Target"/>
                                                                    </MultiBinding>
                                                                </TextBlock.Text>
                                                            </TextBlock>
                                                        </StackPanel>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </StackPanel>
                                </Border>

                                <!-- Leaderboard -->
                                <Border Background="#232629" BorderBrush="#1E293B" BorderThickness="1" CornerRadius="12" Padding="20">
                                    <StackPanel>
                                        <Grid Margin="0,0,0,16">
                                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                                                <Path Data="M2,14 V9 H5 V14Z M6.5,14 V6 H9.5 V14Z M11,14 V2 H14 V14Z" Fill="#6A7D90"
                                          Width="14" Height="14" Stretch="Uniform" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                                <TextBlock Text="{loc:Loc AchievementsLeaderboard}" FontSize="14" FontWeight="Bold" Foreground="White"/>
                                            </StackPanel>
                                            <TextBlock Text="VER TODOS" FontSize="9" FontWeight="Bold" Foreground="#6A7D90" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                                        </Grid>

                                        <ItemsControl ItemsSource="{Binding Leaderboard}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Border Padding="10" Margin="0,0,0,6">
                                                        <Grid>
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="20"/>
                                                                <ColumnDefinition Width="Auto"/>
                                                                <ColumnDefinition Width="*"/>
                                                                <ColumnDefinition Width="Auto"/>
                                                            </Grid.ColumnDefinitions>
                                                            <TextBlock Grid.Column="0" Text="{Binding Rank}" Foreground="#64748B" FontSize="11" FontWeight="Bold" VerticalAlignment="Center"/>
                                                            <Border Grid.Column="1" Width="28" Height="28" Background="#334155" CornerRadius="14" Margin="0,0,8,0">
                                                                <TextBlock Text="{Binding Initials}" Foreground="White" FontSize="10" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                            </Border>
                                                            <StackPanel Grid.Column="2" VerticalAlignment="Center">
                                                                <TextBlock Text="{Binding Name}" Foreground="White" FontSize="11" FontWeight="Bold"/>
                                                                <TextBlock Text="{Binding Title}" Foreground="#94A3B8" FontSize="9"/>
                                                            </StackPanel>
                                                            <TextBlock Grid.Column="3" Foreground="#E2E8F0" FontSize="11" FontWeight="Bold" VerticalAlignment="Center">
                                                                <TextBlock.Text>
                                                                    <Binding Path="XpPoints" StringFormat="{}{0:N0} XP"/>
                                                                </TextBlock.Text>
                                                            </TextBlock>
                                                        </Grid>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </StackPanel>
                                </Border>
                            </StackPanel>

                            <!-- Achievement Gallery -->
                            <StackPanel Grid.Column="2">
                                <Border Background="#232629" BorderBrush="#1E293B" BorderThickness="1" CornerRadius="12" Padding="24" Margin="0,0,0,20">
                                    <StackPanel>
                                        <Grid Margin="0,0,0,20">
                                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                                                <Path Data="M5,1 H11 L12,5 L8,8 L4,5Z M6,9 H10 V11 H6Z M4,11.5 H12 V13 H4Z" Fill="#6A7D90"
                                          Width="16" Height="16" Stretch="Uniform" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                                <TextBlock Text="{loc:Loc AchievementsGallery}" FontSize="18" FontWeight="Bold" Foreground="White"/>
                                            </StackPanel>
                                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                                <Border Background="#6A7D90" CornerRadius="4" Padding="8,4" Margin="0,0,6,0">
                                                    <TextBlock Text="TODOS" Foreground="White" FontSize="9" FontWeight="Bold"/>
                                                </Border>
                                                <Border Background="#232629" CornerRadius="4" Padding="8,4" Margin="0,0,6,0">
                                                    <TextBlock Text="DESBLOQUEADOS" Foreground="#94A3B8" FontSize="9" FontWeight="Bold"/>
                                                </Border>
                                                <Border Background="#232629" CornerRadius="4" Padding="8,4">
                                                    <TextBlock Text="BLOQUEADOS" Foreground="#94A3B8" FontSize="9" FontWeight="Bold"/>
                                                </Border>
                                            </StackPanel>
                                        </Grid>

                                        <ItemsControl ItemsSource="{Binding FilteredAchievements}">
                                            <ItemsControl.ItemsPanel>
                                                <ItemsPanelTemplate>
                                                    <UniformGrid Columns="4"/>
                                                </ItemsPanelTemplate>
                                            </ItemsControl.ItemsPanel>
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Border CornerRadius="12" Padding="16" Margin="0,0,6,12" Cursor="Hand"
                                                            Background="{Binding IsUnlocked, Converter={StaticResource BoolToBackground}}"
                                                            BorderThickness="1"
                                                            Opacity="{Binding IsUnlocked, Converter={StaticResource BoolToOpacity}}">
                                                        <StackPanel HorizontalAlignment="Center">
                                                            <Border Width="56" Height="56" CornerRadius="28" HorizontalAlignment="Center" Margin="0,0,0,10"
                                                                    Background="{Binding IsUnlocked, Converter={StaticResource BoolToBadgeBg}}">
                                                                <Path Data="M5,1 H11 L12,5 L8,8 L4,5Z M6,9 H10 V11 H6Z M4,11.5 H12 V13 H4Z"
                                                                      Fill="{Binding IsUnlocked, Converter={StaticResource BoolToBadgeFill}}"
                                                                      Width="24" Height="24" Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                            </Border>
                                                            <TextBlock Text="{Binding Title}" Foreground="White" FontSize="12" FontWeight="Bold" HorizontalAlignment="Center" TextAlignment="Center"/>
                                                            <TextBlock Foreground="#94A3B8" FontSize="9" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,2,0,0">
                                                                <TextBlock.Text>
                                                                    <Binding Path="IsUnlocked" Converter="{StaticResource BoolToUnlockLabel}"/>
                                                                </TextBlock.Text>
                                                            </TextBlock>
                                                        </StackPanel>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </StackPanel>
                                </Border>

                                <!-- Unlocks & Rewards -->
                                <Border Background="#232629" BorderBrush="#1E293B" BorderThickness="1" CornerRadius="12" Padding="24">
                                    <StackPanel>
                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                                            <Path Data="M1,6 H15 V14 H1Z M8,6 V14 M2,6 V3 H14 V6 M5,3 L8,0 L11,3" Stroke="#6A7D90" StrokeThickness="1.5" Fill="Transparent"
                                          Width="16" Height="16" Stretch="Uniform" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                            <TextBlock Text="Desbloqueios e Recompensas" FontSize="18" FontWeight="Bold" Foreground="White"/>
                                        </StackPanel>

                                        <ItemsControl ItemsSource="{Binding Rewards}">
                                            <ItemsControl.ItemsPanel>
                                                <ItemsPanelTemplate>
                                                    <UniformGrid Columns="2"/>
                                                </ItemsPanelTemplate>
                                            </ItemsControl.ItemsPanel>
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Border Background="{Binding IsUnlocked, Converter={StaticResource BoolToBackground}}"
                                                            BorderBrush="#1E293B" BorderThickness="1" CornerRadius="12" Padding="16" Margin="0,0,6,12"
                                                            Opacity="{Binding IsUnlocked, Converter={StaticResource BoolToOpacity}}">
                                                        <Grid>
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="Auto"/>
                                                                <ColumnDefinition Width="*"/>
                                                                <ColumnDefinition Width="Auto"/>
                                                            </Grid.ColumnDefinitions>
                                                            <Border Grid.Column="0" Width="44" Height="44" CornerRadius="8" Margin="0,0,12,0"
                                                                    Background="{Binding IsUnlocked, Converter={StaticResource BoolToBadgeBg}}">
                                                                <Path Data="M8,1 L9,5 L13,5 L10,8 L11,12 L8,10 L5,12 L6,8 L3,5 L7,5Z"
                                                                      Fill="{Binding IsUnlocked, Converter={StaticResource BoolToBadgeFill}}"
                                                                      Width="20" Height="20" Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                            </Border>
                                                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                                <TextBlock Text="{Binding Title}" Foreground="White" FontSize="12" FontWeight="Bold"/>
                                                                <TextBlock Text="{Binding Description}" Foreground="#94A3B8" FontSize="10"/>
                                                            </StackPanel>
                                                            <TextBlock Grid.Column="2" FontSize="16" VerticalAlignment="Center">
                                                                <TextBlock.Text>
                                                                    <Binding Path="IsUnlocked" Converter="{StaticResource BoolToUnlockLabel}"
                                                                             ConverterParameter="emoji"/>
                                                                </TextBlock.Text>
                                                            </TextBlock>
                                                        </Grid>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </ScrollViewer>
            </Grid>
        </Grid>
    </Border>
</Window>
