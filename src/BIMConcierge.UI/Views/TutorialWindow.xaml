<Window x:Class="BIMConcierge.UI.Views.TutorialWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:BIMConcierge.UI.ViewModels"
        xmlns:conv="clr-namespace:BIMConcierge.UI.Converters"
        Title="BIM Concierge — Tutorial Guiado"
        Width="960" Height="680"
        WindowStyle="None" AllowsTransparency="True"
        WindowStartupLocation="CenterScreen"
        Background="Transparent">

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="../Themes/BIMConciergeTheme.xaml" />
            </ResourceDictionary.MergedDictionaries>
            <conv:BoolToVisibilityConverter x:Key="BoolToVis" />
        </ResourceDictionary>
    </Window.Resources>

    <Border CornerRadius="12"
            Background="{StaticResource SurfaceDarkBrush}"
            BorderBrush="{StaticResource BorderDarkBrush}"
            BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect BlurRadius="40" ShadowDepth="0" Color="#000000" Opacity="0.6" />
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="52" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="72" />
            </Grid.RowDefinitions>

            <!-- Top bar -->
            <Border Grid.Row="0"
                    Background="{StaticResource BackgroundDarkBrush}"
                    BorderBrush="{StaticResource BorderDarkBrush}"
                    BorderThickness="0,0,0,1"
                    CornerRadius="12,12,0,0"
                    MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Grid Margin="20,0">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Left">
                        <Border Width="28" Height="28" CornerRadius="6"
                                Background="{StaticResource PrimaryBrush}" Margin="0,0,10,0">
                            <TextBlock Text="&#xE82D;" FontFamily="Segoe MDL2 Assets"
                                       FontSize="14" Foreground="White"
                                       HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <TextBlock Text="Tutorial Guiado"
                                   FontSize="14" FontWeight="Bold"
                                   Foreground="{StaticResource TextPrimaryBrush}" />
                    </StackPanel>
                    <Button Content="✕" Width="32" Height="32"
                            HorizontalAlignment="Right"
                            Background="Transparent" BorderThickness="0"
                            Foreground="{StaticResource TextSecondaryBrush}"
                            Cursor="Hand" Click="CloseButton_Click" />
                </Grid>
            </Border>

            <!-- Progress bar -->
            <Border Grid.Row="1"
                    Background="{StaticResource SurfaceDark2Color}"
                    Padding="24,16">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="8" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <Grid Grid.Row="0" Margin="0,0,0,8">
                        <TextBlock Text="Progresso do Tutorial"
                                   FontSize="11" FontWeight="Medium"
                                   Foreground="{StaticResource TextSecondaryBrush}" />
                        <TextBlock HorizontalAlignment="Right"
                                   FontSize="11" FontWeight="Bold"
                                   Foreground="{StaticResource PrimaryBrush}">
                            <Run Text="Passo " />
                            <Run Text="{Binding CurrentStepIndex, Mode=OneWay}" />
                            <Run Text=" de " />
                            <Run Text="{Binding Tutorial.StepCount, Mode=OneWay}" />
                        </TextBlock>
                    </Grid>
                    <ProgressBar Grid.Row="1"
                                 Style="{StaticResource SlimProgressBar}"
                                 Value="{Binding ProgressPercent, Mode=OneWay}"
                                 Maximum="100" />
                </Grid>
            </Border>

            <!-- Step content -->
            <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto" Padding="32">
                <StackPanel>
                    <TextBlock Text="{Binding CurrentStep.Title}"
                               FontSize="26" FontWeight="Bold"
                               Foreground="{StaticResource TextPrimaryBrush}"
                               Margin="0,0,0,16" TextWrapping="Wrap" />

                    <TextBlock Text="{Binding CurrentStep.Instruction}"
                               FontSize="15"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               TextWrapping="Wrap"
                               LineHeight="24"
                               Margin="0,0,0,24" />

                    <!-- Auto-fix button (shown when step supports it) -->
                    <Button Style="{StaticResource GhostButton}"
                            Command="{Binding ApplyAutoFixCommand}"
                            Content="⚡  Aplicar Automaticamente"
                            HorizontalAlignment="Left"
                            Padding="16,10"
                            Visibility="{Binding CurrentStep.AutoApplicable,
                                         Converter={StaticResource BoolToVis}}" />
                </StackPanel>
            </ScrollViewer>

            <!-- Bottom navigation -->
            <Border Grid.Row="3"
                    Background="{StaticResource BackgroundDarkBrush}"
                    BorderBrush="{StaticResource BorderDarkBrush}"
                    BorderThickness="0,1,0,0"
                    Padding="24,0"
                    CornerRadius="0,0,12,12">
                <Grid>
                    <Button Style="{StaticResource GhostButton}"
                            Command="{Binding PreviousStepCommand}"
                            Content="← Anterior"
                            HorizontalAlignment="Left"
                            Padding="16,10" />

                    <Button Style="{StaticResource PrimaryButton}"
                            Command="{Binding NextStepCommand}"
                            Content="Próximo →"
                            HorizontalAlignment="Right"
                            Padding="24,12" />
                </Grid>
            </Border>

        </Grid>
    </Border>
</Window>
