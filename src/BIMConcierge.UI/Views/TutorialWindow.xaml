<Window x:Class="BIMConcierge.UI.Views.TutorialWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:BIMConcierge.UI.ViewModels"
        mc:Ignorable="d"
        Title="BIMConcierge - Tutorial" 
        Height="650" Width="1000"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None" 
        AllowsTransparency="True" 
        Background="Transparent"
        FontFamily="Segoe UI">

    <Border CornerRadius="10" Background="#1E1E24" BorderBrush="#2D2D35" BorderThickness="1">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="350" />
            </Grid.ColumnDefinitions>

            <Grid Grid.Column="0" Margin="40">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0">
                    <TextBlock Text="{Binding Tutorial.Title, FallbackValue='Paredes e Cortinas'}" FontSize="28" FontWeight="Bold" Foreground="White" Margin="0,0,0,5"/>
                    <TextBlock Text="{Binding CurrentStep.Title, FallbackValue='Passo 1: Selecionando o tipo correto'}" FontSize="18" Foreground="#6A7D90" Margin="0,0,0,20"/>
                </StackPanel>

                <Border Grid.Row="1" Background="#18181D" CornerRadius="8" BorderBrush="#2D2D35" BorderThickness="1">
                    <TextBlock Text="[Área do Vídeo/Imagem do Passo]" Foreground="#808085" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>

                <TextBlock Grid.Row="2" Text="{Binding CurrentStep.Instruction, FallbackValue='Neste passo, você deve acessar a aba Arquitetura e selecionar a ferramenta Parede...'}" 
                           Foreground="#A0A0A5" FontSize="14" TextWrapping="Wrap" Margin="0,20,0,0" LineHeight="22"/>
            </Grid>

            <Border Grid.Column="1" Background="#18181D" CornerRadius="0,10,10,0" Padding="30">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0" Margin="0,0,0,20">
                        <TextBlock Text="Progresso" FontSize="20" FontWeight="SemiBold" Foreground="White"/>
                        <Button x:Name="BtnClose" Content="✕" HorizontalAlignment="Right" VerticalAlignment="Top" 
                                Width="30" Height="30" Background="Transparent" Foreground="#A0A0A5" 
                                BorderThickness="0" FontSize="16" Cursor="Hand" Click="BtnClose_Click"/>
                    </Grid>

                    <StackPanel Grid.Row="1">
                        <Border Background="#2D2D35" CornerRadius="8" Padding="15" Margin="0,0,0,10" BorderBrush="#6A7D90" BorderThickness="1">
                            <StackPanel>
                                <TextBlock Text="Passo 1" FontSize="12" Foreground="#6A7D90" FontWeight="Bold"/>
                                <TextBlock Text="Selecionar ferramenta Parede" Foreground="White" FontSize="14" Margin="0,5,0,0" TextWrapping="Wrap"/>
                            </StackPanel>
                        </Border>

                        <Border Background="Transparent" CornerRadius="8" Padding="15" Margin="0,0,0,10">
                            <StackPanel>
                                <TextBlock Text="Passo 2" FontSize="12" Foreground="#808085" FontWeight="Bold"/>
                                <TextBlock Text="Configurar restrição base" Foreground="#A0A0A5" FontSize="14" Margin="0,5,0,0" TextWrapping="Wrap"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>

                    <StackPanel Grid.Row="2">
                        <Button Command="{Binding ApplyAutoFixCommand}" Content="⚡ APLICAR AUTO-FIX" Height="40" Margin="0,0,0,10"
                                Background="#F39C12" Foreground="White" FontWeight="Bold" BorderThickness="0" Cursor="Hand">
                            <Button.Resources>
                                <Style TargetType="Border">
                                    <Setter Property="CornerRadius" Value="5"/>
                                </Style>
                            </Button.Resources>
                        </Button>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="10"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <Button Grid.Column="0" Command="{Binding PreviousStepCommand}" Content="VOLTAR" Height="45" 
                                    Background="#2D2D35" Foreground="White" FontWeight="Bold" BorderThickness="0" Cursor="Hand">
                                <Button.Resources>
                                    <Style TargetType="Border">
                                        <Setter Property="CornerRadius" Value="5"/>
                                    </Style>
                                </Button.Resources>
                            </Button>

                            <Button Grid.Column="2" Command="{Binding NextStepCommand}" Content="PRÓXIMO" Height="45" 
                                    Background="#6A7D90" Foreground="White" FontWeight="Bold" BorderThickness="0" Cursor="Hand">
                                <Button.Resources>
                                    <Style TargetType="Border">
                                        <Setter Property="CornerRadius" Value="5"/>
                                    </Style>
                                </Button.Resources>
                            </Button>
                        </Grid>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>
