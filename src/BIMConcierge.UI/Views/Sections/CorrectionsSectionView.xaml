<UserControl x:Class="BIMConcierge.UI.Views.Sections.CorrectionsSectionView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:conv="clr-namespace:BIMConcierge.UI.Converters"
             xmlns:loc="clr-namespace:BIMConcierge.UI.Localization"
             mc:Ignorable="d"
             d:DesignHeight="768" d:DesignWidth="1024"
             Background="Transparent" FontFamily="Segoe UI">

    <UserControl.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVisibility"/>
        <conv:NullToVisibilityConverter x:Key="StringToVisibility"/>
        <conv:SeverityToBrushConverter x:Key="SeverityToBrush"/>
    </UserControl.Resources>

    <Grid Margin="40">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,25">
            <TextBlock Text="{loc:Loc CorrectionsHeading}" FontSize="28" FontWeight="Bold" Foreground="White" Margin="0,0,0,8"/>
            <TextBlock Text="{loc:Loc CorrectionsSubtitle}" FontSize="15" Foreground="#94A3B8"/>
        </StackPanel>

        <!-- Auto-fix toggle + severity filters -->
        <Grid Grid.Row="1" Margin="0,0,0,25">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Auto-fix toggle -->
            <Border Grid.Column="0" Background="#232629" BorderBrush="#1E293B" BorderThickness="1" CornerRadius="10" Padding="15,10">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="&#x26A1;" FontSize="16" Margin="0,0,10,0" VerticalAlignment="Center"/>
                    <StackPanel VerticalAlignment="Center" Margin="0,0,15,0">
                        <TextBlock Text="{loc:Loc CorrectionsAutoFix}" Foreground="White" FontSize="13" FontWeight="SemiBold"/>
                        <TextBlock Text="{loc:Loc CorrectionsAutoFixDesc}" Foreground="#94A3B8" FontSize="11"/>
                    </StackPanel>
                    <CheckBox IsChecked="{Binding IsAutoFixEnabled}" VerticalAlignment="Center"/>
                </StackPanel>
            </Border>

            <!-- Severity filter buttons -->
            <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                <Button Content="{loc:Loc CorrectionsFilterAll}" Height="36" Padding="18,0" Margin="0,0,8,0"
                        FontSize="12" FontWeight="SemiBold" BorderThickness="0" Cursor="Hand"
                        Command="{Binding SetFilterCommand}" CommandParameter="Todos">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Background" Value="#1E293B"/>
                            <Setter Property="Foreground" Value="#94A3B8"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}" CornerRadius="18" Padding="{TemplateBinding Padding}">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding SelectedSeverity}" Value="Todos">
                                    <Setter Property="Background" Value="#6A7D90"/>
                                    <Setter Property="Foreground" Value="White"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>

                <Button Height="36" Padding="18,0" Margin="0,0,8,0"
                        FontSize="12" FontWeight="SemiBold" BorderThickness="0" Cursor="Hand"
                        Command="{Binding SetFilterCommand}" CommandParameter="Error">
                    <Button.Content>
                        <TextBlock><Run Text="&#x1F6D1; "/><Run Text="{Binding [CorrectionsFilterError], Source={x:Static loc:TranslationSource.Instance}}"/></TextBlock>
                    </Button.Content>
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Background" Value="#1E293B"/>
                            <Setter Property="Foreground" Value="#94A3B8"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}" CornerRadius="18" Padding="{TemplateBinding Padding}">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding SelectedSeverity}" Value="Error">
                                    <Setter Property="Background" Value="#EF4444"/>
                                    <Setter Property="Foreground" Value="White"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>

                <Button Height="36" Padding="18,0" Margin="0,0,8,0"
                        FontSize="12" FontWeight="SemiBold" BorderThickness="0" Cursor="Hand"
                        Command="{Binding SetFilterCommand}" CommandParameter="Warning">
                    <Button.Content>
                        <TextBlock><Run Text="&#x26A0;&#xFE0F; "/><Run Text="{Binding [CorrectionsFilterWarning], Source={x:Static loc:TranslationSource.Instance}}"/></TextBlock>
                    </Button.Content>
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Background" Value="#1E293B"/>
                            <Setter Property="Foreground" Value="#94A3B8"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}" CornerRadius="18" Padding="{TemplateBinding Padding}">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding SelectedSeverity}" Value="Warning">
                                    <Setter Property="Background" Value="#F59E0B"/>
                                    <Setter Property="Foreground" Value="White"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>

                <Button Height="36" Padding="18,0"
                        FontSize="12" FontWeight="SemiBold" BorderThickness="0" Cursor="Hand"
                        Command="{Binding SetFilterCommand}" CommandParameter="Info">
                    <Button.Content>
                        <TextBlock><Run Text="&#x2139;&#xFE0F; "/><Run Text="{Binding [CorrectionsFilterInfo], Source={x:Static loc:TranslationSource.Instance}}"/></TextBlock>
                    </Button.Content>
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Background" Value="#1E293B"/>
                            <Setter Property="Foreground" Value="#94A3B8"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}" CornerRadius="18" Padding="{TemplateBinding Padding}">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding SelectedSeverity}" Value="Info">
                                    <Setter Property="Background" Value="#6A7D90"/>
                                    <Setter Property="Foreground" Value="White"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
            </StackPanel>
        </Grid>

        <!-- Summary bar -->
        <Border Grid.Row="2" Background="#232629" BorderBrush="#1E293B" BorderThickness="1" CornerRadius="8" Padding="20,12" Margin="0,0,0,20">
            <StackPanel Orientation="Horizontal">
                <TextBlock Foreground="#94A3B8" FontSize="13" VerticalAlignment="Center" Margin="0,0,20,0">
                    <Run Text="{Binding [CorrectionsActive], Source={x:Static loc:TranslationSource.Instance}}"/><Run Text="{Binding ActiveCount, Mode=OneWay}" Foreground="#EF4444" FontWeight="Bold"/>
                </TextBlock>
                <TextBlock Foreground="#94A3B8" FontSize="13" VerticalAlignment="Center">
                    <Run Text="{Binding [CorrectionsCorrected], Source={x:Static loc:TranslationSource.Instance}}"/><Run Text="{Binding FixedCount, Mode=OneWay}" Foreground="#22C55E" FontWeight="Bold"/>
                </TextBlock>
            </StackPanel>
        </Border>

        <!-- Loading Indicator -->
        <TextBlock Grid.Row="3" Text="{loc:Loc CorrectionsLoading}" FontSize="16" Foreground="#94A3B8"
                   HorizontalAlignment="Center" VerticalAlignment="Center"
                   Visibility="{Binding IsBusy, Converter={StaticResource BoolToVisibility}}"/>

        <!-- Error Message -->
        <TextBlock Grid.Row="3" Text="{Binding ErrorMessage}" FontSize="14" Foreground="#EF4444"
                   HorizontalAlignment="Center" VerticalAlignment="Top" Margin="0,10,0,0"
                   Visibility="{Binding ErrorMessage, Converter={StaticResource StringToVisibility}}"/>

        <!-- Correction Cards List -->
        <ScrollViewer Grid.Row="3" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <ItemsControl ItemsSource="{Binding Corrections}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Background="#232629" CornerRadius="12" Margin="0,0,0,12"
                                BorderBrush="{Binding Severity, Converter={StaticResource SeverityToBrush}}"
                                BorderThickness="4,0,0,0" Padding="20">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <!-- Severity icon -->
                                <Border Grid.Column="0" Width="40" Height="40" CornerRadius="20" Margin="0,0,15,0" VerticalAlignment="Top">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Background" Value="#1E293B"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Severity}" Value="Error">
                                                    <Setter Property="Background" Value="#3B1111"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding Severity}" Value="Warning">
                                                    <Setter Property="Background" Value="#3B2E11"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <TextBlock HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="16">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Text" Value="&#x2139;&#xFE0F;"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Severity}" Value="Error">
                                                        <Setter Property="Text" Value="&#x1F6D1;"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Severity}" Value="Warning">
                                                        <Setter Property="Text" Value="&#x26A0;&#xFE0F;"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </Border>

                                <!-- Content -->
                                <StackPanel Grid.Column="1" VerticalAlignment="Top">
                                    <Grid Margin="0,0,0,4">
                                        <TextBlock Text="{Binding Title}" FontSize="14" FontWeight="Bold" Foreground="White" HorizontalAlignment="Left"/>
                                        <TextBlock Text="{Binding OccurredAt, StringFormat='{}{0:HH:mm}'}" FontSize="10" Foreground="#64748B" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                                    </Grid>

                                    <TextBlock Text="{Binding Description}" Foreground="#94A3B8" FontSize="13" TextWrapping="Wrap" LineHeight="18" Margin="0,0,0,10"/>

                                    <!-- Element ID -->
                                    <TextBlock Foreground="#64748B" FontSize="11" Margin="0,0,0,10">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding ElementId}" Value="{x:Null}">
                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                        <Run Text="{Binding [CorrectionsElement], Source={x:Static loc:TranslationSource.Instance}}"/><Run Text="{Binding ElementId, Mode=OneWay}" FontFamily="Consolas" Foreground="#6A7D90"/>
                                    </TextBlock>

                                    <!-- Rule info box -->
                                    <Border Background="#0F172A" CornerRadius="6" Padding="12,8" Margin="0,0,0,12"
                                            BorderBrush="#1E293B" BorderThickness="1">
                                        <StackPanel>
                                            <TextBlock Text="{loc:Loc CorrectionsViolatedRule}" Foreground="#64748B" FontSize="9" FontWeight="Bold" Margin="0,0,0,4"/>
                                            <TextBlock Text="{Binding Title}" Foreground="#6A7D90" FontSize="12" FontWeight="SemiBold"/>
                                        </StackPanel>
                                    </Border>
                                </StackPanel>

                                <!-- Action buttons -->
                                <StackPanel Grid.Column="2" VerticalAlignment="Center" Margin="15,0,0,0">
                                    <Button Content="{loc:Loc CorrectionsDismiss}" Height="32" Padding="15,0" Margin="0,0,0,8"
                                            Background="#1E293B" Foreground="#94A3B8" FontSize="12" FontWeight="Bold" BorderThickness="0" Cursor="Hand"
                                            Command="{Binding DataContext.DismissCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            CommandParameter="{Binding}">
                                        <Button.Resources>
                                            <Style TargetType="Border">
                                                <Setter Property="CornerRadius" Value="6"/>
                                            </Style>
                                        </Button.Resources>
                                    </Button>

                                    <Button Height="32" Padding="15,0"
                                            FontSize="12" FontWeight="Bold" BorderThickness="0" Cursor="Hand"
                                            IsEnabled="{Binding CanAutoFix}"
                                            Command="{Binding DataContext.AutoFixCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            CommandParameter="{Binding}">
                                        <Button.Content>
                                            <TextBlock>
                                                <Run Text="&#x26A1; "/><Run Text="Auto-Fix"/>
                                            </TextBlock>
                                        </Button.Content>
                                        <Button.Style>
                                            <Style TargetType="Button">
                                                <Setter Property="Background" Value="#6A7D90"/>
                                                <Setter Property="Foreground" Value="White"/>
                                                <Style.Triggers>
                                                    <Trigger Property="IsEnabled" Value="False">
                                                        <Setter Property="Background" Value="#1E293B"/>
                                                        <Setter Property="Foreground" Value="#64748B"/>
                                                    </Trigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Button.Style>
                                        <Button.Resources>
                                            <Style TargetType="Border">
                                                <Setter Property="CornerRadius" Value="6"/>
                                            </Style>
                                        </Button.Resources>
                                    </Button>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <!-- Empty state -->
        <StackPanel Grid.Row="3" HorizontalAlignment="Center" VerticalAlignment="Center"
                    Visibility="{Binding IsBusy, Converter={StaticResource BoolToVisibility}, ConverterParameter=Inverse}">
            <StackPanel.Style>
                <Style TargetType="StackPanel">
                    <Setter Property="Visibility" Value="Collapsed"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding Corrections.Count}" Value="0">
                            <Setter Property="Visibility" Value="Visible"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </StackPanel.Style>
            <TextBlock Text="&#x2705;" FontSize="48" HorizontalAlignment="Center" Margin="0,0,0,15"/>
            <TextBlock Text="{loc:Loc CorrectionsEmptyTitle}" FontSize="18" FontWeight="SemiBold" Foreground="#94A3B8" HorizontalAlignment="Center" Margin="0,0,0,5"/>
            <TextBlock Text="{loc:Loc CorrectionsEmptyDesc}" FontSize="13" Foreground="#64748B" HorizontalAlignment="Center"/>
        </StackPanel>
    </Grid>
</UserControl>
