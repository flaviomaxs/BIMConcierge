<UserControl x:Class="BIMConcierge.UI.Views.Sections.TutorialDetailSectionView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:BIMConcierge.UI.Converters"
             xmlns:loc="clr-namespace:BIMConcierge.UI.Localization"
             FontFamily="Segoe UI">

    <UserControl.Resources>
        <conv:NullToVisibilityConverter x:Key="NullToVis"/>
        <conv:PercentToWidthConverter x:Key="PercentToWidth"/>
    </UserControl.Resources>

    <Grid Background="#17191B">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="400"/>
        </Grid.ColumnDefinitions>

        <!-- Left panel: Tutorial info -->
        <Grid Grid.Column="0" Margin="50">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Breadcrumb -->
            <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,20">
                <TextBlock Text="Biblioteca" Foreground="#6A7D90" FontSize="13" FontWeight="SemiBold"/>
                <TextBlock Text=" ❯ " Foreground="#334155" FontSize="13" FontWeight="SemiBold"/>
                <TextBlock Text="{Binding Tutorial.Category, FallbackValue='...'}" Foreground="#6A7D90" FontSize="13" FontWeight="SemiBold"/>
                <TextBlock Text=" ❯ " Foreground="#334155" FontSize="13" FontWeight="SemiBold"/>
                <TextBlock Text="{Binding Tutorial.Title, Mode=OneWay, FallbackValue='...'}" Foreground="#94A3B8" FontSize="13" FontWeight="SemiBold"/>
            </StackPanel>

            <!-- Title + badges -->
            <StackPanel Grid.Row="1" Margin="0,0,0,30">
                <TextBlock Text="{Binding Tutorial.Title, FallbackValue='Carregando...'}"
                           FontSize="36" FontWeight="Bold" Foreground="White" Margin="0,0,0,15" TextWrapping="Wrap"/>

                <WrapPanel Orientation="Horizontal">
                    <Border Background="#1E293B" CornerRadius="6" Padding="10,5" Margin="0,0,10,0">
                        <TextBlock Text="{Binding CategoryLabel, FallbackValue='...'}"
                                   Foreground="#6A7D90" FontSize="11" FontWeight="Bold"/>
                    </Border>
                    <Border Background="#1E293B" CornerRadius="6" Padding="10,5" Margin="0,0,10,0">
                        <TextBlock Text="{Binding DifficultyLabel, FallbackValue='...'}"
                                   Foreground="#F59E0B" FontSize="11" FontWeight="Bold"/>
                    </Border>
                    <Border Background="#1E293B" CornerRadius="6" Padding="10,5" Margin="0,0,10,0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="⏱" Foreground="#94A3B8" FontSize="12" Margin="0,0,5,0" VerticalAlignment="Center"/>
                            <TextBlock Text="{Binding DurationLabel, FallbackValue='0 MINUTOS'}"
                                       Foreground="#94A3B8" FontSize="11" FontWeight="Bold" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                    <Border Background="#1E293B" CornerRadius="6" Padding="10,5" Margin="0,0,10,0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="☰" Foreground="#94A3B8" FontSize="12" Margin="0,0,5,0" VerticalAlignment="Center"/>
                            <TextBlock Text="{Binding StepCountLabel, FallbackValue='0 PASSOS'}"
                                       Foreground="#94A3B8" FontSize="11" FontWeight="Bold" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                </WrapPanel>
            </StackPanel>

            <!-- Description -->
            <TextBlock Grid.Row="2" Text="{Binding Tutorial.Description, FallbackValue='Carregando descrição...'}"
                       Foreground="#94A3B8" FontSize="16" TextWrapping="Wrap" LineHeight="24" Margin="0,0,0,40"/>

            <!-- Learning objectives (derived from step titles) -->
            <StackPanel Grid.Row="3">
                <TextBlock Text="{loc:Loc TutorialDetailWhatYouLearn}" FontSize="20" FontWeight="SemiBold" Foreground="White" Margin="0,0,0,20"/>

                <ItemsControl ItemsSource="{Binding Tutorial.Steps}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel Orientation="Vertical" MaxHeight="300"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal" Margin="0,0,30,15" Width="350">
                                <Border Width="24" Height="24" Background="#10B981" CornerRadius="12" Margin="0,0,10,0">
                                    <TextBlock Text="✓" Foreground="White" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <TextBlock Text="{Binding Title}" Foreground="#CBD5E1" FontSize="14" VerticalAlignment="Center" TextWrapping="Wrap" MaxWidth="300"/>
                            </StackPanel>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>

            <!-- Start button -->
            <Button Grid.Row="4" Content="{loc:Loc TutorialDetailStartTrack}" Height="55" Width="300" HorizontalAlignment="Left"
                    Command="{Binding StartTutorialCommand}"
                    Background="#6A7D90" Foreground="White" FontSize="14" FontWeight="Bold" BorderThickness="0" Cursor="Hand">
                <Button.Resources>
                    <Style TargetType="Border">
                        <Setter Property="CornerRadius" Value="8"/>
                    </Style>
                </Button.Resources>
            </Button>
        </Grid>

        <!-- Right panel: Step list with progress -->
        <Border Grid.Column="1" Background="#0F172A" BorderBrush="#1E293B" BorderThickness="1,0,0,0" Padding="30">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Progress summary -->
                <StackPanel Grid.Row="0" Margin="0,20,0,30">
                    <TextBlock Text="{loc:Loc TutorialDetailTrackContent}" FontSize="20" FontWeight="Bold" Foreground="White" Margin="0,0,0,15"/>

                    <Grid Margin="0,0,0,8">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                            <TextBlock Text="{Binding CompletedSteps, Mode=OneWay, FallbackValue='0'}" Foreground="#94A3B8" FontSize="13" FontWeight="SemiBold"/>
                            <TextBlock Text="/" Foreground="#94A3B8" FontSize="13" FontWeight="SemiBold"/>
                            <TextBlock Text="{Binding Tutorial.StepCount, Mode=OneWay, FallbackValue='0'}" Foreground="#94A3B8" FontSize="13" FontWeight="SemiBold"/>
                            <TextBlock Text=" Passos Concluídos" Foreground="#94A3B8" FontSize="13" FontWeight="SemiBold"/>
                        </StackPanel>
                        <TextBlock Foreground="#10B981" FontSize="13" FontWeight="Bold" HorizontalAlignment="Right"
                                   Text="{Binding ProgressLabel, FallbackValue='0%'}"/>
                    </Grid>

                    <Border Height="8" Background="#1E293B" CornerRadius="4">
                        <Border Background="#10B981" CornerRadius="4" HorizontalAlignment="Left"
                                Width="{Binding SavedProgressPercent, Converter={StaticResource PercentToWidth}, ConverterParameter=340}"/>
                    </Border>
                </StackPanel>

                <!-- Step list -->
                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                    <ItemsControl ItemsSource="{Binding Tutorial.Steps}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="0,0,0,15">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <Border Grid.Column="0" Width="28" Height="28" CornerRadius="14" Margin="0,0,15,0" VerticalAlignment="Top"
                                            Background="#1E293B" BorderBrush="#334155" BorderThickness="1">
                                        <TextBlock Foreground="#94A3B8" FontSize="12" FontWeight="Bold"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center"
                                                   Text="{Binding Order}"/>
                                    </Border>

                                    <TextBlock Grid.Column="1" Foreground="#CBD5E1" FontSize="14" FontWeight="Medium"
                                               TextWrapping="Wrap" VerticalAlignment="Center"
                                               Text="{Binding Title}"/>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>
        </Border>
    </Grid>
</UserControl>
