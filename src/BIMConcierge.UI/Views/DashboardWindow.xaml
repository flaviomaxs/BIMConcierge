<Window x:Class="BIMConcierge.UI.Views.DashboardWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:vm="clr-namespace:BIMConcierge.UI.ViewModels"
        xmlns:conv="clr-namespace:BIMConcierge.UI.Converters"
        mc:Ignorable="d"
        Title="BIMConcierge - Dashboard" Height="768" Width="1280"
        WindowStartupLocation="CenterScreen" WindowStyle="None" 
        AllowsTransparency="True" Background="Transparent" FontFamily="Segoe UI">

    <Border CornerRadius="16" Background="#17191B" BorderBrush="#1E293B" BorderThickness="1" MouseLeftButtonDown="Border_MouseLeftButtonDown">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="280" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="#0F172A" CornerRadius="16,0,0,16" BorderBrush="#1E293B" BorderThickness="0,0,1,0" Padding="24">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Margin="0,0,0,40" Orientation="Horizontal" VerticalAlignment="Center">
                        <Border Width="32" Height="32" Background="#1E293B" CornerRadius="8" Margin="0,0,12,0">
                            <TextBlock Text="BIM" Foreground="#6A7D90" FontWeight="Black" FontSize="12" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock Text="BIM CONCIERGE" FontSize="15" FontWeight="Bold" Foreground="#6A7D90" VerticalAlignment="Center"/>
                    </StackPanel>

                    <StackPanel Grid.Row="1">
                        <Border Background="#1E293B" CornerRadius="8" Padding="12,10" Margin="0,0,0,5" Cursor="Hand">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="⊞" Foreground="#6A7D90" FontSize="18" Margin="0,0,12,0" VerticalAlignment="Center"/>
                                <TextBlock Text="Painel Principal" Foreground="White" FontWeight="SemiBold" FontSize="14" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>

                        <Border Background="Transparent" CornerRadius="8" Padding="12,10" Margin="0,0,0,5" Cursor="Hand"
                                MouseLeftButtonUp="SidebarTutorials_Click">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="▶" Foreground="#94A3B8" FontSize="16" Margin="0,0,12,0" VerticalAlignment="Center"/>
                                <TextBlock Text="Tutoriais" Foreground="#94A3B8" FontWeight="Medium" FontSize="14" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>

                        <Border Background="Transparent" CornerRadius="8" Padding="12,10" Margin="0,0,0,5" Cursor="Hand"
                                MouseLeftButtonUp="SidebarStandards_Click">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="★" Foreground="#94A3B8" FontSize="18" Margin="0,0,12,0" VerticalAlignment="Center"/>
                                <TextBlock Text="Padrões da Empresa" Foreground="#94A3B8" FontWeight="Medium" FontSize="14" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>

                        <Border Background="Transparent" CornerRadius="8" Padding="12,10" Margin="0,0,0,5" Cursor="Hand"
                                MouseLeftButtonUp="SidebarProgress_Click">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="📊" Foreground="#94A3B8" FontSize="18" Margin="0,0,12,0" VerticalAlignment="Center"/>
                                <TextBlock Text="Progresso do Aluno" Foreground="#94A3B8" FontWeight="Medium" FontSize="14" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>

                        <Border Background="Transparent" CornerRadius="8" Padding="12,10" Margin="0,0,0,5" Cursor="Hand"
                                MouseLeftButtonUp="SidebarAchievements_Click">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="🏆" Foreground="#94A3B8" FontSize="18" Margin="0,0,12,0" VerticalAlignment="Center"/>
                                <TextBlock Text="Conquistas" Foreground="#94A3B8" FontWeight="Medium" FontSize="14" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>

                    <Border Grid.Row="2" Background="#17191B" BorderBrush="#1E293B" BorderThickness="1" CornerRadius="12" Padding="12">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <Border Grid.Column="0" Width="36" Height="36" Background="#6A7D90" CornerRadius="18" Margin="0,0,12,0">
                                <TextBlock Text="FF" Foreground="White" FontWeight="Bold" FontSize="14" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>

                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                <TextBlock Text="Flávio Filho" Foreground="White" FontWeight="SemiBold" FontSize="13"/>
                                <TextBlock Text="Arquiteto" Foreground="#94A3B8" FontSize="12"/>
                            </StackPanel>

                            <TextBlock Grid.Column="2" Text="⋮" Foreground="#94A3B8" FontSize="18" FontWeight="Bold" VerticalAlignment="Center" Cursor="Hand"/>
                        </Grid>
                    </Border>
                </Grid>
            </Border>

            <Grid Grid.Column="1" Margin="40">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Button Grid.Row="0" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,-20,-20,0"
                        Content="✕" FontSize="16" Foreground="#94A3B8" Background="Transparent" BorderThickness="0"
                        Cursor="Hand" Click="BtnClose_Click"/>

                <StackPanel Grid.Row="0" Margin="0,0,0,30">
                    <TextBlock Text="Bem-vindo(a) de volta, Flávio!" FontSize="28" FontWeight="Bold" Foreground="White" Margin="0,0,0,8"/>
                    <TextBlock Text="Aqui está o que está acontecendo com seus modelos hoje." FontSize="15" Foreground="#94A3B8"/>
                </StackPanel>

                <Grid Grid.Row="1" Margin="0,0,0,30">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="20"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="20"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" Background="#121820" BorderBrush="#1E293B" BorderThickness="1" CornerRadius="12" Padding="20">
                        <StackPanel>
                            <TextBlock Text="ITENS MODELADOS" Foreground="#94A3B8" FontSize="11" FontWeight="Bold" Margin="0,0,0,8"/>
                            <Grid>
                                <TextBlock Text="142" FontSize="28" FontWeight="Bold" Foreground="White" HorizontalAlignment="Left"/>
                                <TextBlock Text="+12%" FontSize="12" FontWeight="Bold" Foreground="#10B981" HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="0,0,0,6"/>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="2" Background="#121820" BorderBrush="#1E293B" BorderThickness="1" CornerRadius="12" Padding="20">
                        <StackPanel>
                            <TextBlock Text="OPERAÇÕES NO PADRÃO" Foreground="#94A3B8" FontSize="11" FontWeight="Bold" Margin="0,0,0,8"/>
                            <Grid>
                                <TextBlock Text="98%" FontSize="28" FontWeight="Bold" Foreground="White" HorizontalAlignment="Left"/>
                                <TextBlock Text="+2%" FontSize="12" FontWeight="Bold" Foreground="#10B981" HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="0,0,0,6"/>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="4" Background="#121820" BorderBrush="#1E293B" BorderThickness="1" CornerRadius="12" Padding="20">
                        <StackPanel>
                            <TextBlock Text="AVISOS CORRIGIDOS" Foreground="#94A3B8" FontSize="11" FontWeight="Bold" Margin="0,0,0,8"/>
                            <Grid>
                                <TextBlock Text="12" FontSize="28" FontWeight="Bold" Foreground="White" HorizontalAlignment="Left"/>
                                <TextBlock Text="ESTÁVEL" FontSize="12" FontWeight="Bold" Foreground="#6A7D90" HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="0,0,0,6"/>
                            </Grid>
                        </StackPanel>
                    </Border>
                </Grid>

                <Grid Grid.Row="2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2*"/>
                        <ColumnDefinition Width="40"/>
                        <ColumnDefinition Width="1*"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Atividade Recente" FontSize="18" FontWeight="SemiBold" Foreground="White" Margin="0,0,0,20"/>

                        <Border Background="#17191B" BorderBrush="#1E293B" BorderThickness="1" CornerRadius="12" Padding="0,10">
                            <StackPanel>
                                <Border BorderBrush="#1E293B" BorderThickness="0,0,0,1" Padding="20,15">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <Ellipse Grid.Column="0" Width="10" Height="10" Fill="#6A7D90" VerticalAlignment="Center" Margin="0,0,15,0"/>
                                        <TextBlock Grid.Column="1" Text="Modelou Parede Básica" Foreground="White" FontSize="14" FontWeight="Medium" VerticalAlignment="Center"/>
                                        <TextBlock Grid.Column="2" Text="Há 2 min" Foreground="#94A3B8" FontSize="12" VerticalAlignment="Center"/>
                                    </Grid>
                                </Border>

                                <Border BorderBrush="#1E293B" BorderThickness="0,0,0,1" Padding="20,15">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <Ellipse Grid.Column="0" Width="10" Height="10" Fill="#10B981" VerticalAlignment="Center" Margin="0,0,15,0"/>
                                        <TextBlock Grid.Column="1" Text="Corrigiu elementos sobrepostos" Foreground="White" FontSize="14" FontWeight="Medium" VerticalAlignment="Center"/>
                                        <TextBlock Grid.Column="2" Text="Há 15 min" Foreground="#94A3B8" FontSize="12" VerticalAlignment="Center"/>
                                    </Grid>
                                </Border>

                                <Border Padding="20,15">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <Ellipse Grid.Column="0" Width="10" Height="10" Fill="#F59E0B" VerticalAlignment="Center" Margin="0,0,15,0"/>
                                        <TextBlock Grid.Column="1" Text="Iniciou Tutorial: Paredes Cortina" Foreground="White" FontSize="14" FontWeight="Medium" VerticalAlignment="Center"/>
                                        <TextBlock Grid.Column="2" Text="Há 1 hora" Foreground="#94A3B8" FontSize="12" VerticalAlignment="Center"/>
                                    </Grid>
                                </Border>
                            </StackPanel>
                        </Border>
                    </StackPanel>

                    <StackPanel Grid.Column="2">
                        <TextBlock Text="Padrão em Foco" FontSize="18" FontWeight="SemiBold" Foreground="White" Margin="0,0,0,20"/>

                        <Border Background="#0F172A" BorderBrush="#1E293B" BorderThickness="1" CornerRadius="12" Padding="20">
                            <StackPanel>
                                <Border Width="40" Height="40" Background="#1E293B" CornerRadius="8" HorizontalAlignment="Left" Margin="0,0,0,15">
                                    <TextBlock Text="⚡" Foreground="#F59E0B" FontSize="18" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <TextBlock Text="Convenção de Nomenclatura" Foreground="White" FontSize="15" FontWeight="SemiBold" Margin="0,0,0,5"/>
                                <TextBlock Text="Sua taxa de conformidade para nomenclatura de níveis e vistas estruturais." 
                                           Foreground="#94A3B8" FontSize="13" TextWrapping="Wrap" Margin="0,0,0,20" LineHeight="20"/>

                                <Grid Margin="0,0,0,20">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <TextBlock Grid.Row="0" Text="98% Concluído" Foreground="#10B981" FontSize="12" FontWeight="Bold" Margin="0,0,0,5"/>
                                    <Border Grid.Row="1" Height="6" Background="#1E293B" CornerRadius="3">
                                        <Border Width="180" Background="#10B981" CornerRadius="3" HorizontalAlignment="Left"/>
                                    </Border>
                                </Grid>

                                <Button Content="Ver Detalhes" Height="40" Background="#1E293B" Foreground="White" 
                                        FontSize="13" FontWeight="SemiBold" BorderThickness="0" Cursor="Hand">
                                    <Button.Resources>
                                        <Style TargetType="Border">
                                            <Setter Property="CornerRadius" Value="6"/>
                                        </Style>
                                    </Button.Resources>
                                </Button>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Grid>
            </Grid>
        </Grid>
    </Border>
</Window>
