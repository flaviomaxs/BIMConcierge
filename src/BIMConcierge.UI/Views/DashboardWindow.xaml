<Window x:Class="BIMConcierge.UI.Views.DashboardWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:BIMConcierge.UI.ViewModels"
        xmlns:views="clr-namespace:BIMConcierge.UI.Views"
        xmlns:controls="clr-namespace:BIMConcierge.UI.Controls"
        Title="BIM Concierge"
        Width="1100" Height="720"
        WindowStyle="None" AllowsTransparency="True"
        WindowStartupLocation="CenterScreen"
        Background="Transparent">

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="../Themes/BIMConciergeTheme.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>

    <Border CornerRadius="12"
            Background="{StaticResource BackgroundDarkBrush}"
            BorderBrush="{StaticResource BorderDarkBrush}"
            BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect BlurRadius="40" ShadowDepth="0" Color="#000000" Opacity="0.6" />
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="52" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!-- ── Top bar ─────────────────────────────────────────────────── -->
            <Border Grid.Row="0"
                    Background="{StaticResource BackgroundDarkBrush}"
                    BorderBrush="{StaticResource BorderDarkBrush}"
                    BorderThickness="0,0,0,1"
                    CornerRadius="12,12,0,0"
                    MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Grid Margin="16,0">
                    <!-- Logo -->
                    <StackPanel Orientation="Horizontal"
                                VerticalAlignment="Center" HorizontalAlignment="Left">
                        <Border Width="28" Height="28" CornerRadius="6"
                                Background="{StaticResource PrimaryBrush}" Margin="0,0,10,0">
                            <TextBlock Text="&#xE53C;" FontFamily="Segoe MDL2 Assets"
                                       FontSize="14" Foreground="White"
                                       HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="BIM Concierge"
                                       FontSize="14" FontWeight="Bold"
                                       Foreground="{StaticResource TextPrimaryBrush}" />
                            <TextBlock Text="INTELLIGENT REVIT ASSISTANT"
                                       FontSize="8" FontWeight="Medium"
                                       Foreground="{StaticResource PrimaryLightBrush}"
                                       controls:LetterSpacing.Value="1.5" />
                        </StackPanel>
                    </StackPanel>

                    <!-- Search box -->
                    <Border HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Width="220" Height="30"
                            CornerRadius="{StaticResource RadiusMd}"
                            Background="{StaticResource SurfaceDarkBrush}"
                            BorderBrush="{StaticResource BorderDarkBrush}"
                            BorderThickness="1">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="30" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="&#xE721;" FontFamily="Segoe MDL2 Assets"
                                       FontSize="12" Foreground="{StaticResource TextSecondaryBrush}"
                                       HorizontalAlignment="Center" VerticalAlignment="Center" />
                            <TextBox Grid.Column="1"
                                     Text="{Binding SearchQuery, UpdateSourceTrigger=PropertyChanged}"
                                     Background="Transparent" BorderThickness="0"
                                     Foreground="{StaticResource TextPrimaryBrush}"
                                     VerticalAlignment="Center" FontSize="12"
                                     Padding="0,0,8,0" />
                        </Grid>
                    </Border>

                    <!-- Right controls -->
                    <StackPanel Orientation="Horizontal"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Center">
                        <Button Width="32" Height="32" Background="Transparent" BorderThickness="0"
                                Margin="4,0">
                            <TextBlock Text="&#xE7E7;" FontFamily="Segoe MDL2 Assets"
                                       FontSize="16" Foreground="{StaticResource TextSecondaryBrush}" />
                        </Button>
                        <Button Width="32" Height="32" Background="Transparent" BorderThickness="0"
                                Margin="4,0">
                            <TextBlock Text="&#xE713;" FontFamily="Segoe MDL2 Assets"
                                       FontSize="16" Foreground="{StaticResource TextSecondaryBrush}" />
                        </Button>
                        <!-- Avatar -->
                        <Border Width="30" Height="30" CornerRadius="15"
                                Background="{StaticResource PrimaryBrush}"
                                Margin="8,0,0,0">
                            <TextBlock Text="{Binding CurrentUser.Name[0]}"
                                       Foreground="White" FontWeight="Bold" FontSize="13"
                                       HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <!-- Close -->
                        <Button Content="✕" Width="32" Height="32"
                                Background="Transparent" BorderThickness="0"
                                Foreground="{StaticResource TextSecondaryBrush}"
                                FontSize="13" Cursor="Hand"
                                Margin="8,0,0,0"
                                Click="CloseButton_Click" />
                    </StackPanel>
                </Grid>
            </Border>

            <!-- ── Main content ────────────────────────────────────────────── -->
            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="220" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <!-- ── Sidebar ──────────────────────────────────────────────── -->
                <Border Grid.Column="0"
                        Background="{StaticResource BackgroundDarkBrush}"
                        BorderBrush="{StaticResource BorderDarkBrush}"
                        BorderThickness="0,0,1,0">
                    <StackPanel Margin="12,16">

                        <TextBlock Text="MENU PRINCIPAL"
                                   FontSize="9" FontWeight="Medium"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   controls:LetterSpacing.Value="1.5"
                                   Margin="12,0,0,8" />

                        <!-- Nav items -->
                        <Button Style="{StaticResource GhostButton}"
                                Command="{Binding NavigateToCommand}"
                                CommandParameter="Dashboard"
                                HorizontalContentAlignment="Left"
                                Padding="12,10" Margin="0,2" Height="44">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE80F;" FontFamily="Segoe MDL2 Assets"
                                           FontSize="16" Margin="0,0,12,0"
                                           Foreground="{StaticResource PrimaryLightBrush}" />
                                <TextBlock Text="Dashboard" FontSize="14"
                                           Foreground="{StaticResource TextPrimaryBrush}" />
                            </StackPanel>
                        </Button>

                        <Button Style="{StaticResource GhostButton}"
                                Command="{Binding NavigateToCommand}"
                                CommandParameter="Tutorials"
                                HorizontalContentAlignment="Left"
                                Padding="12,10" Margin="0,2" Height="44">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE82D;" FontFamily="Segoe MDL2 Assets"
                                           FontSize="16" Margin="0,0,12,0"
                                           Foreground="{StaticResource TextSecondaryBrush}" />
                                <TextBlock Text="Biblioteca de Tutoriais" FontSize="14"
                                           Foreground="{StaticResource TextPrimaryBrush}" />
                            </StackPanel>
                        </Button>

                        <Button Style="{StaticResource GhostButton}"
                                Command="{Binding NavigateToCommand}"
                                CommandParameter="Corrections"
                                HorizontalContentAlignment="Left"
                                Padding="12,10" Margin="0,2" Height="44">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE9CE;" FontFamily="Segoe MDL2 Assets"
                                           FontSize="16" Margin="0,0,12,0"
                                           Foreground="{StaticResource TextSecondaryBrush}" />
                                <TextBlock Text="Correção em Tempo Real" FontSize="13"
                                           Foreground="{StaticResource TextPrimaryBrush}" />
                            </StackPanel>
                        </Button>

                        <Button Style="{StaticResource GhostButton}"
                                Command="{Binding NavigateToCommand}"
                                CommandParameter="Standards"
                                HorizontalContentAlignment="Left"
                                Padding="12,10" Margin="0,2" Height="44">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xECA5;" FontFamily="Segoe MDL2 Assets"
                                           FontSize="16" Margin="0,0,12,0"
                                           Foreground="{StaticResource TextSecondaryBrush}" />
                                <TextBlock Text="Padrões da Empresa" FontSize="14"
                                           Foreground="{StaticResource TextPrimaryBrush}" />
                            </StackPanel>
                        </Button>

                        <Separator Background="{StaticResource BorderDarkBrush}" Margin="12,12" />

                        <TextBlock Text="GESTÃO" FontSize="9" FontWeight="Medium"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   controls:LetterSpacing.Value="1.5" Margin="12,0,0,8" />

                        <Button Style="{StaticResource GhostButton}"
                                Command="{Binding NavigateToCommand}"
                                CommandParameter="Progress"
                                HorizontalContentAlignment="Left"
                                Padding="12,10" Margin="0,2" Height="44">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE9D9;" FontFamily="Segoe MDL2 Assets"
                                           FontSize="16" Margin="0,0,12,0"
                                           Foreground="{StaticResource TextSecondaryBrush}" />
                                <TextBlock Text="Progresso do Aluno" FontSize="14"
                                           Foreground="{StaticResource TextPrimaryBrush}" />
                            </StackPanel>
                        </Button>

                        <Button Style="{StaticResource GhostButton}"
                                Command="{Binding NavigateToCommand}"
                                CommandParameter="Achievements"
                                HorizontalContentAlignment="Left"
                                Padding="12,10" Margin="0,2" Height="44">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE735;" FontFamily="Segoe MDL2 Assets"
                                           FontSize="16" Margin="0,0,12,0"
                                           Foreground="{StaticResource TextSecondaryBrush}" />
                                <TextBlock Text="Conquistas" FontSize="14"
                                           Foreground="{StaticResource TextPrimaryBrush}" />
                            </StackPanel>
                        </Button>

                    </StackPanel>
                </Border>

                <!-- ── Content area — troca de view por DataTrigger ───────── -->
                <ContentControl Grid.Column="1" Margin="0">
                    <ContentControl.Style>
                        <Style TargetType="ContentControl">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding ActiveSection}" Value="Dashboard">
                                    <Setter Property="Content">
                                        <Setter.Value>
                                            <Border Padding="32">
                                                <StackPanel>
                                                    <TextBlock Text="Dashboard" FontSize="22" FontWeight="Bold"
                                                               Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,8"/>
                                                    <TextBlock Text="Bem-vindo ao BIM Concierge."
                                                               Foreground="{StaticResource TextSecondaryBrush}" FontSize="14"/>
                                                </StackPanel>
                                            </Border>
                                        </Setter.Value>
                                    </Setter>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding ActiveSection}" Value="Tutorials">
                                    <Setter Property="Content">
                                        <Setter.Value>
                                            <Border Padding="32">
                                                <TextBlock Text="Biblioteca de Tutoriais" FontSize="22" FontWeight="Bold"
                                                           Foreground="{StaticResource TextPrimaryBrush}"/>
                                            </Border>
                                        </Setter.Value>
                                    </Setter>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding ActiveSection}" Value="Corrections">
                                    <Setter Property="Content">
                                        <Setter.Value>
                                            <Border Padding="32">
                                                <TextBlock Text="Correção em Tempo Real" FontSize="22" FontWeight="Bold"
                                                           Foreground="{StaticResource TextPrimaryBrush}"/>
                                            </Border>
                                        </Setter.Value>
                                    </Setter>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding ActiveSection}" Value="Standards">
                                    <Setter Property="Content">
                                        <Setter.Value>
                                            <Border Padding="32">
                                                <TextBlock Text="Padrões da Empresa" FontSize="22" FontWeight="Bold"
                                                           Foreground="{StaticResource TextPrimaryBrush}"/>
                                            </Border>
                                        </Setter.Value>
                                    </Setter>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding ActiveSection}" Value="Progress">
                                    <Setter Property="Content">
                                        <Setter.Value>
                                            <Border Padding="32">
                                                <TextBlock Text="Progresso do Aluno" FontSize="22" FontWeight="Bold"
                                                           Foreground="{StaticResource TextPrimaryBrush}"/>
                                            </Border>
                                        </Setter.Value>
                                    </Setter>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding ActiveSection}" Value="Achievements">
                                    <Setter Property="Content">
                                        <Setter.Value>
                                            <Border Padding="32">
                                                <TextBlock Text="Conquistas" FontSize="22" FontWeight="Bold"
                                                           Foreground="{StaticResource TextPrimaryBrush}"/>
                                            </Border>
                                        </Setter.Value>
                                    </Setter>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </ContentControl.Style>
                </ContentControl>

            </Grid>
        </Grid>
    </Border>
</Window>
